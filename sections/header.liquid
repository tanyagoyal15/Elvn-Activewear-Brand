{%- liquid
  assign breakpoint_sm_down = 479.98
  assign breakpoint_md = 768
  assign tabbed_collection_block = section.blocks | where: 'type', 'mega-menu-coll-tabs'

  assign show_language = settings.show_language
  if localization.available_languages.size <= 1
    assign show_language = false
  endif

  assign show_country = settings.show_country
  if localization.available_countries.size <= 1
    assign show_country = false
  endif
-%}

{%- if section.settings.enable_search and settings.enable_predictive_search -%}
  <link rel="stylesheet" href="{{ 'mobile-header.css' | asset_url }}" media="print" onload="this.media='all'">
  <noscript><link rel="stylesheet" href="{{ 'mobile-header.css' | asset_url }}"></noscript>
  <link rel="stylesheet" href="{{ 'predictive-search.css' | asset_url }}" media="print" onload="this.media='all'">
  <script src="{{ 'predictive-search.js' | asset_url }}" defer></script>
  <script src="{{ 'tabs.js' | asset_url }}" defer></script>
{%- elsif tabbed_collection_block -%}
  <script src="{{ 'tabs.js' | asset_url }}" defer></script>
{%- endif -%}

{%- style -%}
  {%- if section.settings.logo != blank -%}
    .logo__image {
      width: {{ section.settings.logo_width | plus: 0 }}px;
    }

    @media (max-width: {{ breakpoint_sm_down }}px) {
      .logo__image {
        width: {{ section.settings.logo_width_mobile | plus: 0 }}px;
      }
    }
  {%- endif -%}

  {%- if section.settings.enable_sticky -%}
    .cc-header { position: -webkit-sticky; position: sticky; }
    .viewport-height, .viewport-height .slide {
      min-height: calc(100svh - var(--header-height) + 24px);
    }
  {%- endif -%}

  {%- if section.settings.enable_transparency -%}
    .cc-header { min-height: calc(var(--header-height) - var(--announcement-height, 0px)) }
    .cc-header ~ .banner-candidate.shopify-section-group-header-group,
    .cc-header ~ #main-content > .banner-candidate:first-child { margin-top: calc(var(--header-height) * -1); }
    .cc-header ~ .banner-candidate.shopify-section-group-header-group .screen-height,
    .cc-header ~ #main-content > .banner-candidate:first-child .screen-height { min-height: 100svh; }
    .cc-header ~ .banner-candidate.shopify-section-group-header-group .text-overlay,
    .cc-header ~ #main-content > .banner-candidate:first-child .text-overlay { margin-top: calc(var(--header-height) + 20px); }
    @media (max-width: {{ breakpoint_sm_down }}px) {
      .cc-header ~ .banner-candidate.shopify-section-group-header-group .mobile-stacked .text-overlay,
      .cc-header ~ #main-content > .banner-candidate:first-child .mobile-stacked .text-overlay { margin-top: 0; }
    }
    @media (min-width: {{ breakpoint_md }}px) {
      .cc-header ~ .banner-candidate.shopify-section-group-header-group .text-overlay,
      .cc-header ~ #main-content > .banner-candidate:first-child .text-overlay { margin-top: calc(var(--header-height) + 40px); }
    }
  {%- else -%}
    .cc-header ~ .banner-candidate.shopify-section-group-header-group .screen-height,
    .cc-header ~ #main-content > .banner-candidate:first-child .screen-height {
      min-height: calc(100svh - var(--header-height));
    }
  {%- endif -%}
{%- endstyle -%}

<main-header class="header js-header-height block relative bg-theme-bg text-theme-text
             {%- if section.settings.enable_sticky %} header--sticky{% endif -%}
             {%- if section.settings.enable_transparency %} header--transparent{% endif -%}
             {%- if section.settings.enable_divider_line %} header--divider-line{% endif -%}">
  <div class="overlay absolute top-0 right-0 {% if section.settings.enable_divider_line %}bottom-[-1px]{% else %}bottom-0{% endif %} left-0 header__overlay"></div>
  <div class="header__grid px-6 md:px-12 lg:px-14 py-3 sm:py-4 lg:py-6 flex items-center">
    {%- capture logo_html -%}
      <div class="logo logo--position-{{ section.settings.logo_position }}{% if section.settings.logo_position == 'left' %} lg:pe-12{% else %} lg:px-12{% endif %}">
        <a class="logo__link block relative" href="{{ routes.root_url }}">
          {%- if section.settings.logo != blank -%}
            {%- liquid
              assign logo_width = section.settings.logo_width | at_least: section.settings.logo_width_mobile
              if section.settings.logo.width < logo_width
                assign logo_width = section.settings.logo.width
              endif
            -%}
            {% render 'image',
              image: section.settings.logo,
              src_width: logo_width,
              srcset_2x: true,
              lazy_load: false,
              alt_text: false,
              class: 'logo__image block'
            %}
            {%- if section.settings.contrast_logo -%}
              {% render 'image',
                image: section.settings.contrast_logo,
                src_width: logo_width,
                srcset_2x: true,
                lazy_load: false,
                alt_text: false,
                class: 'logo__contrast-image img-fit img-fit--contain'
              %}
            {%- endif -%}
          {%- endif -%}

          {%- if request.page_type == 'index' and section.settings.logo_h1 -%}
            <h1 class="logo__text x-large-heading text-theme-text m-0{% if section.settings.logo != blank %} visually-hidden{% endif %}">{{ shop.name }}</h1>
          {%- else -%}
            <span class="logo__text x-large-heading text-theme-text m-0{% if section.settings.logo != blank %} visually-hidden{% endif %}">{{ shop.name }}</span>
          {%- endif -%}
        </a>
      </div>
    {%- endcapture -%}

    {%- if section.settings.logo_position == 'left' -%}
      {{ logo_html }}
    {%- endif -%}

    {%- if section.settings.menu != blank -%}
      <main-menu class="main-menu{% if section.settings.logo_position == 'middle' %} flex-1{% endif %}" data-parent-opens-child-mobile="{{ section.settings.parent_opens_child_mobile }}">
        <details class="main-menu__disclosure" open>
          <summary class="main-menu__toggle lg:hidden">
            <div class="main-menu__toggle-icon has-ltr-icon" aria-hidden="true">{% render 'icon-menu' %}</div>
            <span class="visually-hidden">{{ 'general.icon_labels.menu' | t }}</span>
          </summary>
          <div class="main-menu__content">

            <div class="main-menu__mobile-nav-header pt-6 md:pt-8 pb-6 flex justify-between lg:hidden">
              <button class="header__icon header__icon--close text-current js-close-nav">
                {% render 'icon-close' %}
                <span class="visually-hidden">{{ 'general.icon_labels.close' | t }}</span>
              </button>

              {%- if section.settings.enable_localization or shop.customer_accounts_enabled -%}
                <div class="flex">

                  {%- if section.settings.enable_localization -%}
                    {% if show_country or show_language %}
                      <button class="localization-options localization-options--header text-current js-toggle-localization" data-localization-trigger="localization-drawer-header">
                        {% if show_language %}
                          <span class="active-language">{{ localization.language.iso_code }}</span>
                        {% endif %}
                        {% if show_country %}
                          <span class="active-currency">{{ localization.country.currency.symbol }}</span>
                        {% endif %}
                      </button>
                    {% endif %}
                  {%- endif -%}

                  {%- if shop.customer_accounts_enabled -%}
                    {%- if customer -%}
                      <a class="header__icon text-current lg:hidden" href="{{ routes.account_url }}">
                        {% render 'icon-customer' %}
                        <span class="visually-hidden">{{ 'sections.header.account' | t }}</span>
                      </a>
                    {%- else -%}
                      <a class="header__icon text-current lg:hidden" href="{{ routes.account_login_url }}">
                        {% render 'icon-customer' %}
                        <span class="visually-hidden">{{ 'sections.header.log_in' | t }}</span>
                      </a>
                    {%- endif -%}
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>

            <nav aria-label="{{ 'accessibility.main_navigation' | t }}" class="header-nav-menu">
              <div class="mobile-tabs lg:hidden">

                <!-- TABS -->
                <div class="mobile-tabs__list flex border-b">
                  {% for link in section.settings.menu.links %}
                    <button 
                      class="mobile-tab {% if forloop.first %}active{% endif %}" 
                      data-tab="{{ forloop.index }}">
                      {{ link.title }}
                    </button>
                  {% endfor %}
                </div>
              
                <!-- TAB CONTENT -->
                <div class="mobile-tab-content-footer-menu">
                  <div class="mobile-tabs__content">
              
                    {% for link in section.settings.menu.links %}
                      <div 
                        class="mobile-tab-panel {% unless forloop.first %}hidden{% endunless %}" 
                        data-panel="{{ forloop.index }}">
                
                        {% if link.links != blank %}
                
                          {% if link.title == 'Activities' %}
                
                            <!-- ACTIVITIES GRID -->
                            <div class="mobile-grid">
                              {% for child_link in link.links %}
                                {% assign collection = child_link.object %}
                
                                <a href="{{ child_link.url }}" class="mobile-card">
                                  {% if collection.featured_image %}
                                    <div class="mobile-card__image">
                                      <img 
                                        width="100%"
                                        height="100%"
                                        src="{{ collection.featured_image | image_url: width: 600 }}" 
                                        alt="{{ child_link.title }}"
                                      />
                                      <div class="mobile-card__overlay">
                                        {{ child_link.title }}
                                      </div>
                                    </div>
                                  {% endif %}
                                </a>
                
                              {% endfor %}
                            </div>
                
                          {% else %}
                
                            <!-- NORMAL MENU -->
                            <ul class="mobile-tab-links">
                              {% for child_link in link.links %}
                                <li>
                
                                  {% if child_link.links != blank %}
                                    
                                    <details class="mobile-accordion">
                                      <summary class="flex justify-between items-center">
                                        <span>{{ child_link.title }}</span>
                                        <span class="icon">{% render 'icon-chevron-down' %}</span>
                                      </summary>
                
                                      <ul class="mobile-submenu">
                                        {% for grandchild_link in child_link.links %}
                                          <li>
                                            <a href="{{ grandchild_link.url }}">
                                              {{ grandchild_link.title }}
                                            </a>
                                          </li>
                                        {% endfor %}
                                      </ul>
                                    </details>
                
                                  {% else %}
                
                                    <a href="{{ child_link.url }}">
                                      {{ child_link.title }}
                                    </a>
                
                                  {% endif %}
                
                                </li>
                              {% endfor %}
                            </ul>
                
                          {% endif %}
                
                        {% else %}
                          <a href="{{ link.url }}">{{ link.title }}</a>
                        {% endif %}
                
                      </div>
                    {% endfor %}
                
                  </div>
                
                  <div class="mobile-extra-menu">
    
                    {% if section.settings.mobile_footer_menu != blank %}
                      <ul>
                  
                        {% for child_link in section.settings.mobile_footer_menu.links %}
                          <li>
                  
                            {% if child_link.links != blank %}
                              
                              <details class="mobile-accordion">
                                <summary class="flex justify-between items-center">
                                  <span>{{ child_link.title }}</span>
                                  <span class="icon">{% render 'icon-chevron-down' %}</span>
                                </summary>
                  
                                <ul class="mobile-submenu">
                                  {% for grandchild_link in child_link.links %}
                                    <li>
                                      <a href="{{ grandchild_link.url }}">
                                        {{ grandchild_link.title }}
                                      </a>
                                    </li>
                                  {% endfor %}
                                </ul>
                              </details>
                  
                            {% else %}
                  
                              <a href="{{ child_link.url }}">
                                {{ child_link.title }}
                              </a>
                  
                            {% endif %}
                  
                          </li>
                        {% endfor %}
                  
                      </ul>
                    {% endif %}
                  
                    <div class="mobile-social">
                      <a href="#">Instagram</a>
                      <a href="#">Facebook</a>
                      <a href="#">Pinterest</a>
                    </div>
                  
                  </div>
                </div>
              
              </div>
              <ul class="main-nav hidden">
                {%- for link in section.settings.menu.links -%}
                  {%- liquid
                    assign mega_menu_block = false
                    assign link_title_sanitised = link.title | downcase | strip
                    for block in section.blocks
                      assign menu_link_title_sanitised = block.settings.menu_link_title | downcase | strip
                      if menu_link_title_sanitised == link_title_sanitised and block.type contains 'mega-menu'
                        assign mega_menu_block = block
                      endif
                    endfor
                  -%}
                  <li>
                    {%- if link.links == blank and mega_menu_block == false -%}
                      <a class="main-nav__item main-nav__item--primary{% if link.current %} is-active{% endif %}" href="{{ link.url }}"{% if link.current %} aria-current="page"{% endif %}>
                        {{- link.title | escape -}}
                      </a>
                    {%- else -%}
                      <a class="main-nav__item main-nav__item--primary{% if link.current %} is-active{% endif %}" {% if link.current %} aria-current="page"{% endif %}>
                        {{- link.title | escape -}}
                      </a>
                      <details>
                        <summary class="main-nav__summary js-toggle" aria-label="{{ 'accessibility.toggle_submenu' | t: title: link.title }}">
                          {%- render 'icon-chevron-down' -%}
                        </summary>
                        <div class="main-nav__child{% if mega_menu_block %} mega-nav{% endif %}">
                          {% if mega_menu_block %}<div class="mega-nav__grid {{ mega_menu_block.type }} container lg:px-14" {{ mega_menu_block.shopify_attributes }}>{% endif %}
                            <ul class="child-nav">
                              <li class="lg:hidden">
                                <button type="button" class="main-nav__item main-nav__item--back js-back">
                                  <div class="main-nav__item-content has-ltr-icon" aria-label="{{ 'accessibility.close_submenu' | t: title: link.title }}">
                                    {%- render 'icon-chevron-left' %} <span aria-hidden="true">{{ link.title | escape -}}</span>
                                  </div>
                                </button>
                              </li>

                              {%- if mega_menu_block and mega_menu_block.type == 'mega-menu-coll-tabs' -%}
                                <li class="lg:flex-1">
                                  {%- if link.links != blank -%}
                                    <tabbed-content class="w-full block">
                                      <div class="tablist overflow-hidden mb-2">
                                        <div class="tablist__scroller flex" role="tablist">
                                          {%- for child_link in link.links -%}
                                            <button type="button"
                                                    class="tablist__tab custom-case"
                                                    id="mmct-{{ mega_menu_block.id }}-{{ forloop.index }}-tab"
                                                    role="tab"
                                                    {%- unless forloop.first %}tabindex="-1"{% endunless %}
                                                    aria-controls="mmct-{{ mega_menu_block.id }}-{{ forloop.index }}"
                                                    aria-selected="{% if forloop.first %}true{% else %}false{% endif %}">
                                                    {{ child_link.title | escape }}
                                            </button>
                                          {% endfor -%}
                                        </div>
                                      </div>

                                      {%- for child_link in link.links -%}
                                        <div class="main-nav__collection-tabpanel" id="mmct-{{ mega_menu_block.id }}-{{ forloop.index }}" role="tabpanel" aria-labelledby="mmct-{{ mega_menu_block.id }}-{{ forloop.index }}-tab"{% unless forloop.first %} hidden{% endunless %}>
                                          <a class="main-nav__collection-tabpanel-view-all link" href="{{ child_link.url }}">
                                            {{- 'sections.featured_collection.view_all' | t -}}
                                          </a>
                                          {%- liquid
                                            assign product_limit = 6
                                            if promo contains 'div'
                                              assign product_limit = 4
                                            endif

                                            if mega_menu_block.settings.product_rows == '2'
                                              assign product_limit = product_limit | times: 2
                                            endif

                                            capture promo
                                              if forloop.index < 6
                                                assign promo_settings_suffix = '_' | append: forloop.index
                                                assign column_index = child_link.object.products.size | at_most: product_limit
                                                render 'nav-promo', promo_settings: mega_menu_block.settings, settings_suffix: promo_settings_suffix, element: 'div', column_index: column_index
                                              endif
                                            endcapture
                                          -%}
                                          <div class="main-nav__collection-tabpanel-grid max-lg-peek-carousel overflow-auto{% if mega_menu_block.settings.card_cutout %} has-cutout-cards{% endif %}" data-limit="{{ product_limit }}">
                                            {%- for product in child_link.object.products limit: product_limit -%}
                                              {%- if settings.show_gift_wrapping and product.id == settings.gift_wrap_product.id -%}{% continue %}{%- endif -%}
                                              <div class="flex" style="--column-index: {{ forloop.index0 }}">{%- render 'product-card', product: product, disable_quick_shop: true, disable_animate: true, disable_image_blending: mega_menu_block.settings.card_cutout -%}</div>
                                            {%- endfor -%}
                                          </div>
                                          {{- promo -}}
                                        </div>
                                      {%- endfor -%}
                                    </tabbed-content>
                                  {%- endif -%}
                                </li>

                              {%- else -%}
                                {%- liquid
                                  assign find_collection_ratio = false
                                  if mega_menu_block and mega_menu_block.type == 'mega-menu-coll-cards'
                                    assign find_collection_ratio = true
                                    assign card_color_scheme = nil
                                    if mega_menu_block.settings.card_inherit_color_scheme == false
                                      assign card_color_scheme = mega_menu_block.settings.card_color_scheme
                                    endif
                                  endif
                                  if find_collection_ratio
                                    if settings.coll_card_image_ratio == 'shortest'
                                      assign coll_image_ratio = 0
                                      for child_link in link.links
                                        if child_link.type == 'collection_link'
                                          assign collection_featured_image = child_link.object.featured_image | default: child_link.object.products.first.featured_image
                                          if collection_featured_image.aspect_ratio > coll_image_ratio
                                            assign coll_image_ratio = collection_featured_image.aspect_ratio
                                          endif
                                        endif
                                      endfor
                                    elsif settings.coll_card_image_ratio == 'tallest'
                                      assign coll_image_ratio = 99
                                      for child_link in link.links
                                        if child_link.type == 'collection_link'
                                          assign collection_featured_image = child_link.object.featured_image | default: child_link.object.products.first.featured_image
                                          if collection_featured_image.aspect_ratio < coll_image_ratio
                                            assign coll_image_ratio = collection_featured_image.aspect_ratio
                                          endif
                                        endif
                                      endfor
                                    else
                                      assign coll_image_ratio = settings.coll_card_image_ratio
                                    endif
                                  endif
                                -%}
                                {%- for child_link in link.links -%}
                                  <li style="--column-index: {{ forloop.index0 }}">
                                    {%- if mega_menu_block and mega_menu_block.type == 'mega-menu-coll-cards' and child_link.type == 'collection_link' -%}
                                      {%- render 'collection-card',
                                          collection: child_link.object,
                                          image_ratio: coll_image_ratio,
                                          style: mega_menu_block.settings.card_style,
                                          show_count: mega_menu_block.settings.card_show_count,
                                          compact: mega_menu_block.settings.card_compact,
                                          disable_animate: true,
                                          color_scheme: card_color_scheme
                                      -%}

                                    {%- elsif child_link.links == blank -%}
                                      <a class="main-nav__item child-nav__item" href="{{ child_link.url }}"{% if child_link.current %} aria-current="page"{% endif %}>
                                        {{- child_link.title | escape -}}
                                      </a>

                                    {%- else -%}
                                      <a class="main-nav__item child-nav__item" href="{{ child_link.url }}"{% if child_link.current %} aria-current="page"{% endif %}>
                                        {%- if mega_menu_block and mega_menu_block.type == 'mega-menu-columns' and mega_menu_block.settings.show_collection_images and child_link.type == 'collection_link' %}
                                          {%- liquid
                                            assign column_image = false
                                            if mega_menu_block.settings.collection_image_source == 'featured'
                                              assign column_image = child_link.object.featured_image
                                            elsif mega_menu_block.settings.collection_image_source == 'metafield'
                                              assign column_image = child_link.object.metafields.theme.icon
                                            endif
                                          -%}
                                          {%- if column_image -%}
                                            <div class="main-nav__item-image relative lg:mb-4 custom-aspect-ratio" style="--ratio: {{ mega_menu_block.settings.collection_image_ratio }};">
                                              {%- capture sizes %}{% render 'sizes-attribute', grid: true, min: 1, sm: 2, lg: 3, xl: 4 %}{% endcapture -%}
                                              {%- liquid
                                                assign class = 'img-fit'
                                                if settings.coll_card_image_fit == 'contain'
                                                  assign class = 'img-fit img-fit--contain'
                                                else
                                                  assign class = 'img-fit ' | append: settings.coll_image_align
                                                endif
                                              -%}
                                              {%- render 'image',
                                                image: column_image,
                                                widths: '320, 460, 600, 700, 800, 900, 1200',
                                                src_width: 460,
                                                sizes: sizes,
                                                class: class
                                              -%}
                                            </div>
                                          {%- endif -%}
                                        {% endif -%}
                                        <span class="{% if mega_menu_block %}main-nav__heading{% endif %}" role="heading" aria-level="2">{{- child_link.title | escape -}}</span>
                                      </a>
                                      <details open>
                                        <summary class="main-nav__summary js-toggle" aria-label="{{ 'accessibility.toggle_submenu' | t: title: child_link.title }}">
                                          {%- render 'icon-chevron-right' -%}
                                        </summary>
                                        <ul class="main-nav__grandchild{% if mega_menu_block %} mega-nav__list{% endif %}">
                                          {%- for grandchild_link in child_link.links -%}
                                            <li>
                                              <a class="main-nav__item{% if mega_menu_block %} mega-nav__item{% endif %}" href="{{ grandchild_link.url }}"{% if grandchild_link.current %} aria-current="page"{% endif %}>
                                                {{- grandchild_link.title | escape -}}
                                              </a>
                                            </li>
                                          {%- endfor -%}
                                        </ul>
                                      </details>
                                    {%- endif -%}
                                  </li>
                                {%- endfor -%}
                              {%- endif -%}
                            </ul>
                            {%- if mega_menu_block -%}
                              {%- if mega_menu_block.type == 'mega-menu-columns' or mega_menu_block.type == 'mega-menu-promos' -%}
                                {%- liquid
                                  assign column_index = link.links.size
                                  capture nav_promo_html
                                    render 'nav-promo', promo_settings: mega_menu_block.settings, settings_suffix: '_1', column_index: column_index
                                    assign column_index = column_index | plus: 1
                                    render 'nav-promo', promo_settings: mega_menu_block.settings, settings_suffix: '_2', column_index: column_index
                                    assign column_index = column_index | plus: 1
                                    if mega_menu_block.type == 'mega-menu-promos'
                                      render 'nav-promo', promo_settings: mega_menu_block.settings, settings_suffix: '_3', column_index: column_index
                                      assign column_index = column_index | plus: 1
                                      render 'nav-promo', promo_settings: mega_menu_block.settings, settings_suffix: '_4', column_index: column_index
                                      assign column_index = column_index | plus: 1
                                      render 'nav-promo', promo_settings: mega_menu_block.settings, settings_suffix: '_5', column_index: column_index
                                    endif
                                  endcapture
                                  assign promo_count = nav_promo_html | split: 'main-nav__promo ' | size | minus: 1
                                -%}
                                {%- if promo_count > 0 -%}
                                  <ul class="main-nav__adjacent-promos" data-count="{{ promo_count }}">
                                    {{- nav_promo_html -}}
                                  </ul>
                                {%- endif -%}
                              {%- endif -%}
                            {%- endif -%}
                          {% if mega_menu_block %}</div>{% endif %}
                        </div>
                      </details>
                    {%- endif -%}
                  </li>
                {%- endfor -%}
              </ul>
            </nav>

            {%- capture social_media -%}{%- render 'social-media', icon: settings.social_custom_icon, icon_height: 28, class: ' gap-4 justify-start w-full' -%}{%- endcapture -%}
            {% if social_media contains '</a>' %}
              <div class="main-nav__social pt-10 flex-none lg:hidden">
                {{- social_media -}}
              </div>
            {% endif %}
          </div>
        </details>
      </main-menu>
    {%- endif -%}

    {%- if section.settings.logo_position == 'middle' -%}
      {{ logo_html }}
    {%- endif -%}

    <div class="header__icons flex-1 flex justify-end items-center">
      <a class="header__icon text-current" href="https://wa.me/919892836850" target="_blank" rel="noopener">
        {% render 'icon-whatsapp' %}
        <span class="visually-hidden">WhatsApp</span>
      </a>
      {%- if section.settings.enable_localization -%}
        {% if show_country or show_language %}
