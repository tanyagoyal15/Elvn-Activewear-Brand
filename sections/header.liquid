<script>
  // From set-dimensions.js
  requestAnimationFrame(() => {
    const header = document.querySelector('.js-header-height');
    if (!header) return;
    let height = header.offsetHeight;

    // Add announcement bar height (if shown).
    const announcement = document.querySelector('.cc-announcement');
    const announcementHeight = announcement ? announcement.offsetHeight : 0;
    height += announcementHeight;

    document.documentElement.style.setProperty('--announcement-height', `${announcementHeight}px`);
    document.documentElement.style.setProperty('--header-height', `${height}px`);
  });
</script>

<script>
  (function () {
    'use strict';
  
    var MOBILE_BREAKPOINT = 990;
    var initialized = false;
  
    function isMobile() {
      return window.innerWidth < MOBILE_BREAKPOINT;
    }
  
    function disableThemeDetailsDisclosure() {
      document.querySelectorAll('details-disclosure').forEach(function (el) {
        el.replaceWith(...el.childNodes);
      });
    }
  
    function closeSiblingDetails(currentDetails) {
      var parent = currentDetails.parentElement;
      var grandparent = parent ? parent.parentElement : null;
      if (!grandparent) return;
  
      var siblings = grandparent.querySelectorAll(':scope > li > details');
      siblings.forEach(function (sib) {
        if (sib !== currentDetails && sib.hasAttribute('open')) {
          sib.removeAttribute('open');
        }
      });
    }
  
    function handleSummaryClick(e) {
      if (!isMobile()) return;
      const summary = e.currentTarget;
    
      if (summary.closest('.mobile-tabs')) return;
      e.preventDefault();
      e.stopImmediatePropagation();
    
      var details = summary.closest('details');
      if (!details) return;
    
      var isOpen = details.hasAttribute('open');
    
      closeSiblingDetails(details);
    
      if (isOpen) {
        details.removeAttribute('open');
      } else {
        details.setAttribute('open', '');
      }
    }
  
    function handleParentClick(e) {
      if (!isMobile()) return;
  
      var link = e.currentTarget;
      var parent = link.closest('li');
      var details = parent ? parent.querySelector('details') : null;
  
      if (!details) return;
  
      e.preventDefault();
      e.stopImmediatePropagation(); // 🔥 MUST
  
      var isOpen = details.hasAttribute('open');
  
      closeSiblingDetails(details);
  
      if (isOpen) {
        details.removeAttribute('open');
      } else {
        details.setAttribute('open', '');
      }
    }
  
    function initAccordion() {
      if (!isMobile()) return;
      if (initialized) return;
  
      disableThemeDetailsDisclosure();
  
      var mainMenu = document.querySelector('main-menu');
      if (!mainMenu) return;
  
      var summaries = mainMenu.querySelectorAll(
        '.main-nav > li > details > summary.main-nav__summary');      
      summaries.forEach(function (summary) {
        summary.addEventListener('click', handleSummaryClick);
      });
  
      var parentLinks = mainMenu.querySelectorAll('.main-nav__item--primary');
      parentLinks.forEach(function (link) {
        link.addEventListener('click', handleParentClick);
      });
  
      var grandchildDetails = mainMenu.querySelectorAll('.child-nav details');
      grandchildDetails.forEach(function (d) {
        d.removeAttribute('open');
      });
  
      initialized = true;
    }

    if (!document.querySelector('.mobile-tabs')) {
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAccordion);
      } else {
        initAccordion();
      }
    }
  
    window.addEventListener('resize', function () {
      if (!isMobile()) {
        initialized = false;
      } else {
        initAccordion();
      }
    });
  
  })();

  document.addEventListener("DOMContentLoaded", function () {
    const tabs = document.querySelectorAll(".mobile-tab");
    const panels = document.querySelectorAll(".mobile-tab-panel");
  
    if (panels.length) {
      panels[0].classList.add("is-active");
    }
  
    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        const target = tab.dataset.tab;
  
        tabs.forEach(t => t.classList.remove("active"));
        tab.classList.add("active");
  
        panels.forEach(panel => {
          if (panel.dataset.panel === target) {
            panel.classList.remove("hidden");
  
            requestAnimationFrame(() => {
              panel.classList.add("is-active");
            });
  
          } else {
            panel.classList.remove("is-active");
  
            panel.classList.add("hidden");
          }
        });
      });
    });
  });

  document.addEventListener("DOMContentLoaded", function () {
    document.querySelectorAll(".mobile-tab details summary").forEach(summary => {
      summary.addEventListener("click", function (e) {
        e.preventDefault();
  
        const parent = summary.parentElement;
        parent.toggleAttribute("open");
      });
    });
  });

  document.addEventListener("DOMContentLoaded", function () {
    document.querySelectorAll(".mobile-tab details summary").forEach(summary => {
      summary.addEventListener("click", function (e) {
        e.preventDefault();
  
        const parent = summary.parentElement;
  
        document.querySelectorAll(".mobile-tab details").forEach(d => {
          if (d !== parent) d.classList.remove("is-open");
        });
  
        parent.classList.toggle("is-open");
      });
    });
  });
</script>

<style>
  @media (max-width: 767.98px) {
    .mobile-tabs {
      height: 90vh;
    }
    .header-nav-menu {
      padding-top: 0px !important;
    }

    .mobile-tabs__list {
      display: flex;
      border-bottom: 1px solid #ddd;
    }
    
    .mobile-tab {
      font-size: 12px;
      text-transform: uppercase;
      flex: 1;
      padding: 12px;
      text-align: center;
      font-weight: 500;
      border-bottom: 2px solid transparent;
    }
    
    .mobile-tab.active {
      font-weight: 700;
      border-bottom: 2px solid black;
    }
    
    .mobile-tab-panel.hidden {
      display: none;
    }

    .mobile-tab-links {
      margin-top: 20px;
    }
    
    .mobile-tab-links li {
      font-size: 12px;
      margin-bottom: 12px;
    }

    .mobile-tab details summary .icon {
      transition: transform 0.25s ease;
    }
    
    .mobile-tab details[open] summary .icon {
      transform: rotate(180deg);
    }

    .mobile-submenu {
      padding-left: 16px;
      margin-top: 8px;
    }
    
    .mobile-submenu li {
      {% comment %} padding: 8px 0; {% endcomment %}
    }
    
    .mobile-tab-links > li > details > summary {
      cursor: pointer;
    }

    .mobile-tab details .mobile-submenu {
      display: none;
    }
    
    .mobile-tab details.is-open .mobile-submenu {
      display: block;
    }

    .mobile-tab-panel {
      opacity: 0;
      transform: translateY(8px);
      transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .mobile-tab-panel.is-active {
      opacity: 1;
      transform: translateY(0);
    }

    .mobile-grid {
      display: grid;
      gap: 20px;
      margin-top: 20px;
    }

    .mobile-card__image {
      position: relative;
      width: 100%
    }

    .mobile-card__image img {
      aspect-ratio: 4 / 1;
      object-fit: cover;
    }

    .mobile-card__overlay {
      position: absolute;
      bottom: 20px;
      left: 20px;
      font-size: 14px;
      margin-top: 4px;
      opacity: 0.9;
      text-shadow: 0 0 6px rgba(0, 0, 0, 0.2);
      letter-spacing: 0.4px;
      color: #fff;
      font-weight: bold;
      text-transform: uppercase;
      text-align: center;
    }

    .mobile-extra-menu {
      margin-top: 32px;
      padding: 20px 0 10px;
      border-top: 1px solid #eee;
      margin-top: auto;
    }
    
    .mobile-extra-menu ul li {
      padding: 6px 0;
    }
    
    .mobile-extra-menu a {
      font-size: 12px;
      opacity: 0.7;
      letter-spacing: 0.5px;
    }
    
    .mobile-social {
      display: flex;
      gap: 16px;
      margin-top: 16px;
    }
    
    .mobile-social a {
      font-size: 12px;
      opacity: 0.6;
    }

    .mobile-tab-content-footer-menu {
      display: flex;
      flex-direction: column;
      height: 100%;
      flex: 1;
    }

    .mobile-tabs__content {
      flex: 1;
    }

    .main-menu__mobile-nav-header {
      padding: 0;
    }

    .mobile-tab-links .icon svg {
      width: 16px;
      height: 16px;
    }
  }
</style>
  
