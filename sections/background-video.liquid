<link rel="stylesheet" href="{{ 'video.css' | asset_url }}" {%- render 'lazy-stylesheet-attrs' %}>
<script src="{{ 'video.js' | asset_url }}" defer></script>

{%- liquid
  # shared variables
  assign color_scheme = section.settings.color_scheme
  assign bg_color = section.settings.color_scheme.settings.background

  if bg_color.alpha == 0
    assign bg_color = false
  endif

  assign full_width = section.settings.full_width

  assign bg_image_enabled = false
  if section.settings.background_mode == 'image'
    assign bg_image_enabled = true
  endif

  assign bg_image_exists = false
  if section.settings.background_image != blank
    assign bg_image_exists = true
  endif

  # unique variables
  if section.index == 1 or section.settings.prevent_animation
    assign lazy_load_images = false
  else
    assign lazy_load_images = true
  endif

  assign overlay_position = section.settings.overlay_position | split: ' '

  assign placeholder_url = "https://www.youtube.com/watch?v=_9VUPq3SxOc"
-%}

{%- style -%}
  {%- comment -%} Section background {%- endcomment -%}
  {%- if section.settings.full_width == false -%}
    {%- if section.settings.background_mode == 'color' -%}
      #{{ section.id }} { background: {{ section.settings.background_color }}; }
    {%- elsif section.settings.background_mode == 'simple-gradient' -%}
      #{{ section.id }} {
        background: {% render 'custom-gradient',
                        type: section.settings.background_gradient_curve,
                        start_color: section.settings.background_gradient_stop_1,
                        end_color: section.settings.background_gradient_stop_2
                    %};
      }
    {%- elsif section.settings.background_mode == 'advanced-gradient' -%}
      #{{ section.id }} { background: {{ section.settings.background_gradient }}; }
    {%- endif -%}
  {%- endif -%}

  {%- comment -%} Overlay background - color {%- endcomment -%}
  {%- unless bg_color == false -%}
    #{{ section.id }} .text-overlay { background: {{ bg_color }}; }
  {%- endunless-%}

  {%- comment -%} Video tint {%- endcomment -%}
  {%- if section.settings.tint_opacity > 0 -%}
    #{{ section.id }} .media::after {
      background-color: rgba({{ section.settings.tint_color.rgb }} / {{ section.settings.tint_opacity | divided_by: 100.0 }});
    }
  {%- endif -%}

  {%- comment -%} Minimum size {%- endcomment -%}
  #{{ section.id }} .video-section::after {
    content: '';
    {%- if section.settings.video_height == 'full' -%}
      padding-top: var(--viewport-height, 100lvh);
    {%- elsif section.settings.video_height == 'landscape' -%}
      padding-top: 56.25%;
    {%- elsif section.settings.video_height == 'lg' -%}
      padding-top: 60vh;
    {%- elsif section.settings.video_height == 'md' -%}
      padding-top: 45vh;
    {%- else -%}
      padding-top: 30vh;
    {%- endif -%}
  }

  {%- if section.settings.video_height != 'full' and section.settings.video_height != 'landscape' -%}
    @media(min-width: 768px){
      #{{ section.id }} .video-section::after {
      {%- if section.settings.video_height == 'lg' -%}
        padding-top: 80vh;
      {%- elsif section.settings.video_height == 'md' -%}
        padding-top: 65vh;
      {%- else -%}
        padding-top: 50vh;
      {%- endif -%}
      }
    }
  {% endif %}

{%- endstyle -%}

{%- capture video_component -%}
  {% if section.settings.video_shopify != blank %}
    <video-component class="has-video block w-full h-full" data-video-id="{{ section.id }}" data-resume-on-scroll-up="true" data-autoplay="true" data-background="true" data-description="{{ section.settings.video_description | escape }}">
      {{ section.settings.video_shopify | video_tag: playsinline: true, autoplay: true, muted: true, loop: true, poster: '' | replace: '<img ', '<img loading="lazy" hidden ' }}
    </video-component>
  {% else %}
    <video-component class="has-iframe block w-full h-full" data-video-url="{{ placeholder_url | escape }}" data-video-id="{{ section.id }}" data-resume-on-scroll-up="true" data-autoplay="true" data-background="true" data-description="{{ section.settings.video_description | escape }}">
      <div></div>
    </video-component>
  {% endif %}
{%- endcapture -%}

<div id="{{ section.id }}" class="section-background{% if full_width == false and bg_image_enabled %} relative{% endif %}">

{% if full_width == false %}
  {%- if bg_image_enabled and bg_image_exists -%}
  <div class="absolute inset-0">
    {%- render 'image',
      image: section.settings.background_image,
      src_width: 1400,
      widths: '480, 980, 1200, 1400, 1600, 1920, 2560, 3200',
      class: 'img-fit cover',
      sizes: '100vw'
    -%}
  </div>
  {%- endif -%}

  <div class="flex wide-container w-full">
{% endif %}
    <div class="section color-scheme color-scheme--no-bg color-scheme--{{ color_scheme }}
                  {%- unless bg_color == false %} color-scheme--section{%- endunless %}
                  {%- if full_width == false %} section--boundary-{{ section.settings.section_join_mode }}{% endif %}
                  {%- if full_width %}section--full-width{% else %}section--inset-banner section--border-radius overflow-hidden{% endif %}
                  {%- if section.settings.mobile_stacked and section.settings.height_mode != 'screen' %}
                    mobile-stacked
                    {%- if full_width and bg_color == false or bg_color == settings.default_color_scheme.settings.background %} mobile-stacked--spaced{% endif %}
                  {%- endif %}"
            data-section-index="{{ section.index }}">
      <div class="video-section bg-video-section relative flex mx-auto overflow-hidden {{ overlay_position | first }} {{ overlay_position | last }}">

        {%- if section.blocks.size > 0 -%}
          <div class="video-section__text container container--full container--padded-xl flex {{ overlay_position | first }}{% if section.settings.mob_center_text %} md-down:center md-down:justify-center{% endif %}{% unless bg_color %}{% if section.settings.mobile_stacked %} md-down:p-xl h-full md:h-auto{% endif %}{% endunless %}" {%- render 'animation-attrs', attrs: 'data-cc-animate' -%}>

            {% liquid
              assign max_overlay_override = ""

              if section.settings.overlay_width_override
                assign max_overlay_override = 'style="--overlay-max-width: ' | append: section.settings.overlay_max_width | append: 'px"'
              endif

              assign text_overlay_classes = ""
              # - Padding when background color isn't transparent
              if bg_color
                assign text_overlay_classes = text_overlay_classes | append: " text-overlay--bg"
              endif
              # - Text Alignment
              assign text_overlay_classes = text_overlay_classes | append: " " | append: section.settings.overlay_text_align
              # - Text Alignment (Mobile Override)
              if section.settings.mob_center_text
                assign text_overlay_classes = text_overlay_classes | append: " md-down:text-center"
              endif
              # - Animation
              assign text_overlay_classes = text_overlay_classes | append: " has-motion"
            %}

            <div class="text-overlay text-overlay--background-video{{ text_overlay_classes }}" {{ max_overlay_override }}>

            {%- for block in section.blocks -%}
                {%- case block.type -%}

                  {%- when 'subheading' -%}
                    {%- if block.settings.text != blank -%}
                      <p class="text-overlay__subheading text-overlay__block subheading" {{ block.shopify_attributes }}>
                        {{- block.settings.text | escape -}}
                      </p>
                    {%- endif -%}

                  {%- when 'heading' -%}
                    {%- if block.settings.heading != blank -%}
                      {%- if block.settings.heading_h1 -%}
                        <h1 class="text-overlay__heading text-overlay__block md:{{ block.settings.heading_size_desktop }} {{ block.settings.heading_size_mobile }}" {{ block.shopify_attributes }}>
                          {{- block.settings.heading | newline_to_br -}}
                        </h1>
                      {%- else -%}
                        <h2 class="text-overlay__heading text-overlay__block md:{{ block.settings.heading_size_desktop }} {{ block.settings.heading_size_mobile }}" {{ block.shopify_attributes }}>
                          {{- block.settings.heading | newline_to_br -}}
                        </h2>
                      {%- endif -%}
                    {%- endif -%}

                  {%- when 'text' -%}
                    {%- if block.settings.text != blank -%}
                      <div class="text-overlay__text text-overlay__block rte{% if block.settings.enlarge_text %} text-lg{% endif %}" {{ block.shopify_attributes }}>
                        {{ block.settings.text }}
                      </div>
                    {%- endif -%}

                  {%- when 'countdown' -%}
                    {%- style -%}
                      #{{ section.id }} .countdown__grid {
                        font-size: calc(({{ block.settings.number_size }} / 1.25) * var(--fluid-1-25));
                      }
                    {%- endstyle -%}
                    <script src="{{ 'countdown-timer.js' | asset_url }}" defer></script>
                    <div class="text-overlay__countdown text-overlay__block text-overlay__block--spaced countdown-font-{{ block.settings.number_font }} no-js-hidden" {{ block.shopify_attributes }}>
                      {% render 'countdown-timer',
                        end_date: block.settings.end_date,
                        end_time: block.settings.end_time,
                        end_text: block.settings.end_text,
                        end_midnight: true,
                        hide_on_end: block.settings.hide_on_end,
                        show_labels: block.settings.show_timer_labels
                      %}
                    </div>

                  {%- when 'button' -%}
                    {%- if block.settings.button_1_label != blank or block.settings.button_2_label != blank -%}
                      <div class="text-overlay__buttons text-overlay__block flex flex-wrap md:gap-6 gap-4 items-start {% if section.settings.overlay_text_align == 'text-start' %} justify-start{% elsif section.settings.overlay_text_align == 'text-end' %} justify-end{% else %} justify-center{% endif %}{% if section.settings.mob_center_text %}  md-down:justify-center md-down:center{% endif %}">
                        {%- if block.settings.button_1_label != blank -%}
                          <a class="{{ block.settings.button_1_style }} md:px-12" {% if block.settings.button_1_link == blank %}role="link" aria-disabled="true"{% else %}href="{{ block.settings.button_1_link }}"{% endif %}>
                            {{- block.settings.button_1_label | escape -}}
                          </a>
                        {%- endif -%}

                        {%- if block.settings.button_2_label != blank -%}
                          <a class="{{ block.settings.button_2_style }} md:px-12" {% if block.settings.button_2_link == blank %}role="link" aria-disabled="true"{% else %}href="{{ block.settings.button_2_link }}"{% endif %}>
                            {{- block.settings.button_2_label | escape -}}
                          </a>
                        {%- endif -%}
                      </div>
                    {%- endif -%}

                {%- endcase -%}
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}

        <div class="video-section__media block w-full vertical-center absolute top-0 left-0 h-full">
          {%- if section.settings.lazyload == false -%}
            <div class="video-section__bg-video pointer-events-none absolute top-0 left-0 w-full h-full">
              {{ video_component }}
            </div>
          {%- else -%}
            <deferred-media class="video-section__bg-video block pointer-events-none absolute top-0 left-0 w-full h-full no-js-hidden">
              <template>{{ video_component }}</template>
            </deferred-media>

            <noscript>
              <div class="video-section__bg-video pointer-events-none absolute top-0 left-0 w-full h-full">
                {{ video_component }}
              </div>
            </noscript>
          {%- endif -%}

          <div class="media media--has-overlay absolute top-0 left-0 w-full h-full">
            {%- liquid
              assign sizes = false
              assign class = 'img-fit object-center video-played-hidden'
            -%}
            {%- if section.settings.poster_image != blank or section.settings.video_shopify != blank -%}
              {%- assign poster_image = section.settings.poster_image | default: section.settings.video_shopify.preview_image -%}
              {% render 'image',
                image: poster_image,
                widths: '750, 856, 1440, 1680, 1920, 2560',
                src_width: 1680,
                sizes: sizes,
                lazy_load: lazy_load_images,
                class: class
              %}
            {%- else -%}
              {%- assign class = class | prepend: 'media__placeholder ' -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: class }}
            {%- endif -%}
          </div>
        </div>

      </div>
    </div>
{% if full_width == false %}
  </div>
{% endif %}

</div>

{% schema %}
{
  "name": "Background video",
  "tag": "section",
  "class": "cc-background-video banner-candidate",
  "settings": [
    {
      "type": "paragraph",
      "content": "Background videos are designed to autoplay and be silent."
    },
    {
      "type": "video",
      "id": "video_shopify",
      "label": "Video upload"
    },
    {
      "type": "text",
      "id": "video_description",
      "label": "Video description",
      "info": "Describe the video for customers using screen readers."
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Cover image",
      "info": "Required. Shows while the video is loading, or if it cannot autoplay."
    },
    {
      "type": "header",
      "content": "Video layout"
    },
    {
      "type": "select",
      "id": "video_height",
      "label": "Minimum video size",
      "options": [
        {
          "value": "landscape",
          "label": "Landscape (16:9)"
        },
        {
          "value": "sm",
          "label": "Small"
        },
        {
          "value": "md",
          "label": "Medium"
        },
        {
          "value": "lg",
          "label": "Large"
        },
        {
          "value": "full",
          "label": "Full screen height"
        }
      ],
      "default": "md"
    },
    {
      "type": "header",
      "content": "Video styles"
    },
    {
      "type": "color",
      "id": "tint_color",
      "label": "Video tint color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "tint_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Video tint opacity",
      "default": 0,
      "info": "Does not apply if fade is used below"
    },
    {
      "type": "header",
      "content": "Text overlay"
    },
    {
      "type": "select",
      "id": "overlay_position",
      "label": "Overlay position",
      "options": [
        {
          "value": "justify-start items-start",
          "label": "Top left"
        },
        {
          "value": "justify-center items-start",
          "label": "Top center"
        },
        {
          "value": "justify-end items-start",
          "label": "Top right"
        },
        {
          "value": "justify-start items-center",
          "label": "Middle left"
        },
        {
          "value": "justify-center items-center",
          "label": "Middle center"
        },
        {
          "value": "justify-end items-center",
          "label": "Middle right"
        },
        {
          "value": "justify-start items-end",
          "label": "Bottom left"
        },
        {
          "value": "justify-center items-end",
          "label": "Bottom center"
        },
        {
          "value": "justify-end items-end",
          "label": "Bottom right"
        }
      ],
      "default": "justify-start items-center"
    },
    {
      "type": "select",
      "id": "overlay_text_align",
      "label": "Text alignment",
      "options": [
        {
          "value": "text-start",
          "label": "Left"
        },
        {
          "value": "text-center",
          "label": "Center"
        },
        {
          "value": "text-end",
          "label": "Right"
        }
      ],
      "default": "text-start"
    },
    {
      "type": "checkbox",
      "id": "overlay_width_override",
      "label": "Custom overlay width",
      "default": false
    },
    {
      "visible_if": "{{ section.settings.overlay_width_override }}",
      "type": "range",
      "id": "overlay_max_width",
      "min": 400,
      "max": 900,
      "step": 10,
      "unit": "px",
      "label": "Maximum overlay width",
      "default": 640
    },
    {
      "type": "checkbox",
      "id": "mob_center_text",
      "label": "Center text on mobile",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-3"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": true
    },
    {
      "visible_if": "{{ section.settings.full_width == false }}",
      "type": "select",
      "id": "background_mode",
      "label": "Section background",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "color",
          "label": "Color"
        },
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "simple-gradient",
          "label": "Simple gradient"
        },
        {
          "value": "advanced-gradient",
          "label": "Advanced gradient"
        }
      ],
      "default": "default"
    },
    {
      "visible_if": "{{ section.settings.full_width == false and section.settings.background_mode == 'color' }}",
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "visible_if": "{{ section.settings.full_width == false and section.settings.background_mode == 'image' }}",
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "visible_if": "{{ section.settings.full_width == false and section.settings.background_mode == 'simple-gradient' }}",
      "type": "color",
      "id": "background_gradient_stop_1",
      "label": "Gradient start",
      "default": "#cccccc"
    },
    {
      "visible_if": "{{ section.settings.full_width == false and section.settings.background_mode == 'simple-gradient' }}",
      "type": "color",
      "id": "background_gradient_stop_2",
      "label": "Gradient end",
      "default": "#ffffff"
    },
    {
      "visible_if": "{{ section.settings.full_width == false and section.settings.background_mode == 'simple-gradient' }}",
      "type": "select",
      "id": "background_gradient_curve",
      "label": "Gradient style",
      "options": [
        {
          "value": "linear",
          "label": "Linear"
        },
        {
          "value": "ease-up",
          "label": "Ease up"
        },
        {
          "value": "ease-down",
          "label": "Ease down"
        }
      ],
      "default": "linear"
    },
    {
      "visible_if": "{{ section.settings.full_width == false and section.settings.background_mode == 'advanced-gradient' }}",
      "type": "color_background",
      "id": "background_gradient",
      "label": "Advanced gradient",
      "default": "linear-gradient(#f8f1f4, #f8f1f4 12%, #c8bdc1, #e8dccc 92%)"
    },
    {
      "visible_if": "{{ section.settings.full_width == false }}",
      "type": "header",
      "content": "Layout"
    },
    {
      "visible_if": "{{ section.settings.full_width == false }}",
      "type": "select",
      "id": "section_join_mode",
      "label": "Boundary above section",
      "info": "Some sections support seamless joining",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "tight",
          "label": "Tight"
        },
        {
          "value": "join",
          "label": "Join"
        }
      ],
      "default": "default"
    },
    {
      "type": "header",
      "content": "Advanced"
    },
    {
      "type": "checkbox",
      "id": "lazyload",
      "label": "Lazy load the video",
      "info": "This will load the video only when it's about to come into view. Turn this off if you'd rather the video had the best chance of auto-playing on older devices, or if this section is visible when the page loads.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "prevent_animation",
      "label": "Load the section without animation",
      "info": "If this section is visible when the page loads, enabling this setting can reduce CLS and may improve site speed scores. [Read more](https://cleancanvas.co.uk/support/beautify/performance-guide)",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "subheading",
      "name": "Subheading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Subheading",
          "default": "Subheading"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Talk about your brand"
        },
        {
          "type": "select",
          "id": "heading_size_desktop",
          "label": "Heading size (desktop)",
          "options": [
            {
              "value": "h4",
              "label": "Extra extra small"
            },
            {
              "value": "h3",
              "label": "Extra small"
            },
            {
              "value": "h2",
              "label": "Small"
            },
            {
              "value": "h1",
              "label": "Medium"
            },
            {
              "value": "x-large-heading",
              "label": "Large"
            },
            {
              "value": "xx-large-heading",
              "label": "Extra large"
            }
          ],
          "default": "h1"
        },
        {
          "type": "select",
          "id": "heading_size_mobile",
          "label": "Heading size (mobile)",
          "options": [
            {
              "value": "h4",
              "label": "Extra extra small"
            },
            {
              "value": "h3",
              "label": "Extra small"
            },
            {
              "value": "h2",
              "label": "Small"
            },
            {
              "value": "h1",
              "label": "Medium"
            },
            {
              "value": "x-large-heading",
              "label": "Large"
            },
            {
              "value": "xx-large-heading",
              "label": "Extra large"
            }
          ],
          "default": "h1"
        },
        {
          "type": "checkbox",
          "id": "heading_h1",
          "label": "Set as page heading (uses h1 tag)",
          "info": "For optimum SEO, a page should only have one h1 and it should be the first heading on the page.",
          "default": false
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Share information about your brand with your customers. Describe a product, make announcements, or welcome customers to your store.</p>"
        },
        {
          "type": "checkbox",
          "id": "enlarge_text",
          "label": "Enlarge text",
          "default": false
        }
      ]
    },
    {
      "type": "button",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_1_label",
          "label": "Button 1 label",
          "default": "Button"
        },
        {
          "type": "url",
          "id": "button_1_link",
          "label": "Button 1 link"
        },
        {
          "type": "select",
          "id": "button_1_style",
          "label": "Button 1 style",
          "options": [
            {
              "value": "link",
              "label": "Link"
            },
            {
              "value": "btn btn--primary",
              "label": "Primary button"
            },
            {
              "value": "btn btn--secondary",
              "label": "Secondary button"
            }
          ],
          "default": "btn btn--primary"
        },
        {
          "type": "text",
          "id": "button_2_label",
          "label": "Button 2 label",
          "default": "Button"
        },
        {
          "type": "url",
          "id": "button_2_link",
          "label": "Button 2 link"
        },
        {
          "type": "select",
          "id": "button_2_style",
          "label": "Button 2 style",
