{%- liquid
  assign img = section.settings.image_desktop
  assign m_img = section.settings.image_mobile

  if section.index == 1
    assign lazy_load_images = false
  else
    assign lazy_load_images = true
  endif

  assign overlay_position = section.settings.overlay_position | split: ' '
  assign color_scheme = section.settings.color_scheme
  assign bg_color = section.settings.color_scheme.settings.background

  if bg_color.alpha == 0
    assign bg_color = false
  endif

  assign gutter_lg = 56
  assign breakpoint_sm_down = 480 | minus: 0.02
  assign breakpoint_sm = 480
  assign breakpoint_xxl = 1536
  assign breakpoint_page = settings.max_page_width | default: 1320 | plus: gutter_lg | plus: gutter_lg
-%}

{%- style -%}
  #{{ section.id }} {
    --duration: {{ section.settings.speed }}s;
    --direction: {{ section.settings.direction }};
    --image-top-fade-depth: {{ section.settings.top_fade_depth }}px;
    --image-top-fade-bg: {% render 'custom-gradient', type: 'ease-up-out', start_color: section.settings.top_fade_color.rgb, start_opacity: 1 %};
    --image-bottom-fade-depth: {{ section.settings.bottom_fade_depth }}px;
    --image-bottom-fade-bg: {% render 'custom-gradient', type: 'ease-down-out', start_color: section.settings.bottom_fade_color.rgb, start_opacity: 1 %};
  }


  {%- if section.settings.full_width == false -%}
    {%- if section.settings.background_mode == 'color' -%}
      #{{ section.id }} { background: {{ section.settings.background_color }}; }
    {%- elsif section.settings.background_mode == 'simple-gradient' -%}
      #{{ section.id }} {
        background: {% render 'custom-gradient',
                        type: section.settings.background_gradient_curve,
                        start_color: section.settings.background_gradient_stop_1,
                        end_color: section.settings.background_gradient_stop_2
                    %};
      }
    {%- elsif section.settings.background_mode == 'advanced-gradient' -%}
      #{{ section.id }} { background: {{ section.settings.background_gradient }}; }
    {%- endif -%}
  {%- endif -%}

  #{{ section.id }} .scrolling-banner { background: {{ bg_color }}; }
  #{{ section.id }} .section { --section-padding: {{ section.settings.section_height }}px; }

  {%- if section.settings.height_mode == 'fixed' -%}
    #{{ section.id }} .image-banner { min-height: {{ section.settings.fixed_height_mobile }}px; }

    {%- if section.settings.mobile_stacked -%}
      @media (max-width: {{ breakpoint_sm_down }}px) {
        #{{ section.id }} .image-banner__image { min-height: {{ section.settings.fixed_height_mobile }}px; }
      }
    {%- endif -%}

    @media (min-width: {{ breakpoint_sm }}px) {
      #{{ section.id }} .image-banner {
        min-height: calc({{ section.settings.fixed_height_mobile }}px + ({{ section.settings.fixed_height_desktop }} - {{ section.settings.fixed_height_mobile }}) * ((100vw - {{ breakpoint_sm }}px) / {{ breakpoint_xxl | minus: breakpoint_sm }}));
      }
    }
    @media (min-width: {{ breakpoint_page }}px) {
      #{{ section.id }} .image-banner { min-height: {{ section.settings.fixed_height_desktop }}px; }
    }
  {%- elsif section.settings.height_mode == 'auto' -%}
    {%- liquid
      if img != blank
        assign img_ratio = img.aspect_ratio
      else
        assign img_ratio = 1.77
      endif
      if m_img != blank
        assign m_img_ratio = m_img.aspect_ratio
      else
        assign m_img_ratio = img_ratio
      endif
    -%}
    #{{ section.id }} .image-banner {
      aspect-ratio: {{ img_ratio }};
    }

    {%- if m_img != blank -%}
      @media (max-width: {{ breakpoint_sm }}px) {
        #{{ section.id }} .image-banner,
        #{{ section.id }} .media {
          aspect-ratio: {{ m_img_ratio }};
        }
      }
    {%- endif -%}
  {%- endif -%}

  {%- if section.settings.tint_opacity > 0 -%}
    #{{ section.id }} .media::after {
      background-color: rgba({{ section.settings.tint_color.rgb }} / {{ section.settings.tint_opacity | divided_by: 100.0 }});
    }
  {%- endif -%}
  #{{ section.id }} .scrolling-banner__item { padding-inline-end: {{ section.settings.spacing }}px; }
  @media (max-width: {{ breakpoint_md }}px) {
    #{{ section.id }} .scrolling-banner__item { padding-inline-end: {{ section.settings.spacing | times: 0.66 }}px; }
  }
  @media (max-width: {{ breakpoint_sm }}px) {
    #{{ section.id }} .scrolling-banner__item { padding-inline-end: {{ section.settings.spacing | times: 0.5 }}px; }
  }
{%- endstyle -%}

{%- if section.settings.animate_on_scroll -%}<parallax-container style="--parallax-speed: {{ section.settings.speed | times: 0.05 }}">{%- endif -%}
<div id="{{ section.id }}"{% if section.settings.full_width == false and section.settings.background_mode == 'image' %} class="relative"{% endif %}>
  {%- if section.settings.full_width == false and section.settings.background_mode == 'image' and section.settings.background_image != blank -%}
    <div class="absolute inset-0">
      {%- render 'image',
        image: section.settings.background_image,
        src_width: 1400,
        widths: '480, 980, 1200, 1400, 1600, 1920, 2560, 3200',
        class: 'img-fit cover',
        sizes: '100vw'
      -%}
    </div>
  {%- endif -%}

  {% if section.settings.full_width == false %}<div class="flex wide-container w-full">{% endif %}
  <div class="section
              {%- if section.settings.full_width == false %} section--boundary-{{ section.settings.section_join_mode }}{% endif %}
              {%- if section.settings.full_width %} section--full-width{% else %} section--inset-banner section--border-radius overflow-hidden{% endif %}
              {%- if section.settings.mobile_stacked and section.settings.height_mode != 'screen' %}
                mobile-stacked
                {%- if section.settings.full_width and bg_color == false or bg_color == settings.default_color_scheme.settings.background %} mobile-stacked--spaced{% endif %}
              {% endif %}
              color-scheme
              {%- if section.settings.full_width and section.settings.background_mode != 'default' %} color-scheme--no-bg{% endif %}
              color-scheme--{{ color_scheme }}"
      data-section-index="{{ section.index }}">
    <div class="image-banner relative flex {{ overlay_position | last }} {{ section.settings.height_mode }}-height screen-height--fixed
                {%- if section.settings.full_width and section.settings.enable_top_fade %} image-banner--top-fade{% endif %}
                {%- if section.settings.full_width and section.settings.enable_bottom_fade %} image-banner--bottom-fade{% endif %}">
      {%- if section.settings.url != blank -%}<a href="{{ section.settings.url }}" class="block w-full h-full absolute left-0 top-0">{%- endif -%}
        <div class="image-banner__image media media--has-overlay absolute top-0 left-0 w-full h-full">
          {%- if img != blank -%}
            {%- liquid
                if section.settings.height_mode == 'screen'
                  assign sizes = '(max-aspect-ratio: 1/2) 50vh, 100vw'
                else
                  capture sizes
                  render 'sizes-attribute'
                  endcapture
                endif
            -%}

            {%- render 'image-desktop-and-mobile',
              class: 'img-fit image-banner__image',
              desktop_image: img,
              mobile_image: m_img,
              src_width_mobile: 980,
              widths_mobile: '480, 980, 1200, 1400',
              src_width_desktop: 1400,
              widths_desktop: '480, 980, 1200, 1400, 1600, 1920, 2560, 3200',
              lazy_load: lazy_load_images,
              sizes: sizes
            -%}
          {%- else -%}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'media__placeholder img-fit dark' }}
          {%- endif -%}
        </div>
      {%- if section.settings.url != blank -%}</a>{%- endif -%}

      {%- capture scrolling_content -%}
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'text' -%}
              {%- if block.settings.link != blank -%}
                <a class="scrolling-banner__item scrolling-banner__text md:{{ block.settings.heading_size_desktop }} {{ block.settings.heading_size_mobile }}{% if block.settings.font == 'body' %} font-body{% endif %}" href="{{ block.settings.link }}" {{ block.shopify_attributes }}>{{ block.settings.text }}</a>
              {%- else -%}
                <span class="scrolling-banner__item scrolling-banner__text md:{{ block.settings.heading_size_desktop }} {{ block.settings.heading_size_mobile }}{% if block.settings.font == 'body' %} font-body{% endif %}" {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</span>
              {%- endif -%}

            {%- when 'icon' -%}
              {% style %}
                #{{ block.id }} {
                  color: {{ block.settings.icon_color }};
                }
              {% endstyle %}
              <span class="scrolling-banner__item flex" id="{{ block.id }}" {{ block.shopify_attributes }}>
                {%- if block.settings.usp_icon != 'none' -%}
                  {% render 'icon-usp',
                    icon: block.settings.usp_icon,
                    width: block.settings.icon_size,
                    height: block.settings.icon_size
                  %}
                {%- else -%}
                  {% render 'icon',
                    icon: block.settings.icon,
                    width: block.settings.icon_size,
                    height: block.settings.icon_size
                  %}
                {%- endif -%}
              </span>

            {%- when 'image' -%}
              {%- liquid
                if block.settings.image != blank
                  assign image_width = block.settings.image_height | times: block.settings.image.aspect_ratio | ceil
                else
                  assign image_width = block.settings.image_height | times: 2
                endif
              -%}
              <span class="scrolling-banner__item" {{ block.shopify_attributes }}>
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}" class="hover:grow-media">
                {%- endif -%}

                <span class="media block relative" style="width: {{ image_width }}px; height: {{ block.settings.image_height }}px;">
                  {%- if block.settings.image != blank -%}
                    {% render 'image', image: block.settings.image, src_width: image_width, srcset_2x: true, lazy_load: false %}
                  {%- else -%}
                    {{ 'logo' | placeholder_svg_tag: 'media__placeholder img-fit' }}
                  {%- endif -%}
                </span>

                {%- if block.settings.link != blank -%}
                  </a>
                {%- endif -%}
              </span>

            {%- when 'button' -%}
              {%- if block.settings.button_label != blank -%}
                <span class="scrolling-banner__item flex" {{ block.shopify_attributes }}>
                  <a class="{{ block.settings.button_style }}" {% if block.settings.button_link == blank %}role="link" aria-disabled="true"{% else %}href="{{ block.settings.button_link }}"{% endif %}>
                    {{- block.settings.button_label | escape -}}
                  </a>
                </span>
              {%- endif -%}

          {%- endcase -%}
        {%- endfor -%}
      {%- endcapture -%}

      <div class="scrolling-banner flex{% if section.settings.pausable %} scrolling-banner--pausable{% endif %}" role="marquee" {%- render 'animation-attrs', attrs: 'data-cc-animate="slide-in-up"' %}>
        <div class="scrolling-banner__items-container flex{% if section.settings.animate_on_scroll %} parallax-marquee{% endif %}">
          {%- for i in (1..20) -%}
            {%- if forloop.first -%}
              <div class="{% unless section.settings.animate_on_scroll %}scrolling-banner__items has-motion {% endunless %}flex items-center">
                {{ scrolling_content }}
              </div>
            {%- else -%}
              <div class="{% unless section.settings.animate_on_scroll %}scrolling-banner__items has-motion {% endunless %}flex items-center" aria-hidden="true">
                {{ scrolling_content | replace: '<a ', '<a tabindex="-1" ' }}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
  {% if section.settings.full_width == false %}</div>{% endif %}
</div>
{%- if section.settings.animate_on_scroll -%}</parallax-container>{%- endif -%}

{% schema %}
{
  "name": "Image with scrolling text",
  "tag": "section",
  "class": "cc-image-banner banner-candidate",
  "settings": [
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Image",
      "info": "For best results, use a landscape shaped image with a width of 3200px."
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image (optional)",
      "info": "For best results, use a square or portrait shaped image. If no mobile image is provided, the large screen image will be used."
    },
    {
      "type": "url",
      "id": "url",
      "label": "Image link (optional)"
    },
    {
      "type": "header",
      "content": "Image styles"
    },
    {
      "type": "color",
      "id": "tint_color",
      "label": "Image tint color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "tint_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Image tint opacity",
      "default": 0,
      "info": "Does not apply if fade is set below."
    },
    {
      "type": "header",
      "content": "Image Layout"
    },
    {
      "type": "select",
      "id": "height_mode",
      "label": "Image height",
      "info": "Restricted to 1080px maximum.",
      "options": [
        {
          "value": "auto",
          "label": "Original image height"
        },
        {
          "value": "fixed",
          "label": "Fixed height (set below)"
        },
        {
          "value": "screen",
          "label": "Full screen height"
        }
      ],
      "default": "fixed"
    },
    {
      "visible_if": "{{ section.settings.height_mode == 'fixed' }}",
      "type": "range",
      "id": "fixed_height_desktop",
      "min": 200,
      "max": 1400,
      "step": 20,
      "unit": "px",
      "label": "Fixed height (desktop)",
      "default": 400
    },
    {
      "visible_if": "{{ section.settings.height_mode == 'fixed' }}",
      "type": "range",
      "id": "fixed_height_mobile",
      "min": 200,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "label": "Fixed height (mobile)",
      "default": 300
    },
    {
      "type": "header",
      "content": "Scrolling"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 1,
      "max": 30,
      "step": 1,
      "label": "Speed",
      "default": 24
    },
    {
      "type": "select",
      "id": "direction",
      "label": "Direction",
      "options": [
        {
          "value": "normal",
          "label": "Right to left"
        },
        {
          "value": "reverse",
          "label": "Left to right"
        }
      ],
      "default": "normal"
    },
    {
      "type": "checkbox",
      "id": "pausable",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "animate_on_scroll",
      "label": "Animate on scroll only",
      "default": false
    },
    {
      "type": "range",
      "id": "spacing",
      "min": 32,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Maximum space between blocks",
      "default": 40
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": true
    },
    {
      "visible_if": "{{ section.settings.full_width }}",
      "type": "checkbox",
      "id": "enable_top_fade",
      "label": "Enable top fade",
      "default": false
    },
    {
      "visible_if": "{{ section.settings.full_width and section.settings.enable_top_fade }}",
      "type": "range",
      "id": "top_fade_depth",
      "min": 10,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Top fade depth",
      "default": 100
    },
    {
      "visible_if": "{{ section.settings.full_width and section.settings.enable_top_fade }}",
      "type": "color",
      "id": "top_fade_color",
      "label": "Top fade color",
      "default": "#ffffff"
    },
    {
      "visible_if": "{{ section.settings.full_width }}",
      "type": "checkbox",
      "id": "enable_bottom_fade",
      "label": "Enable bottom fade",
      "default": false
    },
    {
      "visible_if": "{{ section.settings.full_width and section.settings.enable_bottom_fade }}",
      "type": "range",
      "id": "bottom_fade_depth",
      "min": 10,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Bottom fade depth",
      "default": 100
    },
    {
      "visible_if": "{{ section.settings.full_width and section.settings.enable_bottom_fade }}",
      "type": "color",
      "id": "bottom_fade_color",
      "label": "Bottom fade color",
      "default": "#ffffff"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-3"
    },
    {
      "visible_if": "{{ section.settings.full_width == false }}",
      "type": "select",
      "id": "background_mode",
      "label": "Section background",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "color",
          "label": "Color"
        },
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "simple-gradient",
          "label": "Simple gradient"
        },
        {
          "value": "advanced-gradient",
          "label": "Advanced gradient"
        }
      ],
      "default": "default"
    },
    {
      "visible_if": "{{ section.settings.full_width == false and section.settings.background_mode == 'color' }}",
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "visible_if": "{{ section.settings.full_width == false and section.settings.background_mode == 'image' }}",
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "visible_if": "{{ section.settings.full_width == false and section.settings.background_mode == 'simple-gradient' }}",
      "type": "color",
      "id": "background_gradient_stop_1",
      "label": "Gradient start",
      "default": "#cccccc"
    },
    {
      "visible_if": "{{ section.settings.full_width == false and section.settings.background_mode == 'simple-gradient' }}",
      "type": "color",
      "id": "background_gradient_stop_2",
      "label": "Gradient end",
      "default": "#ffffff"
    },
    {
      "visible_if": "{{ section.settings.full_width == false and section.settings.background_mode == 'simple-gradient' }}",
      "type": "select",
      "id": "background_gradient_curve",
      "label": "Gradient style",
      "options": [
        {
          "value": "linear",
          "label": "Linear"
        },
        {
          "value": "ease-up",
          "label": "Ease up"
        },
        {
          "value": "ease-down",
          "label": "Ease down"
        }
      ],
      "default": "linear"
    },
    {
      "visible_if": "{{ section.settings.full_width == false and section.settings.background_mode == 'advanced-gradient' }}",
      "type": "color_background",
      "id": "background_gradient",
      "label": "Advanced gradient",
      "default": "linear-gradient(#f8f1f4, #f8f1f4 12%, #c8bdc1, #e8dccc 92%)"
    },
    {
      "visible_if": "{{ section.settings.full_width == false }}",
      "type": "header",
      "content": "Layout"
    },
    {
      "visible_if": "{{ section.settings.full_width == false }}",
      "type": "select",
      "id": "section_join_mode",
      "label": "Boundary above section",
      "info": "Some sections support seamless joining",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "tight",
          "label": "Tight"
        },
        {
          "value": "join",
          "label": "Join"
        }
      ],
      "default": "default"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Tell customers about a promotion or make an announcement"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "font",
          "label": "Font",
          "options": [
            {
              "label": "Heading font",
              "value": "heading"
            },
            {
              "label": "Body font",
              "value": "body"
            }
          ],
          "default": "heading"
        },
        {
          "type": "select",
          "id": "heading_size_desktop",
          "label": "Font size (desktop)",
          "options": [
            {
              "value": "h4",
              "label": "Extra extra small"
            },
            {
              "value": "h3",
              "label": "Extra small"
            },
            {
              "value": "h2",
              "label": "Small"
            },
            {
              "value": "h1",
              "label": "Medium"
            },
            {
              "value": "x-large-heading",
              "label": "Large"
            },
            {
              "value": "xx-large-heading",
              "label": "Extra large"
            }
          ],
          "default": "h2"
        },
        {
          "type": "select",
          "id": "heading_size_mobile",
          "label": "Font size (mobile)",
          "options": [
            {
              "value": "h4",
              "label": "Extra extra small"
            },
            {
              "value": "h3",
