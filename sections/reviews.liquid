<!-- reviews.css: non-blocking — reviews section is always below the fold -->
<link rel="stylesheet" href="{{ 'reviews.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="{{ 'reviews.css' | asset_url }}"></noscript>

{%- liquid
  assign color_scheme = section.settings.color_scheme
  assign use_api = section.settings.use_judgeme_api
  assign api_token = section.settings.judgeme_api_token
  assign api_count = section.settings.reviews_count | default: 6
  assign show_section = false
  if use_api and api_token != blank
    assign show_section = true
  elsif section.blocks.size > 0
    assign show_section = true
  endif
-%}

{%- if show_section -%}
  <div class="reviews reviews--loading section color-scheme color-scheme--{{ color_scheme }}" id="{{ section.id }}">
    <div class="container">

      {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
        <div class="reviews__header text-center mb-8 md:mb-10">
          {%- if section.settings.subheading != blank -%}
            <p class="reviews__subheading">{{ section.settings.subheading | escape }}</p>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="reviews__heading {{ section.settings.heading_size }} mb-0">{{ section.settings.heading | escape }}</h2>
          {%- endif -%}
        </div>
      {%- endif -%}

      <carousel-slider class="carousel block relative" inactive>
        <div class="slider-nav slider-nav--alt flex justify-between absolute no-js-hidden">
          <button type="button" class="slider-nav__btn btn text-current has-ltr-icon" name="prev" aria-controls="reviews-slider-{{ section.id }}" aria-label="{{ 'general.slider.previous' | t }}">
            {% render 'icon-chevron-left' %}
          </button>
          <button type="button" class="slider-nav__btn btn text-current has-ltr-icon" name="next" aria-controls="reviews-slider-{{ section.id }}" aria-label="{{ 'general.slider.next' | t }}">
            {% render 'icon-chevron-right' %}
          </button>
        </div>

        <div class="slider slider--no-scrollbar relative reviews__slider" id="reviews-slider-{{ section.id }}">
          <ul class="slider__grid grid grid-flow-col reviews__grid" role="list">

            {%- if use_api and api_token != blank -%}
              {%- comment -%} Shimmer skeletons shown while JS fetches from Judge.me {%- endcomment -%}
              {%- for i in (1..api_count) -%}
                <li class="slider__item reviews__item">
                  <div class="review-card__skeleton" aria-hidden="true">
                    <div class="review-card__skeleton-stars"></div>
                    <div class="review-card__skeleton-lines">
                      <div class="review-card__skeleton-line"></div>
                      <div class="review-card__skeleton-line review-card__skeleton-line--mid"></div>
                      <div class="review-card__skeleton-line review-card__skeleton-line--short"></div>
                    </div>
                    <div class="review-card__skeleton-author">
                      <div class="review-card__skeleton-avatar"></div>
                      <div class="review-card__skeleton-name"></div>
                    </div>
                  </div>
                  <div class="review-card h-full flex flex-col"></div>
                </li>
              {%- endfor -%}

            {%- else -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'review' -%}
                  <li class="slider__item reviews__item" {{ block.shopify_attributes }}>
                    <div class="review-card__skeleton" aria-hidden="true">
                      <div class="review-card__skeleton-stars"></div>
                      <div class="review-card__skeleton-lines">
                        <div class="review-card__skeleton-line"></div>
                        <div class="review-card__skeleton-line review-card__skeleton-line--mid"></div>
                        <div class="review-card__skeleton-line review-card__skeleton-line--short"></div>
                      </div>
                      <div class="review-card__skeleton-author">
                        <div class="review-card__skeleton-avatar"></div>
                        <div class="review-card__skeleton-name"></div>
                      </div>
                    </div>
                    <div class="review-card h-full flex flex-col">
                      {%- assign star_rating = block.settings.rating -%}
                      <div class="review-card__stars" aria-label="{{ star_rating }} out of 5 stars">
                        {%- for i in (1..5) -%}
                          <span class="review-card__star{% if i <= star_rating %} review-card__star--filled{% endif %}">★</span>
                        {%- endfor -%}
                      </div>
                      {%- if block.settings.review_text != blank -%}
                        <p class="review-card__text flex-auto">"{{ block.settings.review_text | escape }}"</p>
                      {%- endif -%}
                      {%- assign fit = block.settings.fit_rating -%}
                      {%- liquid
                        if fit == 'runs_small'
                          assign fit_label = 'Runs small'
                        elsif fit == 'runs_large'
                          assign fit_label = 'Runs large'
                        else
                          assign fit_label = 'True to size'
                        endif
                      -%}
                      <div class="review-card__footer mt-auto">
                        <div class="review-card__author-row flex items-center gap-3">
                          {%- if block.settings.reviewer_image != blank -%}
                            <div class="review-card__avatar shrink-0">
                              {{ block.settings.reviewer_image | image_url: width: 80 | image_tag: width: 40, height: 40, loading: 'lazy', class: 'review-card__avatar-img' }}
                            </div>
                          {%- elsif block.settings.reviewer_name != blank -%}
                            <div class="review-card__avatar review-card__avatar--initials shrink-0" aria-hidden="true">
                              {{- block.settings.reviewer_name | slice: 0, 1 | upcase -}}
                            </div>
                          {%- endif -%}
                          <div>
                            {%- if block.settings.reviewer_name != blank -%}
                              <p class="review-card__name font-semibold mb-0 text-sm">
                                {{ block.settings.reviewer_name | escape }}
                                {%- if block.settings.verified -%}<span class="review-card__verified" title="Verified Purchase">✓</span>{%- endif -%}
                              </p>
                            {%- endif -%}
                            {%- if block.settings.product_name != blank -%}
                              <p class="review-card__product text-xs opacity-60 mb-0">
                                {%- if block.settings.product_link != blank -%}
                                  <a href="{{ block.settings.product_link }}" class="review-card__product-link">{{ block.settings.product_name | escape }}</a>
                                {%- else -%}
                                  {{ block.settings.product_name | escape }}
                                {%- endif -%}
                              </p>
                            {%- endif -%}
                          </div>
                          {%- if fit != blank and fit != 'none' -%}
                            <div class="review-card__fit-badge ms-auto shrink-0">{{ fit_label }}</div>
                          {%- endif -%}
                        </div>
                      </div>
                    </div>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}

          </ul>
        </div>
      </carousel-slider>

    </div>

    <script>
      (function () {
        var sectionEl = document.getElementById('{{ section.id }}');
        if (!sectionEl) return;

        var carousel = sectionEl.querySelector('carousel-slider');
        var useApi = {{ use_api | json }};
        var carouselReady = false;
        var fetchDone = false;

        function tryReveal() {
          if (carouselReady && fetchDone) {
            sectionEl.classList.remove('reviews--loading');
          }
        }

        // Track carousel init
        if (!carousel) {
          carouselReady = true;
        } else if (!carousel.hasAttribute('inactive')) {
          carouselReady = true;
        } else {
          var obs = new MutationObserver(function () {
            if (!carousel.hasAttribute('inactive')) {
              carouselReady = true;
              obs.disconnect();
              tryReveal();
            }
          });
          obs.observe(carousel, { attributes: true, attributeFilter: ['inactive'] });
          setTimeout(function () { carouselReady = true; tryReveal(); }, 2000);
        }

        if (!useApi) {
          fetchDone = true;
          tryReveal();
          return;
        }

        function starsHtml(rating) {
          var html = '<div class="review-card__stars" aria-label="' + rating + ' out of 5 stars">';
          for (var i = 1; i <= 5; i++) {
            html += '<span class="review-card__star' + (i <= rating ? ' review-card__star--filled' : '') + '">★</span>';
          }
          return html + '</div>';
        }

        function buildCard(review) {
          var rating = Math.round(review.rating) || 5;
          var name = (review.reviewer && review.reviewer.name) ? review.reviewer.name : 'Customer';
          var initial = name.charAt(0).toUpperCase();
          var verified = review.verified_buyer
            ? '<span class="review-card__verified" title="Verified Purchase">✓</span>'
            : '';
          var body = review.body || '';
          if (body.length > 220) body = body.substring(0, 220) + '…';
          var productTitle = review.product_title
            ? '<p class="review-card__product text-xs opacity-60 mb-0">' + review.product_title.replace(/</g, '&lt;') + '</p>'
            : '';

          return '<li class="slider__item reviews__item">'
            + '<div class="review-card h-full flex flex-col">'
            + starsHtml(rating)
            + (body ? '<p class="review-card__text flex-auto">“' + body.replace(/</g, '&lt;') + '”</p>' : '')
            + '<div class="review-card__footer mt-auto">'
            +   '<div class="review-card__author-row flex items-center gap-3">'
            +     '<div class="review-card__avatar review-card__avatar--initials shrink-0" aria-hidden="true">' + initial + '</div>'
            +     '<div>'
            +       '<p class="review-card__name font-semibold mb-0 text-sm">' + name.replace(/</g, '&lt;') + verified + '</p>'
            +       productTitle
            +     '</div>'
            +   '</div>'
            + '</div>'
            + '</div>'
            + '</li>';
        }

        var items = sectionEl.querySelectorAll('.reviews__item');

        // Fetch from pre-generated static asset (avoids CORS + keeps private token off browser).
        // Wrapped in IntersectionObserver so the request only fires when the section is
        // near the viewport — not on initial page load.
        var reviewsUrl = {{ 'reviews-data.json' | asset_url | json }};

        function doFetch() {
          fetch(reviewsUrl)
            .then(function (res) {
              if (!res.ok) throw new Error('reviews-data.json not found: ' + res.status);
              return res.json();
            })
            .then(function (data) {
            var reviews = (Array.isArray(data) ? data : []).slice(0, items.length);
            console.log('[Elvn Reviews] Loaded', reviews.length, 'reviews');

            if (reviews.length === 0) {
              sectionEl.style.display = 'none';
              return;
            }

            // Fill each existing skeleton <li> in-place so the carousel keeps its structure
            reviews.forEach(function (review, idx) {
              if (idx >= items.length) return;
              var card = items[idx].querySelector('.review-card');
              if (!card) return;

              var rating = Math.round(review.rating) || 5;
              var name = (review.reviewer && review.reviewer.name) ? review.reviewer.name : 'Customer';
              var initial = name.charAt(0).toUpperCase();
              var verified = review.verified_buyer
                ? '<span class="review-card__verified" title="Verified Purchase">✓</span>'
                : '';
              var body = review.body || '';
              if (body.length > 220) body = body.substring(0, 220) + '…';
              var productTitle = review.product_title
                ? '<p class="review-card__product text-xs opacity-60 mb-0">' + review.product_title.replace(/</g, '&lt;') + '</p>'
                : '';

              var stars = '';
              for (var i = 1; i <= 5; i++) {
                stars += '<span class="review-card__star' + (i <= rating ? ' review-card__star--filled' : '') + '">★</span>';
              }

              card.innerHTML =
                '<div class="review-card__stars" aria-label="' + rating + ' out of 5 stars">' + stars + '</div>'
                + (body ? '<p class="review-card__text flex-auto">"' + body.replace(/</g, '&lt;') + '"</p>' : '')
                + '<div class="review-card__footer mt-auto">'
                +   '<div class="review-card__author-row flex items-center gap-3">'
                +     '<div class="review-card__avatar review-card__avatar--initials shrink-0" aria-hidden="true">' + initial + '</div>'
                +     '<div>'
                +       '<p class="review-card__name font-semibold mb-0 text-sm">' + name.replace(/</g, '&lt;') + verified + '</p>'
                +       productTitle
                +     '</div>'
                +   '</div>'
                + '</div>';
            });

            // Hide unused skeleton slots if fewer reviews came back than slots
            for (var j = reviews.length; j < items.length; j++) {
              items[j].style.display = 'none';
            }
          })
            .catch(function (err) {
              console.error('[Elvn Reviews] Fetch failed:', err);
            })
            .then(function () {
              fetchDone = true;
              tryReveal();
            });
        }

        // Fire doFetch only when section scrolls near the viewport (200px early)
        if ('IntersectionObserver' in window) {
          var revObserver = new IntersectionObserver(function (entries, obs) {
            if (entries[0].isIntersecting) {
              obs.disconnect();
              doFetch();
            }
          }, { rootMargin: '200px' });
          revObserver.observe(sectionEl);
        } else {
          doFetch(); // fallback for old browsers
        }
      })();
    </script>

  </div>
{%- endif -%}

{% schema %}
{
  "name": "Reviews",
  "tag": "section",
  "class": "cc-reviews",
  "settings": [
    {
      "type": "header",
      "content": "Judge.me Auto-fetch"
    },
    {
      "type": "checkbox",
      "id": "use_judgeme_api",
      "label": "Auto-fetch from Judge.me",
      "info": "When ON, reviews are pulled live from Judge.me. Manual review blocks below are ignored.",
      "default": false
    },
    {
      "type": "text",
      "id": "judgeme_api_token",
      "label": "Judge.me Public API Token",
      "info": "Find it in Judge.me → Settings → Integrations → Developers → Public API Token"
    },
    {
      "type": "range",
      "id": "reviews_count",
      "label": "Number of reviews to show",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "select",
      "id": "min_rating",
      "label": "Minimum star rating to show",
      "options": [
        { "value": "1", "label": "All reviews (1★+)" },
        { "value": "3", "label": "3 stars and above" },
        { "value": "4", "label": "4 stars and above" },
        { "value": "5", "label": "5 stars only" }
      ],
      "default": "4"
    },
    {
      "type": "header",
      "content": "Section content"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Customer Reviews"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What our customers say"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h2", "label": "Large" },
        { "value": "h3", "label": "Medium" },
        { "value": "h4", "label": "Small" }
      ],
      "default": "h2"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review text",
          "default": "Absolutely love these leggings! The fabric is so soft and they hold everything in perfectly. I wore them for a 2-hour session and they stayed in place the whole time."
        },
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer name",
          "default": "Priya M."
        },
        {
          "type": "image_picker",
          "id": "reviewer_image",
          "label": "Reviewer photo (optional)"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Show verified badge",
          "default": true
        },
        {
          "type": "select",
          "id": "fit_rating",
          "label": "Size fit",
          "options": [
            { "value": "none", "label": "— None —" },
            { "value": "runs_small", "label": "Runs small" },
            { "value": "true_to_size", "label": "True to size" },
            { "value": "runs_large", "label": "Runs large" }
          ],
          "default": "true_to_size"
        },
        {
          "type": "text",
          "id": "product_name",
          "label": "Product name",
          "default": "PowerSculpt Leggings"
        },
        {
          "type": "url",
          "id": "product_link",
          "label": "Product link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "reviewer_name": "Priya M.",
            "review_text": "Absolutely love these leggings! The fabric is so soft and they hold everything in perfectly. I wore them for a 2-hour session and they stayed in place the whole time.",
            "fit_rating": "true_to_size",
            "product_name": "PowerSculpt Leggings",
            "verified": true
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "reviewer_name": "Anika R.",
            "review_text": "The matching set is everything — I get compliments every time I wear it to the gym. Quality is top-notch and the sizing is true to fit.",
            "fit_rating": "true_to_size",
            "product_name": "Court Muse Set",
            "verified": true
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 4,
            "reviewer_name": "Simran K.",
            "review_text": "Really comfortable for yoga and pilates. The high waist stays up perfectly and doesn't roll down. Will definitely be ordering more colors.",
            "fit_rating": "runs_small",
            "product_name": "Yoga Pilates Bra",
            "verified": true
          }
        },
        {
          "type": "review",
          "settings": {
            "rating": 5,
            "reviewer_name": "Divya S.",
            "review_text": "I was hesitant to spend this much on activewear but it is 100% worth it. The quality is so much better than anything I've tried before.",
            "fit_rating": "runs_large",
            "product_name": "MatchPoint Collection",
            "verified": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
