<script src="{{ 'matching-sets.js' | asset_url }}" defer></script>

{% assign sets = shop.metaobjects.matching_set.values %}

{% comment %} {% for set in sets %}
    <div class="matching-set" data-set="{{ forloop.index }}">
        <div class="set-image">
            {% comment %} <img src="{{ set.image | image_url: width: 800 }}" width="100%" height="100%" /> {% endcomment %}
            <img 
                src="{{ set.image | image_url: width: 800 }}" 
                width="800" 
                height="1000" 
                class="set-img" 
              />

            {% render 'matching-set-hotspot',
                x: set.hotspot_top_x,
                y: set.hotspot_top_y,
                type: 'top',
                set_id: forloop.index
              %}
        
              {% render 'matching-set-hotspot',
                x: set.hotspot_bottom_x,
                y: set.hotspot_bottom_y,
                type: 'bottom',
                set_id: forloop.index
              %}
        </div>

        <!-- CTA -->
        <button class="open-drawer" data-set="{{ forloop.index }}">
            Add Full Look
        </button>
    </div>
{% endfor %} {% endcomment %}


<div class="matching-sets-wrapper">
    <div class="matching-sets-grid">
        <div class="matching-sets-title">Matching Sets</div>
      {% for set in sets %}
        {% render 'matching-set-card',
          set: set,
          set_index: forloop.index
        %}
      {% endfor %}
    </div>
  </div>
    {% render 'matching-set-mini-card' %}

<style>
    {% comment %} .matching-set {
        margin: 40px;
      } {% endcomment %}
      
      .set-image {
        position: relative;
      }
      
      .set-img {
        width: 100%;
        height: auto;
        display: block;
        border-radius: 8px;
      }
      
      .hotspot {
        position: absolute;
        transform: translate(-50%, -50%);
      }

      .mini-card {
        position: fixed; /* 🔥 critical fix */
        width: 220px;
        background: white;
        border-radius: 12px;
        padding: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        z-index: 1000;
      
        transform: translateY(10px) scale(0.98);
        opacity: 0;
        pointer-events: none;
        transition: all 0.25s ease;
      }
      
      /* visible state */
      .mini-card.show {
        transform: translateY(0) scale(1);
        opacity: 1;
        pointer-events: auto;
      }
      
      .mini-card img {
        width: 48px;
        height: 60px;
        object-fit: cover;
        border-radius: 8px;
      }
      
      .mini-card .row {
        display: flex;
        gap: 10px;
      }
      
      .mini-card .actions {
        display: flex;
        justify-content: space-between;
        margin-top: 8px;
      }

      .matching-sets-wrapper {
        max-width: 1400px; 
        margin: 0 auto;
        padding: 0 24px;
      }
      
      .matching-sets-grid {
        display: grid;
        {% comment %} grid-template-columns: repeat(2, 1fr); {% endcomment %}
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 24px;
      }

      {% comment %} .matching-sets-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        max-width: 900px;
        margin: 0 auto;
        padding: 20px;
      } {% endcomment %}

      .matching-sets-title {
        font-size: 40px;
      }
      
      @media (max-width: 768px) {
        .matching-sets-grid {
          grid-template-columns: 1fr;
        }

        .matching-sets-title {
            font-size: 20px;
        }
      }
      
      .matching-set-card {
        display: flex;
        flex-direction: column;
        gap: 10px;
        max-width: 520px;
        margin: 0 auto;
      }

      .set-info {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      
      .set-title {
        font-size: 14px;
        color: #222;
      }
      
      .open-drawer {
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        background: none;
        border: none;
        cursor: pointer;
        color: #555;
      }
      
      .open-drawer:hover {
        color: #000;
      }

      .mini-add, .mini-view {
        font-size: 12px;
      }
</style>

<script>
    window.MATCHING_SETS = [
      {% for set in sets %}
        {
          id: "{{ forloop.index }}",
          handle: "{{ set.handle }}",
          title: "{{ set.title }}",
          image: "{{ set.image | image_url }}",
          hotspot_top_x: {{ set.hotspot_top_x }},
          hotspot_top_y: {{ set.hotspot_top_y }},
          hotspot_bottom_x: {{ set.hotspot_bottom_x }},
          hotspot_bottom_y: {{ set.hotspot_bottom_y }},
          products: [
            {% for product in set.products.value %}
              {
                id: "{{ product.id }}",
                title: "{{ product.title }}",
                price: {{ product.price }},
                variants: [
                  {% for variant in product.variants %}
                    {
                      id: "{{ variant.id }}",
                      title: "{{ variant.title }}"
                    }{% unless forloop.last %},{% endunless %}
                  {% endfor %}
                ]
              }{% unless forloop.last %},{% endunless %}
            {% endfor %}
          ]
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ];
</script>

{% comment %} {% if request.design_mode %} {% endcomment %}
    <script>
    document.querySelectorAll('.set-image').forEach((container) => {
      container.addEventListener('click', (e) => {
        const rect = container.getBoundingClientRect();
    
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
    
        console.log("X:", x.toFixed(2), "Y:", y.toFixed(2));
      });
    });
    </script>
{% comment %} {% endif %} {% endcomment %}

{% schema %}
    {
    "name": "Matching Sets",
    "settings": [],
    "presets": [
        {
        "name": "Matching Sets"
        }
    ]
    }
{% endschema %}