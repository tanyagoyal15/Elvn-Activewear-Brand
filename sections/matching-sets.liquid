<script src="{{ 'matching-sets.js' | asset_url }}" defer></script>

{% assign sets = shop.metaobjects.matching_set.values %}

{% comment %} {% for set in sets %}
    <div class="matching-set" data-set="{{ forloop.index }}">
        <div class="set-image">
            {% comment %} <img src="{{ set.image | image_url: width: 800 }}" width="100%" height="100%" /> {% endcomment %}
            <img 
                src="{{ set.image | image_url: width: 800 }}" 
                width="800" 
                height="1000" 
                class="set-img" 
              />

            {% render 'matching-set-hotspot',
                x: set.hotspot_top_x,
                y: set.hotspot_top_y,
                type: 'top',
                set_id: forloop.index
              %}
        
              {% render 'matching-set-hotspot',
                x: set.hotspot_bottom_x,
                y: set.hotspot_bottom_y,
                type: 'bottom',
                set_id: forloop.index
              %}
        </div>

        <!-- CTA -->
        <button class="open-drawer" data-set="{{ forloop.index }}">
            Add Full Look
        </button>
    </div>
{% endfor %} {% endcomment %}


<div class="matching-sets-wrapper">
    <div class="matching-sets-grid">
        <div class="matching-sets-title">Matching Sets</div>
      {% for set in sets %}
        {% render 'matching-set-card',
          set: set,
          set_index: forloop.index
        %}
      {% endfor %}
    </div>
  </div>

<style>

    /* ================= BASE ================= */
    
    .set-image {
      position: relative;
    }
    
    .set-img {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 8px;
    }
    
    .hotspot {
      position: absolute;
      transform: translate(-50%, -50%);
    }

    .hotspot {
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    
    .set-image.loaded .hotspot {
        opacity: 1;
    }
    
    /* ================= LAYOUT ================= */
    
    .matching-sets-wrapper {
      max-width: 1400px; 
      margin: 0 auto;
      padding: 0 24px;
    }
    
    .matching-sets-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 24px;
    }
    
    .matching-sets-title {
      font-size: 40px;
    }
    
    @media (max-width: 768px) {
      .matching-sets-grid {
        grid-template-columns: 1fr;
      }
    
      .matching-sets-title {
        font-size: 20px;
      }
    }
    
    /* ================= CARD ================= */
    
    .matching-set-card {
      display: flex;
      flex-direction: column;
      gap: 10px;
      max-width: 520px;
      margin: 0 auto;
      opacity: 0;
      transform: translateY(10px);
      transition: all 0.4s ease;
    }

    {% comment %} .matching-set-card {
        
    } {% endcomment %}
      
    .matching-set-card.loaded {
        opacity: 1;
        transform: translateY(0);
    }
    
    .set-info {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    
    .set-title {
      font-size: 14px;
      color: #222;
    }
    
    .open-drawer {
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      background: none;
      border: none;
      cursor: pointer;
      color: #555;
    }
    
    .open-drawer:hover {
      color: #000;
    }
    
    /* ================= MINI CARD ================= */
    
    .mini-card {
      position: absolute;
      width: 220px;
      background: rgba(255,255,255,0.96);
      backdrop-filter: blur(6px);
      border-radius: 12px;
      padding: 10px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.08);
      z-index: 1000;
    
      transform: translateY(10px) scale(0.98);
      opacity: 0;
      pointer-events: none;
      transition: all 0.25s ease;
    }
    
    .mini-card.show {
      transform: translateY(0) scale(1);
      opacity: 1;
      pointer-events: auto;
    }
    
    /* INNER LAYOUT */
    .mini-card-inner {
      display: flex;
      gap: 12px;
      align-items: stretch;
    }
    
    /* IMAGE */
    .mini-left {
      width: 64px;
      flex-shrink: 0;
    }
    
    .mini-left img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 8px;
    }
    
    /* RIGHT SIDE */
    .mini-right {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }
    
    /* TEXT */
    .mini-title {
      font-size: 13px;
      line-height: 1.4;
      font-weight: 500;
      color: #111;
    }
    
    .mini-price {
      font-size: 12px;
      color: #666;
      margin-top: 4px;
    }
    
    /* CTA */
    .mini-view {
      align-self: flex-end;
      font-size: 12px;
      background: none;
      border: none;
      color: #111;
      cursor: pointer;
      padding: 0;
      letter-spacing: 0.3px;
      transition: opacity 0.2s ease;
    }
    
    .mini-view:hover {
      opacity: 0.6;
    }
    
</style>

<script>
    window.MATCHING_SETS = [
      {% for set in sets %}
        {
          id: "{{ forloop.index }}",
          handle: "{{ set.system.handle }}",
          title: "{{ set.title }}",
          image: "{{ set.image | image_url }}",
          hotspot_top_x: {{ set.hotspot_top_x }},
          hotspot_top_y: {{ set.hotspot_top_y }},
          hotspot_bottom_x: {{ set.hotspot_bottom_x }},
          hotspot_bottom_y: {{ set.hotspot_bottom_y }},
          products: [
            {% for product in set.products.value %}
              {
                id: "{{ product.id }}",
                title: "{{ product.title }}",
                price: {{ product.price }},
                variants: [
                  {% for variant in product.variants %}
                    {
                      id: "{{ variant.id }}",
                      title: "{{ variant.title }}",
                      available: {{ variant.available }}
                    }{% unless forloop.last %},{% endunless %}
                  {% endfor %}
                ]
              }{% unless forloop.last %},{% endunless %}
            {% endfor %}
          ]
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ];
</script>

{% comment %} {% if request.design_mode %} {% endcomment %}
    <script>
    document.querySelectorAll('.set-image').forEach((container) => {
      container.addEventListener('click', (e) => {
        const rect = container.getBoundingClientRect();
    
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
    
        console.log("X:", x.toFixed(2), "Y:", y.toFixed(2));
      });
    });
    </script>
{% comment %} {% endif %} {% endcomment %}

{% schema %}
    {
    "name": "Matching Sets",
    "settings": [],
    "presets": [
        {
        "name": "Matching Sets"
        }
    ]
    }
{% endschema %}