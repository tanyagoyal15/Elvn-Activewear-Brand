<script src="{{ 'matching-sets.js' | asset_url }}" defer></script>

{% assign sets = shop.metaobjects.matching_set.values %}
{% assign display_mode = section.settings.display_mode | default: 'home_editorial' %}


{%- if display_mode == 'collection_grid' -%}
  <section class="matching-sets-collection-wrapper">
    <div class="matching-sets-collection-inner">
      <div class="matching-sets-collection-header">
        {%- if section.settings.section_heading != blank -%}
          <h2 class="matching-sets-collection-heading">{{ section.settings.section_heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.section_subheading != blank -%}
          <p class="matching-sets-collection-subheading">{{ section.settings.section_subheading | escape }}</p>
        {%- endif -%}
      </div>

      <div
        class="matching-sets-collection-grid"
        style="--matching-sets-columns-desktop: {{ section.settings.columns_desktop }}; --matching-sets-columns-mobile: {{ section.settings.columns_mobile }};"
      >
        {% for block in section.blocks %}
          {% assign set = block.settings.matching_set %}
          {% if set %}
            {% render 'matching-set-card',
              set: set,
              set_index: forloop.index,
              show_info: true,
              image_width: 900,
              image_height: 1200
            %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>
{%- else -%}
  {%- assign displayed_sets_count = 0 -%}
  {%- for block in section.blocks -%}
    {%- assign set = block.settings.matching_set -%}
    {%- if set and set.show_on_homepage -%}
      {%- assign displayed_sets_count = displayed_sets_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
  <div class="matching-sets-wrapper">
    <div class="matching-sets-editorial">
      <div class="matching-sets-copy">
        {%- if section.settings.eyebrow != blank -%}
          <p class="matching-sets-eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        <h2 class="h2 cg-heading">{{ section.settings.section_heading | escape }}</h2>

        {%- if section.settings.section_subheading != blank -%}
          <p class="cg-subheading">{{ section.settings.section_subheading | escape }}</p>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <a class="matching-sets-shop-all matching-sets-shop-all--desktop" href="{{ section.settings.button_link | default: '/collections/matching-sets' }}">
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
      </div>

      <div class="matching-sets-mosaic matching-sets-mosaic--count-{{ displayed_sets_count }}" aria-label="{{ section.settings.section_heading | escape }}">
        {% for block in section.blocks %}
          {% assign set = block.settings.matching_set %}
          {% if set and set.show_on_homepage %}
            {% render 'matching-set-card',
              set: set,
              set_index: forloop.index,
              show_info: false,
              image_width: 900,
              image_height: 1100
            %}
          {% endif %}
        {% endfor %}
      </div>

      {%- if section.settings.button_label != blank -%}
        <a class="matching-sets-shop-all matching-sets-shop-all--mobile" href="{{ section.settings.button_link | default: '/collections/matching-sets' }}">
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

<style>

    /* ================= BASE ================= */
    
    .set-image {
      position: relative;
      overflow: hidden;
      background: #f7f7f5;
    }
    
    .set-img {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 8px;
      opacity: 0;
      transition: opacity 0.35s ease;
    }

    .set-image.loaded .set-img {
      opacity: 1;
    }

    .set-image::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 1;
      background:
        linear-gradient(
          100deg,
          rgba(255, 255, 255, 0) 20%,
          rgba(255, 255, 255, 0.68) 50%,
          rgba(255, 255, 255, 0) 80%
        ),
        #f2f2f0;
      background-size: 220% 100%;
      animation: matchingImageLoader 1.15s ease-in-out infinite;
      pointer-events: none;
      transition: opacity 0.25s ease, visibility 0.25s ease;
    }

    .set-image.loaded::before {
      opacity: 0;
      visibility: hidden;
    }

    @keyframes matchingImageLoader {
      0% {
        background-position: 120% 0;
      }
      100% {
        background-position: -120% 0;
      }
    }
    
    .hotspot {
      position: absolute;
      transform: translate(-50%, -50%);
    }

    .hotspot {
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    
    .set-image.loaded .hotspot {
        opacity: 1;
    }
    
    /* ================= LAYOUT ================= */
    
    .matching-sets-wrapper {
      box-sizing: border-box;
      width: 100%;
      max-width: 1320px;
      margin: 0 auto;
      padding: 0 32px;
      overflow: clip;
    }

    .matching-sets-editorial {
      display: grid;
      grid-template-columns: minmax(260px, 340px) minmax(0, 860px);
      align-items: center;
      justify-content: center;
      gap: clamp(28px, 4vw, 56px);
      min-width: 0;
    }

    .matching-sets-copy {
      min-width: 0;
      max-width: 380px;
      padding: clamp(12px, 4vw, 56px) 0;
    }

    .matching-sets-eyebrow {
      margin: 0 0 12px;
      color: #111;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.12em;
      line-height: 1.3;
      text-transform: uppercase;
    }

    .matching-sets-copy .cg-heading {
      margin: 0;
    }

    .matching-sets-copy .cg-subheading {
      max-width: 340px;
      margin: 12px 0 0;
      color: #3f3f3f;
    }

    .matching-sets-shop-all {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 250px;
      margin-top: 28px;
      padding: 14px 28px;
      border: 1px solid #111;
      color: #111;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.08em;
      line-height: 1.2;
      text-align: center;
      text-decoration: none;
      text-transform: uppercase;
      transition: background-color 0.2s ease, color 0.2s ease;
    }

    .matching-sets-shop-all:hover {
      background: #111;
      color: #fff;
    }

    /* Desktop: show only the version inside copy column */
    .matching-sets-shop-all--mobile { display: none; }

    /* Mobile: hide the copy-column version, show the one after the grid */
    @media (max-width: 768px) {
      .matching-sets-shop-all--desktop { display: none; }
      .matching-sets-shop-all--mobile  { display: inline-flex; }
    }

    .matching-sets-mosaic {
      display: grid;
      grid-template-columns: repeat(3, 268px);
      grid-auto-rows: 1fr 1fr;
      gap: 10px;
      min-width: 0;
      width: 100%;
      height: auto;
      overflow: hidden;
    }

    .matching-sets-mosaic--count-1,
    .matching-sets-mosaic--count-2 {
      height: clamp(460px, 66vh, 660px);
    }

    .matching-sets-mosaic .matching-set-card {
      width: 100%;
      min-width: 0;
      min-height: 0;
    }

    .matching-sets-mosaic .set-image,
    .matching-sets-mosaic .set-img {
      height: 100%;
    }

    .matching-sets-mosaic .set-image {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .matching-sets-mosaic .set-img {
      aspect-ratio: 4 / 5;
      border-radius: 0;
      object-fit: cover;
      object-position: center center;
    }
    
    .matching-sets-title {
      font-size: 40px;
    }

    /* ================= COLLECTION GRID MODE ================= */

    .matching-sets-collection-wrapper {
      padding: clamp(28px, 5vw, 64px) 0;
      overflow-x: clip;
    }

    .matching-sets-collection-inner {
      width: min(100% - 40px, 1320px);
      margin: 0 auto;
    }

    .matching-sets-collection-header {
      max-width: 620px;
      margin: 0 auto clamp(24px, 4vw, 42px);
      text-align: center;
    }

    .matching-sets-collection-heading {
      margin: 0;
      font-size: clamp(24px, 3vw, 38px);
      font-weight: 500;
      letter-spacing: 0;
      line-height: 1.15;
      text-transform: uppercase;
      font-family: var(--ce-font-head);
    }

    .matching-sets-collection-subheading {
      margin: 12px auto 0;
      color: #666;
      font-size: 15px;
      line-height: 1.55;
    }

    .matching-sets-collection-grid {
      display: grid;
      grid-template-columns: repeat(var(--matching-sets-columns-mobile), minmax(0, 1fr));
      gap: 18px;
    }

    .matching-sets-collection-grid .matching-set-card {
      min-width: 0;
    }

    .matching-sets-collection-grid .set-image {
      overflow: hidden;
    }

    .matching-sets-collection-grid .set-img {
      display: block;
      width: 100%;
      height: auto;
      aspect-ratio: 4 / 5;
      object-fit: cover;
      object-position: center top;
      border-radius: 0;
    }

    @media (min-width: 768px) {
      .matching-sets-collection-grid {
        grid-template-columns: repeat(var(--matching-sets-columns-desktop), minmax(0, 1fr));
        gap: 28px;
      }
    }
    
    @media (max-width: 768px) {
      .matching-sets-editorial {
        grid-template-columns: 1fr;
        gap: 16px;
      }

      .matching-sets-copy {
        max-width: none;
        padding: 4px 0 0;
      }

      .matching-sets-shop-all {
        width: 100%;
        min-width: 0;
        margin-top: 0;
      }

      .matching-sets-mosaic {
        grid-template-columns: repeat(2, 1fr);
        gap: 8px;
        width: 100%;
        height: auto;
        overflow: visible;
      }

      .matching-sets-mosaic .set-image,
      .matching-sets-mosaic .set-img {
        height: auto;
      }
    
      .matching-sets-title {
        font-size: 20px;
      }

      .matching-sets-collection-grid .set-info {
        flex-direction: column;
        align-items: flex-start;
        gap: 6px;
      }

      .matching-sets-collection-grid .set-title {
        font-size: 13px;
      }

      .matching-sets-collection-grid .open-drawer {
        font-size: 11px;
      }
    }
    
    /* ================= CARD ================= */
    
    .matching-set-card {
      display: flex;
      flex-direction: column;
      gap: 10px;
      max-width: none;
      margin: 0 auto;
      opacity: 1;
      transform: none;
      position: relative;
    }

    /* .matching-set-card { } */
      
    .matching-set-card.loaded {
        opacity: 1;
        transform: translateY(0);
    }
    
    .set-info {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    
    .set-title {
      font-size: 14px;
      color: #222;
    }
    
    .open-drawer {
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      background: none;
      border: none;
      cursor: pointer;
      color: #555;
    }
    
    .open-drawer:hover {
      color: #000;
    }
    
    /* ================= MINI CARD ================= */
    
    .mini-card {
      position: absolute;
      width: 220px;
      background: rgba(255,255,255,0.97);
      backdrop-filter: blur(8px);
      border-radius: 12px;
      padding: 10px;
      box-shadow: 0 8px 32px rgba(0,0,0,0.13);
      z-index: 99999;

      transform: translateY(8px) scale(0.97);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.22s ease, transform 0.22s ease;
    }

    .mini-card.show {
      transform: translateY(0) scale(1);
      opacity: 1;
      pointer-events: auto;
    }
    
    /* INNER LAYOUT */
    .mini-card-inner {
      display: flex;
      gap: 12px;
      align-items: stretch;
    }
    
    /* IMAGE */
    .mini-left {
      width: 64px;
      flex-shrink: 0;
    }
    
    .mini-left img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 8px;
      aspect-ratio: 4 / 5;
    }
    
    /* RIGHT SIDE */
    .mini-right {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }
    
    /* TEXT */
    .mini-title {
      font-size: 13px;
      line-height: 1.4;
      font-weight: 500;
      color: #111;
    }
    
    .mini-price {
      font-size: 12px;
      color: #666;
      margin-top: 4px;
    }
    
    /* CTA */
    .mini-view {
      align-self: flex-end;
      font-size: 12px;
      background: none;
      border: none;
      color: #111;
      cursor: pointer;
      padding: 0;
      letter-spacing: 0.3px;
      transition: opacity 0.2s ease;
    }
    
    .mini-view:hover {
      opacity: 0.6;
    }
    
</style>

<script>
    window.MATCHING_SETS = [
      {%- assign first_set = true -%}
      {% for block in section.blocks %}
        {% assign set = block.settings.matching_set %}
        {% if set %}
          {% unless first_set %},{% endunless %}
        {
          id: "{{ forloop.index }}",
          handle: "{{ set.handle }}",
          title: "{{ set.title }}",
          image: "{{ set.image | image_url }}",
          hotspot_top_x: {{ set.hotspot_top_x | default: 0 }},
          hotspot_top_y: {{ set.hotspot_top_y | default: 0 }},
          hotspot_bottom_x: {{ set.hotspot_bottom_x | default: 0 }},
          hotspot_bottom_y: {{ set.hotspot_bottom_y | default: 0 }},
          default_top_color: {{ set.default_top_color | json }},
          default_bottom_color: {{ set.default_bottom_color | json }},
          products: [
            {% for product in set.products.value %}
              {
                id: "{{ product.id }}",
                title: {{ product.title | json }},
                price: {{ product.price | default: 0 }},
                featured_image: "{{ product.featured_image | image_url: width: 300 }}",
                url: "{{ product.url }}",
                type: "{{ product.type | downcase }}",
                colorImages: {
                  {%- assign color_opt_index = 1 -%}
                  {%- for opt in product.options -%}
                    {%- assign opt_lower = opt | downcase -%}
                    {%- if opt_lower == 'color' or opt_lower == 'colour' -%}
                      {%- assign color_opt_index = forloop.index -%}
                    {%- endif -%}
                  {%- endfor -%}
                  {% for variant in product.variants %}
                    {%- if color_opt_index == 1 -%}{%- assign vcolor = variant.option1 -%}
                    {%- elsif color_opt_index == 2 -%}{%- assign vcolor = variant.option2 -%}
                    {%- elsif color_opt_index == 3 -%}{%- assign vcolor = variant.option3 -%}
                    {%- else -%}{%- assign vcolor = variant.option1 -%}{%- endif -%}
                    {% if variant.featured_image %}
                      {{ vcolor | json }}: "{{ variant.featured_image | image_url: width: 300 }}",
                    {% endif %}
                  {% endfor %}
                },
                variants: [
                  {%- assign color_opt_index = 1 -%}
                  {%- for opt in product.options -%}
                    {%- assign opt_lower = opt | downcase -%}
                    {%- if opt_lower == 'color' or opt_lower == 'colour' -%}
                      {%- assign color_opt_index = forloop.index -%}
                    {%- endif -%}
                  {%- endfor -%}
                  {% for variant in product.variants %}
                    {%- if color_opt_index == 1 -%}
                      {%- assign vcolor = variant.option1 -%}{%- assign vsize = variant.option2 -%}
                    {%- elsif color_opt_index == 2 -%}
                      {%- assign vcolor = variant.option2 -%}{%- assign vsize = variant.option1 -%}
                    {%- elsif color_opt_index == 3 -%}
                      {%- assign vcolor = variant.option3 -%}{%- assign vsize = variant.option1 -%}
                    {%- else -%}
                      {%- assign vcolor = variant.option1 -%}{%- assign vsize = variant.option2 -%}
                    {%- endif -%}
                    {
                      id: "{{ variant.id }}",
                      color: {{ vcolor | json }},
                      size: {{ vsize | json }},
                      available: {{ variant.available | json }}
                    }{% unless forloop.last %},{% endunless %}
                  {% endfor %}
                ]
              }{% unless forloop.last %},{% endunless %}
            {% endfor %}
          ]
        }
          {%- assign first_set = false -%}
        {% endif %}
      {% endfor %}
    ];
</script>

{% schema %}
    {
    "name": "Matching Sets",
    "settings": [
      {
        "type": "select",
        "id": "display_mode",
        "label": "Display mode",
        "options": [
          {
            "value": "home_editorial",
            "label": "Homepage editorial"
          },
          {
            "value": "collection_grid",
            "label": "Collection grid"
          }
        ],
        "default": "home_editorial"
      },
      {
        "type": "text",
        "id": "eyebrow",
        "label": "Eyebrow",
        "default": "Explore"
      },
      {
        "type": "text",
        "id": "section_heading",
        "label": "Heading",
        "default": "Matching sets"
      },
      {
        "type": "text",
        "id": "section_subheading",
        "label": "Subheading / description"
      },
      {
        "type": "text",
        "id": "button_label",
        "label": "Button label",
        "default": "Shop all matching sets"
      },
      {
        "type": "url",
        "id": "button_link",
        "label": "Button link"
      },
      {
        "type": "range",
        "id": "sets_to_show",
        "label": "Sets to show",
        "min": 2,
        "max": 6,
        "step": 1,
        "default": 6
      },
      {
        "type": "range",
        "id": "columns_desktop",
        "label": "Columns on desktop",
        "min": 2,
        "max": 4,
        "step": 1,
        "default": 3
      },
      {
        "type": "select",
        "id": "columns_mobile",
        "label": "Columns on mobile",
        "options": [
          {
            "value": "1",
            "label": "1"
          },
          {
            "value": "2",
            "label": "2"
          }
        ],
        "default": "2"
      }
    ],
    "blocks": [
      {
        "type": "matching_set",
        "name": "Matching Set",
        "settings": [
          {
            "type": "metaobject",
            "id": "matching_set",
            "label": "Matching set",
            "metaobject_type": "matching_set"
          }
        ]
      }
    ],
    "presets": [
        {
        "name": "Matching Sets"
        }
    ]
    }
{% endschema %}
