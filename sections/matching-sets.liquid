<script src="{{ 'matching-sets.js' | asset_url }}" defer></script>

{% assign sets = shop.metaobjects.matching_set.values %}
{% assign display_mode = section.settings.display_mode | default: 'home_editorial' %}
{% assign homepage_sets_limit = section.settings.sets_to_show | at_most: 4 %}
{% assign displayed_sets_count = 0 %}
{% for set in sets limit: homepage_sets_limit %}
  {% assign displayed_sets_count = displayed_sets_count | plus: 1 %}
{% endfor %}

{% comment %} {% for set in sets %}
    <div class="matching-set" data-set="{{ forloop.index }}">
        <div class="set-image">
            {% comment %} <img src="{{ set.image | image_url: width: 800 }}" width="100%" height="100%" /> {% endcomment %}
            <img 
                src="{{ set.image | image_url: width: 800 }}" 
                width="800" 
                height="1000" 
                class="set-img" 
              />

            {% render 'matching-set-hotspot',
                x: set.hotspot_top_x,
                y: set.hotspot_top_y,
                type: 'top',
                set_id: forloop.index
              %}
        
              {% render 'matching-set-hotspot',
                x: set.hotspot_bottom_x,
                y: set.hotspot_bottom_y,
                type: 'bottom',
                set_id: forloop.index
              %}
        </div>

        <!-- CTA -->
        <button class="open-drawer" data-set="{{ forloop.index }}">
            Add Full Look
        </button>
    </div>
{% endfor %} {% endcomment %}


{%- if display_mode == 'collection_grid' -%}
  <section class="matching-sets-collection-wrapper">
    <div class="matching-sets-collection-inner">
      <div class="matching-sets-collection-header">
        {%- if section.settings.section_heading != blank -%}
          <h2 class="matching-sets-collection-heading">{{ section.settings.section_heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.section_subheading != blank -%}
          <p class="matching-sets-collection-subheading">{{ section.settings.section_subheading | escape }}</p>
        {%- endif -%}
      </div>

      <div
        class="matching-sets-collection-grid"
        style="--matching-sets-columns-desktop: {{ section.settings.columns_desktop }}; --matching-sets-columns-mobile: {{ section.settings.columns_mobile }};"
      >
        {% for set in sets %}
          {% render 'matching-set-card',
            set: set,
            set_index: forloop.index,
            show_info: true,
            image_width: 900,
            image_height: 1200
          %}
        {% endfor %}
      </div>
    </div>
  </section>
{%- else -%}
  <div class="matching-sets-wrapper">
    <div class="matching-sets-editorial">
      <div class="matching-sets-copy">
        {%- if section.settings.eyebrow != blank -%}
          <p class="matching-sets-eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        <h2 class="h2 cg-heading">{{ section.settings.section_heading | escape }}</h2>

        {%- if section.settings.section_subheading != blank -%}
          <p class="cg-subheading">{{ section.settings.section_subheading | escape }}</p>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <a class="matching-sets-shop-all" href="{{ section.settings.button_link | default: '/collections/matching-sets' }}">
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
      </div>

      <div class="matching-sets-mosaic matching-sets-mosaic--count-{{ displayed_sets_count }}" aria-label="{{ section.settings.section_heading | escape }}">
        {% for set in sets limit: homepage_sets_limit %}
          {% render 'matching-set-card',
            set: set,
            set_index: forloop.index,
            show_info: false,
            image_width: 900,
            image_height: 1100
          %}
        {% endfor %}
      </div>
    </div>
  </div>
{%- endif -%}

<style>

    /* ================= BASE ================= */
    
    .set-image {
      position: relative;
      overflow: hidden;
      background: #f7f7f5;
    }
    
    .set-img {
      width: 100%;
      height: auto;
      display: block;
      border-radius: 8px;
      opacity: 0;
      transition: opacity 0.35s ease;
    }

    .set-image.loaded .set-img {
      opacity: 1;
    }

    .set-image::before {
      content: "";
      position: absolute;
      inset: 0;
      z-index: 1;
      background:
        linear-gradient(
          100deg,
          rgba(255, 255, 255, 0) 20%,
          rgba(255, 255, 255, 0.68) 50%,
          rgba(255, 255, 255, 0) 80%
        ),
        #f2f2f0;
      background-size: 220% 100%;
      animation: matchingImageLoader 1.15s ease-in-out infinite;
      pointer-events: none;
      transition: opacity 0.25s ease, visibility 0.25s ease;
    }

    .set-image.loaded::before {
      opacity: 0;
      visibility: hidden;
    }

    @keyframes matchingImageLoader {
      0% {
        background-position: 120% 0;
      }
      100% {
        background-position: -120% 0;
      }
    }
    
    .hotspot {
      position: absolute;
      transform: translate(-50%, -50%);
    }

    .hotspot {
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    
    .set-image.loaded .hotspot {
        opacity: 1;
    }
    
    /* ================= LAYOUT ================= */
    
    .matching-sets-wrapper {
      box-sizing: border-box;
      width: 100%;
      max-width: 1320px;
      margin: 0 auto;
      padding: 0 32px;
      overflow: clip;
    }

    .matching-sets-editorial {
      display: grid;
      grid-template-columns: minmax(260px, 340px) minmax(0, 860px);
      align-items: center;
      justify-content: center;
      gap: clamp(28px, 4vw, 56px);
      min-width: 0;
    }

    .matching-sets-copy {
      min-width: 0;
      max-width: 380px;
      padding: clamp(12px, 4vw, 56px) 0;
    }

    .matching-sets-eyebrow {
      margin: 0 0 12px;
      color: #111;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.12em;
      line-height: 1.3;
      text-transform: uppercase;
    }

    .matching-sets-copy .cg-heading {
      margin: 0;
    }

    .matching-sets-copy .cg-subheading {
      max-width: 340px;
      margin: 14px 0 0;
      color: #3f3f3f;
    }

    .matching-sets-shop-all {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 250px;
      margin-top: 28px;
      padding: 14px 28px;
      border: 1px solid #111;
      color: #111;
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.08em;
      line-height: 1.2;
      text-align: center;
      text-decoration: none;
      text-transform: uppercase;
      transition: background-color 0.2s ease, color 0.2s ease;
    }

    .matching-sets-shop-all:hover {
      background: #111;
      color: #fff;
    }

    .matching-sets-mosaic {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-auto-rows: minmax(0, 1fr);
      gap: 10px;
      min-width: 0;
      width: 100%;
      height: clamp(620px, 76vh, 820px);
      overflow: hidden;
    }

    .matching-sets-mosaic--count-1,
    .matching-sets-mosaic--count-2 {
      height: clamp(460px, 66vh, 660px);
    }

    .matching-sets-mosaic .matching-set-card {
      width: 100%;
      min-width: 0;
      min-height: 0;
    }

    .matching-sets-mosaic .set-image,
    .matching-sets-mosaic .set-img {
      height: 100%;
    }

    .matching-sets-mosaic .set-image {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .matching-sets-mosaic .set-img {
      aspect-ratio: 4 / 5;
      border-radius: 0;
      object-fit: cover;
      object-position: center top;
    }
    
    .matching-sets-title {
      font-size: 40px;
    }

    /* ================= COLLECTION GRID MODE ================= */

    .matching-sets-collection-wrapper {
      padding: clamp(28px, 5vw, 64px) 0;
    }

    .matching-sets-collection-inner {
      width: min(100% - 40px, 1320px);
      margin: 0 auto;
    }

    .matching-sets-collection-header {
      max-width: 620px;
      margin: 0 auto clamp(24px, 4vw, 42px);
      text-align: center;
    }

    .matching-sets-collection-heading {
      margin: 0;
      font-size: clamp(24px, 3vw, 38px);
      font-weight: 600;
      letter-spacing: 0;
      line-height: 1.15;
      text-transform: uppercase;
    }

    .matching-sets-collection-subheading {
      margin: 12px auto 0;
      color: #666;
      font-size: 15px;
      line-height: 1.55;
    }

    .matching-sets-collection-grid {
      display: grid;
      grid-template-columns: repeat(var(--matching-sets-columns-mobile), minmax(0, 1fr));
      gap: 18px;
    }

    .matching-sets-collection-grid .matching-set-card {
      min-width: 0;
    }

    .matching-sets-collection-grid .set-image {
      aspect-ratio: 4 / 5;
    }

    .matching-sets-collection-grid .set-img {
      width: 100%;
      height: 100%;
      border-radius: 0;
      object-fit: cover;
      object-position: center top;
    }

    @media (min-width: 768px) {
      .matching-sets-collection-grid {
        grid-template-columns: repeat(var(--matching-sets-columns-desktop), minmax(0, 1fr));
        gap: 28px;
      }
    }
    
    @media (max-width: 768px) {
      .matching-sets-editorial {
        grid-template-columns: 1fr;
        gap: 24px;
      }

      .matching-sets-copy {
        max-width: none;
        padding: 4px 0 0;
      }

      .matching-sets-shop-all {
        width: 100%;
        min-width: 0;
      }

      .matching-sets-mosaic {
        gap: 8px;
        width: 100%;
        height: auto;
        overflow: visible;
      }

      .matching-sets-mosaic .set-image,
      .matching-sets-mosaic .set-img {
        height: auto;
      }
    
      .matching-sets-title {
        font-size: 20px;
      }
    }
    
    /* ================= CARD ================= */
    
    .matching-set-card {
      display: flex;
      flex-direction: column;
      gap: 10px;
      max-width: none;
      margin: 0 auto;
      opacity: 1;
      transform: none;
    }

    {% comment %} .matching-set-card {
        
    } {% endcomment %}
      
    .matching-set-card.loaded {
        opacity: 1;
        transform: translateY(0);
    }
    
    .set-info {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    
    .set-title {
      font-size: 14px;
      color: #222;
    }
    
    .open-drawer {
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      background: none;
      border: none;
      cursor: pointer;
      color: #555;
    }
    
    .open-drawer:hover {
      color: #000;
    }
    
    /* ================= MINI CARD ================= */
    
    .mini-card {
      position: absolute;
      width: 220px;
      background: rgba(255,255,255,0.96);
      backdrop-filter: blur(6px);
      border-radius: 12px;
      padding: 10px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.08);
      z-index: 1000;
    
      transform: translateY(10px) scale(0.98);
      opacity: 0;
      pointer-events: none;
      transition: all 0.25s ease;
    }
    
    .mini-card.show {
      transform: translateY(0) scale(1);
      opacity: 1;
      pointer-events: auto;
    }
    
    /* INNER LAYOUT */
    .mini-card-inner {
      display: flex;
      gap: 12px;
      align-items: stretch;
    }
    
    /* IMAGE */
    .mini-left {
      width: 64px;
      flex-shrink: 0;
    }
    
    .mini-left img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 8px;
      aspect-ratio: 4 / 5;
    }
    
    /* RIGHT SIDE */
    .mini-right {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }
    
    /* TEXT */
    .mini-title {
      font-size: 13px;
      line-height: 1.4;
      font-weight: 500;
      color: #111;
    }
    
    .mini-price {
      font-size: 12px;
      color: #666;
      margin-top: 4px;
    }
    
    /* CTA */
    .mini-view {
      align-self: flex-end;
      font-size: 12px;
      background: none;
      border: none;
      color: #111;
      cursor: pointer;
      padding: 0;
      letter-spacing: 0.3px;
      transition: opacity 0.2s ease;
    }
    
    .mini-view:hover {
      opacity: 0.6;
    }
    
</style>

<script>
    window.MATCHING_SETS = [
      {% for set in sets %}
        {
          id: "{{ forloop.index }}",
          handle: "{{ set.handle }}",
          title: "{{ set.title }}",
          image: "{{ set.image | image_url }}",
          hotspot_top_x: {{ set.hotspot_top_x }},
          hotspot_top_y: {{ set.hotspot_top_y }},
          hotspot_bottom_x: {{ set.hotspot_bottom_x }},
          hotspot_bottom_y: {{ set.hotspot_bottom_y }},
          products: [
            {% for product in set.products.value %}
              {
                id: "{{ product.id }}",
                title: {{ product.title | json }},
                price: {{ product.price }},
                featured_image: "{{ product.featured_image | image_url: width: 300 }}",
                url: "{{ product.url }}",
                type: "{{ product.type | downcase }}",
                colorImages: {
                  {% for variant in product.variants %}
                    {% assign vcolor = variant.title | split: "/" | first | strip %}
                    {% if variant.featured_image %}
                      {{ vcolor | json }}: "{{ variant.featured_image | image_url: width: 300 }}",
                    {% endif %}
                  {% endfor %}
                },
                variants: [
                  {% for variant in product.variants %}
                    {
                      id: "{{ variant.id }}",
                      title: {{ variant.title | json }},
                      available: {{ variant.available | json }}
                    }{% unless forloop.last %},{% endunless %}
                  {% endfor %}
                ]
              }{% unless forloop.last %},{% endunless %}
            {% endfor %}
          ]
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ];
</script>

{% schema %}
    {
    "name": "Matching Sets",
    "settings": [
      {
        "type": "select",
        "id": "display_mode",
        "label": "Display mode",
        "options": [
          {
            "value": "home_editorial",
            "label": "Homepage editorial"
          },
          {
            "value": "collection_grid",
            "label": "Collection grid"
          }
        ],
        "default": "home_editorial"
      },
      {
        "type": "text",
        "id": "eyebrow",
        "label": "Eyebrow",
        "default": "Explore"
      },
      {
        "type": "text",
        "id": "section_heading",
        "label": "Heading",
        "default": "Matching sets"
      },
      {
        "type": "text",
        "id": "section_subheading",
        "label": "Subheading / description"
      },
      {
        "type": "text",
        "id": "button_label",
        "label": "Button label",
        "default": "Shop all matching sets"
      },
      {
        "type": "url",
        "id": "button_link",
        "label": "Button link"
      },
      {
        "type": "range",
        "id": "sets_to_show",
        "label": "Sets to show",
        "min": 2,
        "max": 4,
        "step": 1,
        "default": 4
      },
      {
        "type": "range",
        "id": "columns_desktop",
        "label": "Columns on desktop",
        "min": 2,
        "max": 4,
        "step": 1,
        "default": 3
      },
      {
        "type": "select",
        "id": "columns_mobile",
        "label": "Columns on mobile",
        "options": [
          {
            "value": "1",
            "label": "1"
          },
          {
            "value": "2",
            "label": "2"
          }
        ],
        "default": "2"
      }
    ],
    "presets": [
        {
        "name": "Matching Sets"
        }
    ]
    }
{% endschema %}
