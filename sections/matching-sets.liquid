<script src="{{ 'matching-sets.js' | asset_url }}" defer></script>

{% assign sets = shop.metaobjects.matching_set.values %}
{% assign display_mode = section.settings.display_mode | default: 'home_editorial' %}


{%- if display_mode == 'collection_grid' -%}
  <section class="matching-sets-collection-wrapper">
    <div class="matching-sets-collection-inner">
      <div class="matching-sets-collection-header">
        {%- if section.settings.section_heading != blank -%}
          <h2 class="matching-sets-collection-heading">{{ section.settings.section_heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.section_subheading != blank -%}
          <p class="matching-sets-collection-subheading">{{ section.settings.section_subheading | escape }}</p>
        {%- endif -%}
      </div>

      <div
        class="matching-sets-collection-grid"
        style="--matching-sets-columns-desktop: {{ section.settings.columns_desktop }}; --matching-sets-columns-mobile: {{ section.settings.columns_mobile }};"
      >
        {% for block in section.blocks %}
          {% assign set = block.settings.matching_set %}
          {% if set %}
            {% render 'matching-set-card',
              set: set,
              set_index: forloop.index,
              show_info: true,
              image_width: 900,
              image_height: 1200
            %}
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </section>
{%- else -%}
  {%- assign displayed_sets_count = 0 -%}
  {%- for block in section.blocks -%}
    {%- assign set = block.settings.matching_set -%}
    {%- if set and set.show_on_homepage -%}
      {%- assign displayed_sets_count = displayed_sets_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
  <div class="matching-sets-wrapper">
    <div class="matching-sets-editorial">
      <div class="matching-sets-copy">
        {%- if section.settings.eyebrow != blank -%}
          <p class="matching-sets-eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        <h2 class="h2 cg-heading">{{ section.settings.section_heading | escape }}</h2>

        {%- if section.settings.section_subheading != blank -%}
          <p class="cg-subheading">{{ section.settings.section_subheading | escape }}</p>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <a class="matching-sets-shop-all matching-sets-shop-all--desktop" href="{{ section.settings.button_link | default: '/collections/matching-sets' }}">
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
      </div>

      <div class="matching-sets-mosaic matching-sets-mosaic--count-{{ displayed_sets_count }}" aria-label="{{ section.settings.section_heading | escape }}">
        {% for block in section.blocks %}
          {% assign set = block.settings.matching_set %}
          {% if set and set.show_on_homepage %}
            {% render 'matching-set-card',
              set: set,
              set_index: forloop.index,
              show_info: false,
              image_width: 900,
              image_height: 1100
            %}
          {% endif %}
        {% endfor %}
      </div>

      {%- if section.settings.button_label != blank -%}
        <a class="matching-sets-shop-all matching-sets-shop-all--mobile" href="{{ section.settings.button_link | default: '/collections/matching-sets' }}">
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

<link rel="stylesheet" href="{{ 'matching-sets.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript><link rel="stylesheet" href="{{ 'matching-sets.css' | asset_url }}"></noscript>



<!-- MATCHING_SETS data — type=application/json tells the browser to skip JS execution.
     A tiny lazy-getter below parses it only when matching-sets.js first accesses window.MATCHING_SETS. -->
<script type="application/json" id="elvn-matching-sets">[
  {%- assign first_set = true -%}
  {%- for block in section.blocks -%}
    {%- assign set = block.settings.matching_set -%}
    {%- if set -%}
      {%- unless first_set -%},{%- endunless -%}
      {"id":{{ forloop.index | json }},"handle":{{ set.handle | json }},"title":{{ set.title | json }},"image":{{ set.image | image_url | json }},"hotspot_top_x":{{ set.hotspot_top_x | default: 0 }},"hotspot_top_y":{{ set.hotspot_top_y | default: 0 }},"hotspot_bottom_x":{{ set.hotspot_bottom_x | default: 0 }},"hotspot_bottom_y":{{ set.hotspot_bottom_y | default: 0 }},"default_top_color":{{ set.default_top_color | json }},"default_bottom_color":{{ set.default_bottom_color | json }},"products":[
        {%- for product in set.products.value -%}
          {%- assign color_opt_index = 1 -%}
          {%- for opt in product.options -%}
            {%- assign opt_lower = opt | downcase -%}
            {%- if opt_lower == 'color' or opt_lower == 'colour' -%}{%- assign color_opt_index = forloop.index -%}{%- endif -%}
          {%- endfor -%}
          {%- unless forloop.first -%},{%- endunless -%}
          {"id":{{ product.id | json }},"title":{{ product.title | json }},"price":{{ product.price | default: 0 }},"featured_image":{{ product.featured_image | image_url: width: 300 | json }},"url":{{ product.url | json }},"type":{{ product.type | downcase | json }},"colorImages":{
            {%- assign ci_first = true -%}
            {%- for variant in product.variants -%}
              {%- if color_opt_index == 1 -%}{%- assign vcolor = variant.option1 -%}
              {%- elsif color_opt_index == 2 -%}{%- assign vcolor = variant.option2 -%}
              {%- elsif color_opt_index == 3 -%}{%- assign vcolor = variant.option3 -%}
              {%- else -%}{%- assign vcolor = variant.option1 -%}{%- endif -%}
              {%- if variant.featured_image -%}
                {%- unless ci_first -%},{%- endunless -%}
                {{ vcolor | json }}:{{ variant.featured_image | image_url: width: 300 | json }}
                {%- assign ci_first = false -%}
              {%- endif -%}
            {%- endfor -%}
          },"variants":[
            {%- for variant in product.variants -%}
              {%- if color_opt_index == 1 -%}{%- assign vcolor = variant.option1 -%}{%- assign vsize = variant.option2 -%}
              {%- elsif color_opt_index == 2 -%}{%- assign vcolor = variant.option2 -%}{%- assign vsize = variant.option1 -%}
              {%- elsif color_opt_index == 3 -%}{%- assign vcolor = variant.option3 -%}{%- assign vsize = variant.option1 -%}
              {%- else -%}{%- assign vcolor = variant.option1 -%}{%- assign vsize = variant.option2 -%}{%- endif -%}
              {%- unless forloop.first -%},{%- endunless -%}
              {"id":{{ variant.id | json }},"color":{{ vcolor | json }},"size":{{ vsize | json }},"available":{{ variant.available | json }}}
            {%- endfor -%}
          ]}
        {%- endfor -%}
      ]}
      {%- assign first_set = false -%}
    {%- endif -%}
  {%- endfor -%}
]</script>
<script>/* Parse MATCHING_SETS lazily — zero parse cost until first access */
(function(){var p=false,v;Object.defineProperty(window,'MATCHING_SETS',{get:function(){if(!p){v=JSON.parse(document.getElementById('elvn-matching-sets').textContent);p=true;}return v;},set:function(x){v=x;p=true;},configurable:true});})();
</script>

{% schema %}
    {
    "name": "Matching Sets",
    "settings": [
      {
        "type": "select",
        "id": "display_mode",
        "label": "Display mode",
        "options": [
          {
            "value": "home_editorial",
            "label": "Homepage editorial"
          },
          {
            "value": "collection_grid",
            "label": "Collection grid"
          }
        ],
        "default": "home_editorial"
      },
      {
        "type": "text",
        "id": "eyebrow",
        "label": "Eyebrow",
        "default": "Explore"
      },
      {
        "type": "text",
        "id": "section_heading",
        "label": "Heading",
        "default": "Matching sets"
      },
      {
        "type": "text",
        "id": "section_subheading",
        "label": "Subheading / description"
      },
      {
        "type": "text",
        "id": "button_label",
        "label": "Button label",
        "default": "Shop all matching sets"
      },
      {
        "type": "url",
        "id": "button_link",
        "label": "Button link"
      },
      {
        "type": "range",
        "id": "sets_to_show",
        "label": "Sets to show",
        "min": 2,
        "max": 6,
        "step": 1,
        "default": 6
      },
      {
        "type": "range",
        "id": "columns_desktop",
        "label": "Columns on desktop",
        "min": 2,
        "max": 4,
        "step": 1,
        "default": 3
      },
      {
        "type": "select",
        "id": "columns_mobile",
        "label": "Columns on mobile",
        "options": [
          {
            "value": "1",
            "label": "1"
          },
          {
            "value": "2",
            "label": "2"
          }
        ],
        "default": "2"
      }
    ],
    "blocks": [
      {
        "type": "matching_set",
        "name": "Matching Set",
        "settings": [
          {
            "type": "metaobject",
            "id": "matching_set",
            "label": "Matching set",
            "metaobject_type": "matching_set"
          }
        ]
      }
    ],
    "presets": [
        {
        "name": "Matching Sets"
        }
    ]
    }
{% endschema %}
