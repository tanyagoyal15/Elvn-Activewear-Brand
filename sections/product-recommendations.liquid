{%- liquid
  assign color_scheme = section.settings.color_scheme
  assign disable_color_scheme_bg = false
  if section.settings.background_mode != 'default'
    assign disable_color_scheme_bg = true
  endif

  assign grid_classes = 'grid gap-x-5 gap-y-6 md:gap-6'
  if section.settings.layout == 'carousel'
    if section.settings.products_per_row == '1'
      assign grid_classes = grid_classes | append: ' grid-flow-col auto-cols-1 sm:auto-cols-2'
    elsif section.settings.products_per_row == '2'
      assign grid_classes = grid_classes | append: ' grid-flow-col auto-cols-2'
    endif
    if section.settings.products_per_row_desktop == '3'
      assign grid_classes = grid_classes | append: ' md:auto-cols-3'
    elsif section.settings.products_per_row_desktop == '4'
      assign grid_classes = grid_classes | append: ' md:auto-cols-3 lg:auto-cols-4'
    elsif section.settings.products_per_row_desktop == '5'
      assign grid_classes = grid_classes | append: ' md:auto-cols-4 lg:auto-cols-5'
    endif
  else
    if section.settings.products_per_row == '1'
      assign grid_classes = grid_classes | append: ' grid-cols-1 sm:grid-cols-2'
    elsif section.settings.products_per_row == '2'
      assign grid_classes = grid_classes | append: ' grid-cols-2'
    endif
    if section.settings.products_per_row_desktop == '3'
      assign grid_classes = grid_classes | append: ' md:grid-cols-3'
    elsif section.settings.products_per_row_desktop == '4'
      assign grid_classes = grid_classes | append: ' md:grid-cols-3 lg:grid-cols-4'
    elsif section.settings.products_per_row_desktop == '5'
      assign grid_classes = grid_classes | append: ' md:grid-cols-4 lg:grid-cols-5'
    endif
  endif
  assign grid_classes = grid_classes | append: ' stretch-cards'
  assign heading_classes = section.settings.heading_size | append: ' ' | append: section.settings.heading_align
  if section.settings.mob_center_text
    assign heading_classes = heading_classes | append: ' md-down:text-center'
  endif
-%}

{%- style -%}
  {%- if section.settings.background_mode == 'color' -%}
    #{{ section.id }} { background: {{ section.settings.background_color }}; }
  {%- elsif section.settings.background_mode == 'simple-gradient' -%}
    #{{ section.id }} {
      background: {% render 'custom-gradient',
                      type: section.settings.background_gradient_curve,
                      start_color: section.settings.background_gradient_stop_1,
                      end_color: section.settings.background_gradient_stop_2
                  %};
    }
  {%- elsif section.settings.background_mode == 'advanced-gradient' -%}
    #{{ section.id }} { background: {{ section.settings.background_gradient }}; }
  {%- endif -%}
{%- endstyle -%}

<div id="{{ section.id }}" class="section-background{% if section.settings.background_mode == 'image' %} relative{% endif %}">
  {%- if section.settings.background_mode == 'image' and section.settings.background_image != blank -%}
    <div class="absolute inset-0">
      {%- render 'image',
        image: section.settings.background_image,
        src_width: 1400,
        widths: '480, 980, 1200, 1400, 1600, 1920, 2560, 3200',
        class: 'img-fit cover',
        sizes: '100vw'
      -%}
    </div>
  {%- endif -%}

  {%- render 'recommendations',
    products_to_show: section.settings.products_to_show,
    layout: section.settings.layout,
    heading: section.settings.heading,
    heading_align: section.settings.heading_align,
    heading_classes: heading_classes,
    grid_classes: grid_classes,
    hide_promo: true,
    color_scheme: color_scheme,
    disable_color_scheme_bg: disable_color_scheme_bg
  -%}
</div>

{% schema %}
{
  "name": "Related products",
  "tag": "section",
  "class": "cc-product-recommendations",
  "settings": [
    {
      "type": "paragraph",
      "content": "Dynamic recommendations use order and product information to change and improve over time. [Learn more](https://help.shopify.com/en/themes/development/recommended-products)"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You may also like"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Size",
      "options": [
        {
          "value": "h4",
          "label": "Extra extra small"
        },
        {
          "value": "h3",
          "label": "Extra small"
        },
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "x-large-heading",
          "label": "Large"
        },
        {
          "value": "xx-large-heading",
          "label": "Extra large"
        }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_align",
      "label": "Alignment",
      "options": [
        {
          "value": "text-start",
          "label": "Left"
        },
        {
          "value": "text-center",
          "label": "Center"
        },
        {
          "value": "text-end",
          "label": "Right"
        }
      ],
      "default": "text-center"
    },
    {
      "type": "checkbox",
      "id": "mob_center_text",
      "label": "Center text on mobile",
      "default": true
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "background_mode",
      "label": "Section background",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "color",
          "label": "Color"
        },
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "simple-gradient",
          "label": "Simple gradient"
        },
        {
          "value": "advanced-gradient",
          "label": "Advanced gradient"
        }
      ],
      "default": "default"
    },
    {
      "visible_if": "{{ section.settings.background_mode == 'color' }}",
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "visible_if": "{{ section.settings.background_mode == 'image' }}",
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "visible_if": "{{ section.settings.background_mode == 'simple-gradient' }}",
      "type": "color",
      "id": "background_gradient_stop_1",
      "label": "Gradient start",
      "default": "#cccccc"
    },
    {
      "visible_if": "{{ section.settings.background_mode == 'simple-gradient' }}",
      "type": "color",
      "id": "background_gradient_stop_2",
      "label": "Gradient end",
      "default": "#ffffff"
    },
    {
      "visible_if": "{{ section.settings.background_mode == 'simple-gradient' }}",
      "type": "select",
      "id": "background_gradient_curve",
      "label": "Gradient style",
      "options": [
        {
          "value": "linear",
          "label": "Linear"
        },
        {
          "value": "ease-up",
          "label": "Ease up"
        },
        {
          "value": "ease-down",
          "label": "Ease down"
        }
      ],
      "default": "linear"
    },
    {
      "visible_if": "{{ section.settings.background_mode == 'advanced-gradient' }}",
      "type": "color_background",
      "id": "background_gradient",
      "label": "Advanced gradient",
      "default": "linear-gradient(#f8f1f4, #f8f1f4 12%, #c8bdc1, #e8dccc 92%)"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Maximum products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "products_per_row",
      "label": "Products per row on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "products_per_row_desktop",
      "label": "Products per row on desktop",
      "options": [
        {
          "value": "2",
          "label": "2"
        },
        {
          "value": "3",
          "label": "3"
        },
        {
          "value": "4",
          "label": "4"
        },
        {
          "value": "5",
          "label": "5"
        }
      ],
      "default": "4"
    },
    {
      "type": "radio",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "carousel",
          "label": "Carousel"
        },
        {
          "value": "grid",
          "label": "Grid"
        }
      ],
      "default": "carousel"
    }
  ]
}
{% endschema %}
