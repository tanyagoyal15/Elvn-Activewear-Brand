{{ 'hero-collections.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign color_scheme = section.settings.color_scheme
-%}

{%- style -%}
  {%- if section.settings.background_mode == 'color' -%}
    #{{ section.id }} { background: {{ section.settings.background_color }}; }
  {%- elsif section.settings.background_mode == 'simple-gradient' -%}
    #{{ section.id }} {
      background: {% render 'custom-gradient',
                      type: section.settings.background_gradient_curve,
                      start_color: section.settings.background_gradient_stop_1,
                      end_color: section.settings.background_gradient_stop_2
                  %};
    }
  {%- elsif section.settings.background_mode == 'advanced-gradient' -%}
    #{{ section.id }} { background: {{ section.settings.background_gradient }}; }
  {%- endif -%}

  {%- if section.settings.height_mode == 'fixed' -%}
    #{{ section.id }} before-after {
      min-height: {{ section.settings.fixed_height_mobile }}px;
    }
    @media (min-width: {{ breakpoint_sm }}px) {
      #{{ section.id }} before-after {
        min-height: min({{ section.settings.fixed_height_desktop }}px, calc({{ section.settings.fixed_height_mobile }}px + ({{ section.settings.fixed_height_desktop }} - {{ section.settings.fixed_height_mobile }}) * ((100vw - {{ breakpoint_sm }}px) / {{ breakpoint_xxl | minus: breakpoint_sm }})));
      }
    }
    @media (min-width: {{ breakpoint_page }}px) {
      #{{ section.id }} before-after {
        min-height: {{ section.settings.fixed_height_desktop }}px;
      }
    }
  {%- endif -%}

  {% for block in section.blocks %}
    #{{ section.id }} #{{ block.id }} .collection-card--hero {
      --bg-color: {{ block.settings.bg_color }};
      --bg-color-hover: {{ block.settings.bg_color_hover }};
    }
  {% endfor %}
{%- endstyle -%}

<div id="{{ section.id }}" class="section-background{% if section.settings.background_mode == 'image' %} relative{% endif %}" {%- render 'animation-attrs', attrs: 'data-cc-animate' -%}>
  {%- if section.settings.background_mode == 'image' and section.settings.background_image != blank -%}
    <div class="absolute inset-0">
      {%- render 'image',
        image: section.settings.background_image,
        src_width: 1400,
        widths: '480, 980, 1200, 1400, 1600, 1920, 2560, 3200',
        class: 'img-fit cover',
        sizes: '100vw'
      -%}
    </div>
  {%- endif -%}

  <div class="section z-3 color-scheme{% if section.settings.background_mode != 'default' %} color-scheme--no-bg{% endif %} color-scheme--{{ color_scheme }}">
    <ul class="hero-collections relative" role="list">
      {%- for block in section.blocks -%}
        <li id="{{ block.id }}" {{ block.shopify_attributes }}>
          {% render 'collection-card-hero',
            collection: block.settings.collection,
            image: block.settings.image,
            image_width: block.settings.image_width,
            image_ratio: section.settings.card_image_ratio,
            image_shadow: block.settings.image_shadow,
            image_inset: block.settings.image_inset,
            image_inset_width: block.settings.image_inset_width,
            custom_title: block.settings.title,
            heading_size: block.settings.heading_size,
            show_description: block.settings.show_description,
            custom_description: block.settings.description,
            button_text: block.settings.button_text,
            button_style: block.settings.button_style,
            button_inline: block.settings.button_inline,
            show_marquee_on_hover: block.settings.show_marquee_on_hover,
            color_scheme: color_scheme
          %}
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>

{% schema %}
{
  "name": "Hero collections",
  "tag": "section",
  "class": "cc-hero-collections section non-join",
  "max_blocks": 2,
  "disabled_on": {
    "templates": [
      "password"
    ],
    "groups": [
      "aside"
    ]
  },
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "select",
      "id": "card_image_ratio",
      "label": "Image shape (aspect ratio)",
      "options": [
        {
          "value": "1.77",
          "label": "Landscape"
        },
        {
          "value": "1",
          "label": "Square"
        },
        {
          "value": "0.75",
          "label": "Portrait"
        }
      ],
      "default": "0.75"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "background_mode",
      "label": "Section background",
      "info": "Visible when block backgrounds are partially or fully transparent.",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "color",
          "label": "Color"
        },
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "simple-gradient",
          "label": "Simple gradient"
        },
        {
          "value": "advanced-gradient",
          "label": "Advanced gradient"
        }
      ],
      "default": "default"
    },
    {
      "visible_if": "{{ section.settings.background_mode == 'color' }}",
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "visible_if": "{{ section.settings.background_mode == 'image' }}",
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "visible_if": "{{ section.settings.background_mode == 'simple-gradient' }}",
      "type": "color",
      "id": "background_gradient_stop_1",
      "label": "Gradient start",
      "default": "#cccccc"
    },
    {
      "visible_if": "{{ section.settings.background_mode == 'simple-gradient' }}",
      "type": "color",
      "id": "background_gradient_stop_2",
      "label": "Gradient end",
      "default": "#ffffff"
    },
    {
      "visible_if": "{{ section.settings.background_mode == 'simple-gradient' }}",
      "type": "select",
      "id": "background_gradient_curve",
      "label": "Gradient style",
      "options": [
        {
          "value": "linear",
          "label": "Linear"
        },
        {
          "value": "ease-up",
          "label": "Ease up"
        },
        {
          "value": "ease-down",
          "label": "Ease down"
        }
      ],
      "default": "linear"
    },
    {
      "visible_if": "{{ section.settings.background_mode == 'advanced-gradient' }}",
      "type": "color_background",
      "id": "background_gradient",
      "label": "Advanced gradient",
      "default": "linear-gradient(#f8f1f4, #f8f1f4 12%, #c8bdc1, #e8dccc 92%)"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "header",
          "content": "Images"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Optional. Replaces the collections default image."
        },
        {
          "type": "range",
          "id": "image_width",
          "min": 100,
          "max": 300,
          "step": 10,
          "unit": "px",
          "label": "Image width",
          "default": 200
        },
        {
          "type": "checkbox",
          "id": "image_shadow",
          "label": "Image shadow",
          "default": true
        },
        {
          "type": "image_picker",
          "id": "image_inset",
          "label": "Inset image",
          "info": "Optional. Displayed on hover."
        },
        {
          "visible_if": "{{ block.settings.image_inset != blank }}",
          "type": "range",
          "id": "image_inset_width",
          "min": 32,
          "max": 128,
          "step": 4,
          "unit": "px",
          "label": "Image inset width",
          "default": 80
        },
        {
          "type": "header",
          "content": "Content"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "info": "Optional. Replaces the collection's title."
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "Heading size",
          "options": [
            {
              "value": "h4",
              "label": "Extra extra small"
            },
            {
              "value": "h3",
              "label": "Extra small"
            },
            {
              "value": "h2",
              "label": "Small"
            },
            {
              "value": "h1",
              "label": "Medium"
            },
            {
              "value": "x-large-heading",
              "label": "Large"
            },
            {
              "value": "xx-large-heading",
              "label": "Extra large"
            }
          ],
          "default": "h3"
        },
        {
          "type": "checkbox",
          "id": "show_description",
          "label": "Show description",
          "default": false
        },
        {
          "visible_if": "{{ block.settings.show_description }}",
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "info": "Optional. Replaces the collection's description."
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Shop now"
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button style",
          "options": [
            {
              "value": "link",
              "label": "Link"
            },
            {
              "value": "btn btn--primary",
              "label": "Primary button"
            },
            {
              "value": "btn btn--secondary",
              "label": "Secondary button"
            }
          ],
          "default": "btn btn--primary"
        },
        {
          "type": "checkbox",
          "id": "button_inline",
          "label": "Display inline button",
          "info": "Display button alongside content when space allows.",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_marquee_on_hover",
          "label": "Show animated text on hover",
          "default": true
        },
        {
          "type": "header",
          "content": "Style"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background color",
          "alpha": true
        },
        {
          "type": "color",
          "id": "bg_color_hover",
          "label": "Hover background color",
          "info": "Displayed by default on mobiles and tablets.",
          "alpha": true,
          "default": "#e7cab8"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero collections",
      "category": "Collections",
      "blocks": [
        {
          "type": "collection",
          "settings": {
            "bg_color": "#eac9ba"
          }
        },
        {
          "type": "collection",
          "settings": {
            "bg_color": "#efd7e5"
          }
        }
      ]
    }
  ]
}
{% endschema %}
