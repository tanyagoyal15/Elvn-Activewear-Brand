{%- assign color_menu = linklists[section.settings.color_menu] -%}
{%- assign color_hex = collection.metafields.custom.color_hex.value | default: collection.metafields.custom.color.value | default: '#b8b0a3' -%}
{%- assign color_display_name = collection.metafields.custom.color_display_name.value | default: collection.title -%}
{%- assign color_story = collection.metafields.custom.story.value | default: collection.description -%}
{%- assign hero_image = collection.metafields.custom.hero_image.value | default: collection.image -%}
{%- assign secondary_image = collection.metafields.custom.secondary_image.value -%}
{%- assign palette_1 = collection.metafields.custom.palette_1.value -%}
{%- assign palette_2 = collection.metafields.custom.palette_2.value -%}
{%- assign palette_3 = collection.metafields.custom.palette_3.value -%}
{%- assign palette_4 = collection.metafields.custom.palette_4.value -%}
{%- assign shade_collections = collection.metafields.custom.shade_collections.value -%}
{%- assign editorial_images = collection.metafields.custom.editorial_images.value -%}

<link rel="stylesheet" href="{{ 'products-grid.css' | asset_url }}">
<link rel="stylesheet" href="{{ 'quick-add.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'product.css' | asset_url }}" media="print" onload="this.media='all'">
<script src="{{ 'quick-add.js' | asset_url }}" defer></script>
<script src="{{ 'product-form.js' | asset_url }}" defer></script>

{%- liquid
  assign image_ratio = settings.prod_card_image_ratio
  if image_ratio == 'shortest' or image_ratio == 'tallest'
    assign image_ratio = 1
  endif
-%}

<section class="color-editorial color-editorial--{{ section.settings.color_scheme }}">
  <div class="color-editorial__shell">
    <header class="color-editorial__hero">
      <div class="color-editorial__intro">
        <p class="color-editorial__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        <h1 class="color-editorial__title">{{ color_display_name | escape }}</h1>
        {%- if color_story != blank -%}
          <div class="color-editorial__story rte">{{ color_story }}</div>
        {%- endif -%}

        <div class="color-editorial__palette">
          <span class="color-editorial__swatch color-editorial__swatch--primary" style="--swatch-color: {{ color_hex }};"></span>
          {%- if palette_1 != blank -%}<span class="color-editorial__swatch" style="--swatch-color: {{ palette_1 }};"></span>{%- endif -%}
          {%- if palette_2 != blank -%}<span class="color-editorial__swatch" style="--swatch-color: {{ palette_2 }};"></span>{%- endif -%}
          {%- if palette_3 != blank -%}<span class="color-editorial__swatch" style="--swatch-color: {{ palette_3 }};"></span>{%- endif -%}
          {%- if palette_4 != blank -%}<span class="color-editorial__swatch" style="--swatch-color: {{ palette_4 }};"></span>{%- endif -%}
        </div>

        {%- if shade_collections != blank -%}
          <div class="color-editorial__shades">
            <p class="color-editorial__section-label">Shades</p>
            <div class="color-editorial__shade-list">
              {%- for shade in shade_collections -%}
                {%- assign shade_hex = shade.metafields.custom.color_hex.value | default: shade.metafields.custom.color.value | default: color_hex -%}
                <a class="color-editorial__shade-pill" href="{{ shade.url }}">
                  <span class="color-editorial__shade-dot" style="--shade-color: {{ shade_hex }};"></span>
                  <span>{{ shade.title | escape }}</span>
                </a>
              {%- endfor -%}
            </div>
          </div>
        {%- endif -%}
      </div>

      <div class="color-editorial__hero-media">
        {%- if hero_image != blank -%}
          <div class="color-editorial__hero-image color-editorial__hero-image--primary">
            {% render 'image', image: hero_image, src_width: 1400, widths: '700, 900, 1200, 1400, 1800', class: 'img-fit', sizes: '(min-width: 990px) 44vw, 100vw' %}
          </div>
        {%- endif -%}
        {%- if secondary_image != blank -%}
          <div class="color-editorial__hero-image color-editorial__hero-image--secondary">
            {% render 'image', image: secondary_image, src_width: 1100, widths: '480, 700, 900, 1100, 1400', class: 'img-fit', sizes: '(min-width: 990px) 24vw, 100vw' %}
          </div>
        {%- endif -%}
      </div>
    </header>

    {%- if editorial_images != blank -%}
      <section class="color-editorial__moodboard-block">
        <div class="color-editorial__section-head">
          <p class="color-editorial__section-label">{{ section.settings.moodboard_label | escape }}</p>
        </div>
        <div class="color-editorial__moodboard">
          {%- for image in editorial_images limit: 8 -%}
            <div class="color-editorial__mood-tile color-editorial__mood-tile--{{ forloop.index }}">
              {% render 'image', image: image, src_width: 900, widths: '360, 540, 720, 900, 1200', class: 'img-fit', sizes: '(min-width: 990px) 20vw, 50vw' %}
            </div>
          {%- endfor -%}
        </div>
      </section>
    {%- endif -%}

    <section class="color-editorial__products">
      <div class="color-editorial__section-head color-editorial__section-head--products">
        <div>
          <p class="color-editorial__section-label">{{ section.settings.products_label | escape }}</p>
          <h2 class="color-editorial__section-title">{{ section.settings.products_heading | escape }}</h2>
        </div>
      </div>

      <ul class="color-editorial__product-grid grid gap-x-5 gap-y-6 md:gap-6 stretch-cards" role="list">
        {%- for product in collection.products -%}
          <li>
            {% render 'product-card', product: product, image_ratio: image_ratio %}
          </li>
        {%- endfor -%}
      </ul>
    </section>

    {%- if color_menu.links.size > 0 -%}
      <section class="color-editorial__other-colors">
        <div class="color-editorial__section-head">
          <div>
            <p class="color-editorial__section-label">{{ section.settings.other_colors_label | escape }}</p>
            <h2 class="color-editorial__section-title">{{ section.settings.other_colors_heading | escape }}</h2>
          </div>
        </div>

        <div class="color-editorial__other-grid">
          {%- for link in color_menu.links -%}
            {%- assign other_collection = link.object -%}
            {%- if other_collection == blank or other_collection.handle == collection.handle -%}{% continue %}{%- endif -%}
            {%- assign other_hex = other_collection.metafields.custom.color_hex.value | default: other_collection.metafields.custom.color.value | default: '#b8b0a3' -%}
            {%- assign other_image = other_collection.metafields.custom.card_image.value | default: other_collection.image -%}
            <a class="color-editorial__other-card" href="{{ other_collection.url }}">
              <div class="color-editorial__other-media">
                {%- if other_image != blank -%}
                  {% render 'image', image: other_image, src_width: 700, widths: '280, 420, 560, 700, 900', class: 'img-fit', sizes: '(min-width: 990px) 16vw, 42vw' %}
                {%- endif -%}
              </div>
              <div class="color-editorial__other-info">
                <span class="color-editorial__other-dot" style="--swatch-color: {{ other_hex }};"></span>
                <span class="color-editorial__other-name">{{ other_collection.title | escape }}</span>
              </div>
            </a>
          {%- endfor -%}
        </div>
      </section>
    {%- endif -%}
  </div>
</section>

<style>
  .color-editorial {
    --editorial-bg: #f7f4ef;
    --editorial-text: #171717;
    --editorial-muted: #68645d;
    background: var(--editorial-bg);
    color: var(--editorial-text);
    padding: 28px 0 72px;
  }

  .color-editorial__shell {
    width: min(100% - 40px, 1360px);
    margin: 0 auto;
  }

  .color-editorial__hero {
    display: grid;
    grid-template-columns: minmax(260px, 420px) minmax(0, 1fr);
    gap: clamp(24px, 4vw, 56px);
    align-items: start;
    padding: 28px 0 44px;
  }

  .color-editorial__intro {
    position: sticky;
    top: calc(var(--header-height, 0px) + 20px);
  }

  .color-editorial__eyebrow,
  .color-editorial__section-label {
    margin: 0 0 10px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--editorial-muted);
  }

  .color-editorial__title,
  .color-editorial__section-title {
    margin: 0;
    font-size: clamp(28px, 4vw, 54px);
    font-weight: 600;
    line-height: 0.95;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .color-editorial__section-title {
    font-size: clamp(20px, 2vw, 28px);
    line-height: 1.05;
  }

  .color-editorial__story {
    margin-top: 18px;
    color: var(--editorial-muted);
    font-size: 15px;
    line-height: 1.7;
    max-width: 34ch;
  }

  .color-editorial__palette,
  .color-editorial__shade-list,
  .color-editorial__other-info {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
  }

  .color-editorial__palette {
    margin-top: 22px;
  }

  .color-editorial__swatch,
  .color-editorial__other-dot,
  .color-editorial__shade-dot {
    width: 16px;
    height: 16px;
    border-radius: 999px;
    background: var(--swatch-color, #ccc);
    border: 1px solid rgba(0,0,0,0.08);
    flex-shrink: 0;
  }

  .color-editorial__shade-dot {
    width: 12px;
    height: 12px;
    background: var(--shade-color, #ccc);
  }

  .color-editorial__shades {
    margin-top: 26px;
  }

  .color-editorial__shade-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 999px;
    color: var(--editorial-text);
    font-size: 12px;
    text-decoration: none;
  }

  .color-editorial__hero-media {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(220px, 0.75fr);
    gap: 16px;
  }

  .color-editorial__hero-image {
    position: relative;
    overflow: hidden;
    background: #eee8de;
  }

  .color-editorial__hero-image--primary {
    aspect-ratio: 4 / 5;
  }

  .color-editorial__hero-image--secondary {
    aspect-ratio: 4 / 5;
    margin-top: 58px;
  }

  .color-editorial__hero-image img,
  .color-editorial__mood-tile img,
  .color-editorial__other-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .color-editorial__moodboard-block,
  .color-editorial__products,
  .color-editorial__other-colors {
    margin-top: 56px;
  }

  .color-editorial__section-head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 18px;
    margin-bottom: 22px;
  }

  .color-editorial__moodboard {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
    grid-auto-flow: dense;
  }

  .color-editorial__mood-tile {
    position: relative;
    overflow: hidden;
    background: #eee8de;
    aspect-ratio: 4 / 5;
  }

  .color-editorial__mood-tile--2,
  .color-editorial__mood-tile--5 {
    aspect-ratio: 3 / 4;
  }

  .color-editorial__mood-tile--3,
  .color-editorial__mood-tile--6 {
    aspect-ratio: 1 / 1;
  }

  .color-editorial__product-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .color-editorial__other-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .color-editorial__other-card {
    text-decoration: none;
    color: inherit;
  }

  .color-editorial__other-media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: #eee8de;
    margin-bottom: 10px;
  }

  .color-editorial__other-name {
    font-size: 14px;
    line-height: 1.3;
  }

  @media (min-width: 768px) {
    .color-editorial__product-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .color-editorial__other-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media (max-width: 989.98px) {
    .color-editorial__hero {
      grid-template-columns: 1fr;
    }

    .color-editorial__intro {
      position: static;
    }

    .color-editorial__hero-media {
      grid-template-columns: 1fr;
    }

    .color-editorial__hero-image--secondary {
      margin-top: 0;
    }

    .color-editorial__moodboard {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>

{% schema %}
{
  "name": "Color editorial",
  "class": "cc-color-editorial",
  "settings": [
    {
      "type": "link_list",
      "id": "color_menu",
      "label": "Color menu"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Color study"
    },
    {
      "type": "text",
      "id": "moodboard_label",
      "label": "Moodboard label",
      "default": "Editorial board"
    },
    {
      "type": "text",
      "id": "products_label",
      "label": "Products label",
      "default": "Shop this color"
    },
    {
      "type": "text",
      "id": "products_heading",
      "label": "Products heading",
      "default": "Pieces in this palette"
    },
    {
      "type": "text",
      "id": "other_colors_label",
      "label": "Other colors label",
      "default": "Explore more"
    },
    {
      "type": "text",
      "id": "other_colors_heading",
      "label": "Other colors heading",
      "default": "Other colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
