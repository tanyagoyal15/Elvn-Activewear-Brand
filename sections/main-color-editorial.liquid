{%- assign color_menu = linklists[section.settings.color_menu] -%}
{%- assign color_hex = collection.metafields.custom.color_hex.value | default: collection.metafields.custom.color.value | default: '#b8b0a3' -%}
{%- assign color_display_name = collection.metafields.custom.color_display_name.value | default: collection.title -%}
{%- assign selected_color_handle = color_display_name | handleize -%}
{%- assign hero_image = collection.metafields.custom.color_card_image.value | default: collection.metafields.custom.card_image.value | default: collection.image -%}
{%- if hero_image == blank and collection.products.first -%}
  {%- assign hero_image = collection.products.first.featured_image -%}
{%- endif -%}

<link rel="stylesheet" href="{{ 'products-grid.css' | asset_url }}">
<link rel="stylesheet" href="{{ 'quick-add.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'product.css' | asset_url }}" media="print" onload="this.media='all'">
<script src="{{ 'quick-add.js' | asset_url }}" defer></script>
<script src="{{ 'product-form.js' | asset_url }}" defer></script>

<div class="ce">

  <!-- ① HERO -->
  <div class="ce__hero">
    <div class="ce__hero-media">
      {%- if hero_image != blank -%}
        {%- render 'image', image: hero_image, src_width: 1800, widths: '800, 1200, 1600, 1800', class: 'ce__hero-img', sizes: '100vw' -%}
      {%- else -%}
        <div class="ce__hero-img ce__hero-img--solid" style="background-color: {{ color_hex }};"></div>
      {%- endif -%}
      <div class="ce__hero-veil"></div>
    </div>

    <div class="ce__hero-text">
      <span class="ce__hero-eyebrow">{{ section.settings.eyebrow | escape }}</span>
      <h1 class="ce__hero-name">{{ color_display_name | upcase | escape }}</h1>
    </div>

    <span class="ce__hero-dot" style="background: {{ color_hex }};"></span>
  </div>

  <!-- ② PALETTE STRIP -->
  <nav class="ce__palette-bar" aria-label="Color palette navigation">
    <div class="ce__palette-inner">
      <span class="ce__swatch ce__swatch--active" aria-current="true">
        <span class="ce__swatch-fill" style="background: {{ color_hex }};"></span>
        <span class="ce__swatch-name">{{ color_display_name | escape }}</span>
      </span>

      {%- if color_menu != blank -%}
        {%- for link in color_menu.links -%}
          {%- assign lc = link.object -%}
          {%- if lc == blank or lc.handle == collection.handle -%}{% continue %}{%- endif -%}
          {%- assign lhex = lc.metafields.custom.color_hex.value | default: lc.metafields.custom.color.value | default: '#d0c9bd' -%}
          {%- assign lname = lc.metafields.custom.color_display_name.value | default: lc.title -%}
          <a class="ce__swatch" href="{{ lc.url }}">
            <span class="ce__swatch-fill" style="background: {{ lhex }};"></span>
            <span class="ce__swatch-name">{{ lname | escape }}</span>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </nav>

  <!-- ③ PRODUCTS -->
  <div class="ce__products">
    <div class="ce__shell">
      <header class="ce__products-hd">
        <span class="ce__label">{{ section.settings.products_label | escape }}</span>
        <h2 class="ce__products-title">{{ section.settings.products_heading | escape }}</h2>
        <div class="ce__rule"></div>
      </header>
      <ul class="ce__grid stretch-cards" role="list">
        {%- for product in collection.products -%}
          <li>
            {% render 'product-card', product: product, image_ratio: 1.06, target_color_handle: selected_color_handle %}
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>

  <!-- ④ EXPLORE OTHER COLORS -->
  {%- if color_menu != blank -%}
    {%- assign has_others = false -%}
    {%- for link in color_menu.links -%}
      {%- assign olc = link.object -%}
      {%- if olc != blank and olc.handle != collection.handle -%}
        {%- assign has_others = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if has_others -%}
      <div class="ce__explore">
        <div class="ce__shell">
          <header class="ce__explore-hd">
            <span class="ce__label">{{ section.settings.other_colors_label | escape }}</span>
            <h2 class="ce__explore-title">{{ section.settings.other_colors_heading | escape }}</h2>
          </header>
        </div>
        <div class="ce__explore-scroll">
          <div class="ce__explore-track">
            {%- for link in color_menu.links -%}
              {%- assign olc = link.object -%}
              {%- if olc == blank or olc.handle == collection.handle -%}{% continue %}{%- endif -%}
              {%- assign ohex = olc.metafields.custom.color_hex.value | default: olc.metafields.custom.color.value | default: '#d0c9bd' -%}
              {%- assign oname = olc.metafields.custom.color_display_name.value | default: olc.title -%}
              {%- assign oimg = olc.metafields.custom.color_card_image.value | default: olc.metafields.custom.card_image.value | default: olc.image -%}
              {%- if oimg == blank and olc.products.first -%}
                {%- assign oimg = olc.products.first.featured_image -%}
              {%- endif -%}
              <a class="ce__ec" href="{{ olc.url }}" aria-label="{{ oname | escape }}">
                <div class="ce__ec-media">
                  {%- if oimg != blank -%}
                    {%- render 'image', image: oimg, src_width: 600, widths: '300, 480, 600', class: 'ce__ec-img', sizes: '(max-width: 767px) 58vw, 280px' -%}
                  {%- else -%}
                    <div class="ce__ec-img ce__ec-img--solid" style="background: {{ ohex }};"></div>
                  {%- endif -%}
                  <div class="ce__ec-overlay">
                    <span class="ce__ec-dot" style="background: {{ ohex }};"></span>
                    <span class="ce__ec-oname">{{ oname | upcase | escape }}</span>
                    <span class="ce__ec-arrow">&#8599;</span>
                  </div>
                </div>
              </a>
            {%- endfor -%}
          </div>
        </div>
      </div>
    {%- endif -%}
  {%- endif -%}

</div>

<style>
  /* ─── COLOR EDITORIAL PAGE ─────────────────────── */

  .ce {
    --ce-bg: #f5f0eb;
    --ce-text: #1a1a1a;
    --ce-muted: #7a756d;
    --ce-border: rgba(26, 26, 26, 0.1);
    --ce-shell-w: min(100% - 48px, 1240px);
    background: var(--ce-bg);
    color: var(--ce-text);
  }

  /* HERO */
  .ce__hero {
    {% comment %} position: relative; {% endcomment %}
    width: 100%;
    padding: 50px;
    {% comment %} height: clamp(440px, 68vh, 780px); {% endcomment %}
    overflow: hidden;
  }

  .ce__hero-media {
    {% comment %} position: absolute; {% endcomment %}
    {% comment %} inset: 0; {% endcomment %}
  }

  .ce__hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: none;

  }

  .ce__hero-img--solid {
    width: 100%;
    height: 100%;
  }

  .ce__hero-veil {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(12, 9, 7, 0.68) 0%,
      rgba(12, 9, 7, 0.15) 42%,
      transparent 100%
    );
  }

  .ce__hero-text {
    {% comment %} position: absolute; {% endcomment %}
    {% comment %} bottom: 0; {% endcomment %}
    {% comment %} left: 0; {% endcomment %}
    {% comment %} right: 0; {% endcomment %}
    {% comment %} padding: 0 clamp(20px, 5vw, 72px) clamp(28px, 5.5vh, 56px); {% endcomment %}

    color: #000;
    /* display: flex; */
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
  }

  .ce__hero-eyebrow {
    display: block;
    font-size: 9px;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: #000;
    {% comment %} color: rgba(255, 255, 255, 0.55); {% endcomment %}
    margin-bottom: 12px;
    font-weight: 500;
  }

  .ce__hero-name {
    margin: 0;
    font-size: clamp(48px, 9.5vw, 80px);
    line-height: 0.88;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    {% comment %} color: #fff; {% endcomment %}
     color: #000;
    font-weight: 300;
  }

  .ce__hero-dot {
    position: absolute;
    bottom: clamp(28px, 5.5vh, 56px);
    right: clamp(20px, 5vw, 72px);
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 0.4);
  }

  /* PALETTE BAR */
  .ce__palette-bar {
    width: 100%;
    padding: 30px 300px 20px 300px;
    border-bottom: 1px solid var(--ce-border);
  }

  .ce__palette-inner {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none;
    padding-bottom: 2px;
    align-items: flex-start;
  }

  .ce__palette-inner::-webkit-scrollbar {
    display: none;
  }

  .ce__swatch {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 7px;
    flex: 0 0 auto;
    text-decoration: none;
    color: var(--ce-text);
    cursor: pointer;
  }

  .ce__swatch-fill {
    display: block;
    width: clamp(72px, 13vw, 80px);
    height: 5px;
    transition: height 0.22s ease;
  }

  .ce__swatch:hover .ce__swatch-fill {
    height: 9px;
  }

  .ce__swatch--active .ce__swatch-fill {
    height: 9px;
    outline: 1.5px solid rgba(26, 26, 26, 0.45);
    outline-offset: 2.5px;
  }

  .ce__swatch-name {
    font-size: 8.5px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ce-muted);
    white-space: nowrap;
  }

  .ce__swatch--active .ce__swatch-name {
    color: var(--ce-text);
    font-weight: 600;
  }

  /* SHELL */
  .ce__shell {
    width: var(--ce-shell-w);
    margin: 0 auto;
  }

  /* LABEL */
  .ce__label {
    display: block;
    font-size: 9px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--ce-muted);
    margin-bottom: 10px;
  }

  /* PRODUCTS */
  .ce__products {
    padding: 52px 0 68px;
  }

  .ce__products-hd {
    margin-bottom: 0;
  }

  .ce__products-title {
    margin: 0 0 18px;
    font-size: clamp(20px, 3vw, 32px);
    font-weight: 300;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1.1;
  }

  .ce__rule {
    width: 100%;
    height: 1px;
    background: var(--ce-border);
    margin-bottom: 0;
  }

  .ce__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    list-style: none;
    margin: 0;
    padding: 28px 0 0;
  }

  /* EXPLORE OTHER COLORS */
  .ce__explore {
    border-top: 1px solid var(--ce-border);
    padding-bottom: 80px;
  }

  .ce__explore-hd {
    padding: 44px 0 30px;
  }

  .ce__explore-title {
    margin: 0;
    font-size: clamp(18px, 2.4vw, 28px);
    font-weight: 300;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .ce__explore-scroll {
    overflow-x: auto;
    scrollbar-width: none;
    padding: 0 clamp(20px, 5vw, 72px);
  }

  .ce__explore-scroll::-webkit-scrollbar {
    display: none;
  }

  .ce__explore-track {
    display: flex;
    gap: 14px;
  }

  .ce__ec {
    flex: 0 0 auto;
    width: clamp(210px, 21vw, 300px);
    text-decoration: none;
    color: var(--ce-text);
  }

  .ce__ec-media {
    position: relative;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #e6e0d8;
  }

  .ce__ec-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.55s ease;
  }

  .ce__ec-img--solid {
    width: 100%;
    height: 100%;
  }

  .ce__ec:hover .ce__ec-img {
    transform: scale(1.05);
  }

  .ce__ec-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 48px 14px 16px;
    background: linear-gradient(to top, rgba(10, 8, 6, 0.62) 0%, transparent 100%);
    display: flex;
    align-items: flex-end;
    gap: 8px;
  }

  .ce__ec-dot {
    flex-shrink: 0;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.45);
    margin-bottom: 1px;
  }

  .ce__ec-oname {
    font-size: 10px;
    letter-spacing: 0.16em;
    color: rgba(255, 255, 255, 0.9);
    text-transform: uppercase;
    font-weight: 500;
    flex: 1;
    line-height: 1.3;
  }

  .ce__ec-arrow {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.6);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .ce__ec:hover .ce__ec-arrow {
    transform: translate(2px, -2px);
  }

  /* RESPONSIVE */
  @media (max-width: 767.98px) {
    .ce {
      --ce-shell-w: min(100% - 32px, 1240px);
    }

    .ce__hero {
      height: clamp(280px, 56vh, 460px);
    }

    .ce__hero-name {
      font-size: clamp(34px, 12vw, 64px);
    }

    .ce__palette-bar {
      padding: 14px 16px;
    }

    .ce__swatch-fill {
      width: clamp(60px, 22vw, 110px);
    }

    .ce__products {
      padding: 32px 0 48px;
    }

    .ce__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 14px 10px;
    }

    .ce__explore-scroll {
      padding: 0 16px;
    }

    .ce__ec {
      width: clamp(170px, 56vw, 250px);
    }
  }
</style>

{% schema %}
{
  "name": "Color editorial",
  "class": "cc-color-editorial",
  "settings": [
    {
      "type": "link_list",
      "id": "color_menu",
      "label": "Color menu"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Color"
    },
    {
      "type": "text",
      "id": "products_label",
      "label": "Products label",
      "default": "Shop this color"
    },
    {
      "type": "text",
      "id": "products_heading",
      "label": "Products heading",
      "default": "Pieces in this palette"
    },
    {
      "type": "text",
      "id": "other_colors_label",
      "label": "Other colors label",
      "default": "Explore more"
    },
    {
      "type": "text",
      "id": "other_colors_heading",
      "label": "Other colors heading",
      "default": "Colors in this palette"
    }
  ]
}
{% endschema %}
