{%- assign color_menu = linklists[section.settings.color_menu] -%}
{%- assign color_hex = collection.metafields.custom.color_hex.value | default: collection.metafields.custom.color.value | default: '#b8b0a3' -%}
{%- assign color_display_name = collection.metafields.custom.color_display_name.value | default: collection.title -%}
{%- assign selected_color_handle = color_display_name | handleize -%}

<link rel="stylesheet" href="{{ 'products-grid.css' | asset_url }}">
<link rel="stylesheet" href="{{ 'quick-add.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'product.css' | asset_url }}" media="print" onload="this.media='all'">
<script src="{{ 'quick-add.js' | asset_url }}" defer></script>
<script src="{{ 'product-form.js' | asset_url }}" defer></script>

<section class="color-editorial color-editorial--{{ section.settings.color_scheme }}">
  <div class="color-editorial__shell">
    <header class="color-editorial__header">
      <p class="color-editorial__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      <h1 class="color-editorial__title">{{ color_display_name | escape }}</h1>
    </header>

    <section class="color-editorial__palette-section">
      <div class="color-editorial__palette-track" aria-label="Color navigation">
        <span class="color-editorial__rect is-active" style="--rect-color: {{ color_hex }};">
          <span class="color-editorial__rect-label">{{ color_display_name | escape }}</span>
        </span>

        {%- if color_menu != blank and color_menu.links.size > 0 -%}
          {%- for link in color_menu.links -%}
            {%- assign linked_collection = link.object -%}
            {%- if linked_collection == blank or linked_collection.handle == collection.handle -%}{% continue %}{%- endif -%}
            {%- assign linked_hex = linked_collection.metafields.custom.color_hex.value | default: linked_collection.metafields.custom.color.value | default: '#d0c9bd' -%}
            <a class="color-editorial__rect" href="{{ linked_collection.url }}" style="--rect-color: {{ linked_hex }};" aria-label="{{ linked_collection.title | escape }}">
              <span class="color-editorial__rect-label">{{ linked_collection.title | escape }}</span>
            </a>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </section>

    <section class="color-editorial__products">
      <ul class="color-editorial__product-grid grid gap-x-4 gap-y-5 md:gap-x-5 md:gap-y-6 stretch-cards" role="list">
        {%- for product in collection.products -%}
          <li>
            {% render 'product-card', product: product, image_ratio: 1.06, target_color_handle: selected_color_handle %}
          </li>
        {%- endfor -%}
      </ul>
    </section>
  </div>
</section>

<style>
  .color-editorial {
    --editorial-bg: #f7f4ef;
    --editorial-text: #1a1a1a;
    --editorial-muted: #6c675f;
    background: var(--editorial-bg);
    color: var(--editorial-text);
    padding: 18px 0 42px;
  }

  .color-editorial__shell {
    width: min(100% - 28px, 1220px);
    margin: 0 auto;
  }

  .color-editorial__header {
    margin-bottom: 14px;
  }

  .color-editorial__eyebrow {
    margin: 0 0 6px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--editorial-muted);
  }

  .color-editorial__title {
    margin: 0;
    font-size: clamp(24px, 4vw, 40px);
    line-height: 1.1;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .color-editorial__palette-section {
    margin-bottom: 16px;
  }

  .color-editorial__palette-track {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    padding: 4px 1px 6px;
    scrollbar-width: thin;
  }

  .color-editorial__rect {
    position: relative;
    display: inline-flex;
    align-items: flex-end;
    justify-content: flex-start;
    flex: 0 0 auto;
    width: clamp(108px, 18vw, 180px);
    height: 10px;
    {% comment %} padding: 8px 10px; {% endcomment %}
    {% comment %} border: 1px solid rgba(0, 0, 0, 0.14); {% endcomment %}
    background: var(--rect-color, #d5d0c6);
    color: #161616;
    text-decoration: none;
    transition: transform 0.2s ease;
  }

  .color-editorial__rect:hover {
    transform: translateY(-1px);
  }

  .color-editorial__rect.is-active {
    box-shadow: inset 0 0 0 2px rgba(0, 0, 0, 0.55);
  }

  .color-editorial__rect-label {
    font-size: 10px;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    font-weight: 600;
    background: rgba(255, 255, 255, 0.68);
    padding: 3px 5px;
    line-height: 1;
    display: none;
  }

  .color-editorial__products .product-card .card__quick-add {
    margin-top: 8px;
  }

  .color-editorial__product-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
  }

  @media (max-width: 767.98px) {
    .color-editorial {
      padding: 14px 0 34px;
    }

    .color-editorial__shell {
      width: min(100% - 20px, 1220px);
    }

    .color-editorial__rect {
      width: 100px;
      height: 10px;
    }

    .color-editorial__product-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Color editorial",
  "class": "cc-color-editorial",
  "settings": [
    {
      "type": "link_list",
      "id": "color_menu",
      "label": "Color menu"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Color study"
    },
    {
      "type": "text",
      "id": "moodboard_label",
      "label": "Moodboard label",
      "default": "Editorial board"
    },
    {
      "type": "text",
      "id": "products_label",
      "label": "Products label",
      "default": "Shop this color"
    },
    {
      "type": "text",
      "id": "products_heading",
      "label": "Products heading",
      "default": "Pieces in this palette"
    },
    {
      "type": "text",
      "id": "other_colors_label",
      "label": "Other colors label",
      "default": "Explore more"
    },
    {
      "type": "text",
      "id": "other_colors_heading",
      "label": "Other colors heading",
      "default": "Other colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
