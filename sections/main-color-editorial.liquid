{%- assign color_menu = linklists[section.settings.color_menu] -%}
{%- assign color_hex = collection.metafields.custom.color_hex.value | default: collection.metafields.custom.color.value | default: '#b8b0a3' -%}
{%- assign color_display_name = collection.metafields.custom.color_display_name.value | default: collection.title -%}
{%- assign selected_color_handle = color_display_name | handleize -%}
{%- assign hero_image = collection.metafields.custom.color_card_image.value | default: collection.metafields.custom.card_image.value | default: collection.image -%}
{%- if hero_image == blank and collection.products.first -%}
  {%- assign hero_image = collection.products.first.featured_image -%}
{%- endif -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Host+Grotesk:ital,wght@0,300..800;1,300..800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="{{ 'products-grid.css' | asset_url }}">
<link rel="stylesheet" href="{{ 'quick-add.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'product.css' | asset_url }}" media="print" onload="this.media='all'">
<script src="{{ 'quick-add.js' | asset_url }}" defer></script>
<script src="{{ 'product-form.js' | asset_url }}" defer></script>

<div class="ce">

  <!-- HERO -->
  <div class="ce__hero">

    <div class="ce__hero-left">
      <span class="ce__hero-eyebrow">{{ section.settings.eyebrow | escape }}</span>
      <span class="ce__hero-dot" style="background: {{ color_hex }};"></span>
      <h1 class="ce__hero-name">{{ color_display_name | upcase | escape }}</h1>
      <a class="ce__hero-cta" href="#ce-products">Shop this color &#8599;</a>
    </div>

    <div class="ce__hero-right">
      {%- if hero_image != blank -%}
        {%- render 'image', image: hero_image, src_width: 900, widths: '600, 800, 1000', class: 'ce__hero-img', sizes: '(max-width: 767px) 100vw, 50vw' -%}
      {%- else -%}
        <div class="ce__hero-img--solid" style="background: {{ color_hex }};"></div>
      {%- endif -%}
    </div>

  </div>

  <!-- PALETTE STRIP -->
  <nav class="ce__palette-bar" aria-label="Color palette navigation">
    <div class="ce__palette-inner">
      <span class="ce__swatch ce__swatch--active" aria-current="true">
        <span class="ce__swatch-fill" style="background: {{ color_hex }};"></span>
        <span class="ce__swatch-name">{{ color_display_name | escape }}</span>
      </span>

      {%- if color_menu != blank -%}
        {%- for link in color_menu.links -%}
          {%- assign lc = link.object -%}
          {%- if lc == blank or lc.handle == collection.handle -%}{% continue %}{%- endif -%}
          {%- assign lhex = lc.metafields.custom.color_hex.value | default: lc.metafields.custom.color.value | default: '#d0c9bd' -%}
          {%- assign lname = lc.metafields.custom.color_display_name.value | default: lc.title -%}
          <a class="ce__swatch" href="{{ lc.url }}">
            <span class="ce__swatch-fill" style="background: {{ lhex }};"></span>
            <span class="ce__swatch-name">{{ lname | escape }}</span>
          </a>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </nav>

  <!-- PRODUCTS -->
  <div class="ce__products" id="ce-products">
    <div class="ce__shell">
      <header class="ce__products-hd">
        <span class="ce__label">{{ section.settings.products_label | escape }}</span>
        <h2 class="ce__products-title">{{ section.settings.products_heading | escape }}</h2>
        <div class="ce__rule"></div>
      </header>
      <ul class="ce__grid stretch-cards" role="list">
        {%- for product in collection.products -%}
          <li>
            {% render 'product-card', product: product, image_ratio: 1.4, target_color_handle: selected_color_handle %}
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </div>

  <!-- EXPLORE OTHER COLORS -->
  {%- if color_menu != blank -%}
    {%- assign has_others = false -%}
    {%- for link in color_menu.links -%}
      {%- assign olc = link.object -%}
      {%- if olc != blank and olc.handle != collection.handle -%}
        {%- assign has_others = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if has_others -%}
      <div class="ce__explore">
        <div class="ce__shell">
          <header class="ce__explore-hd">
            <span class="ce__label">{{ section.settings.other_colors_label | escape }}</span>
            <h2 class="ce__explore-title">{{ section.settings.other_colors_heading | escape }}</h2>
          </header>
        </div>
        <div class="ce__explore-grid">
          {%- assign ec_count = 0 -%}
          {%- for link in color_menu.links -%}
            {%- assign olc = link.object -%}
            {%- if olc == blank or olc.handle == collection.handle -%}{% continue %}{%- endif -%}
            {%- assign ec_count = ec_count | plus: 1 -%}
            {%- if ec_count > 8 -%}{%- break -%}{%- endif -%}
            {%- assign ohex = olc.metafields.custom.color_hex.value | default: olc.metafields.custom.color.value | default: '#d0c9bd' -%}
            {%- assign oname = olc.metafields.custom.color_display_name.value | default: olc.title -%}
            {%- assign oimg = olc.metafields.custom.color_card_image.value | default: olc.metafields.custom.card_image.value | default: olc.image -%}
            {%- if oimg == blank and olc.products.first -%}
              {%- assign oimg = olc.products.first.featured_image -%}
            {%- endif -%}
            <a class="ce__ec" href="{{ olc.url }}" aria-label="{{ oname | escape }}">
              <div class="ce__ec-media">
                {%- if oimg != blank -%}
                  {%- render 'image', image: oimg, src_width: 800, widths: '400, 600, 800', class: 'ce__ec-img', sizes: '(max-width: 767px) 50vw, 25vw' -%}
                {%- else -%}
                  <div class="ce__ec-img ce__ec-img--solid" style="background: {{ ohex }};"></div>
                {%- endif -%}
                <div class="ce__ec-overlay">
                  <span class="ce__ec-dot" style="background: {{ ohex }};"></span>
                  <span class="ce__ec-oname">{{ oname | upcase | escape }}</span>
                  <span class="ce__ec-arrow">&#8599;</span>
                </div>
              </div>
            </a>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  {%- endif -%}

</div>

<style>

  .ce {
    --ce-font-head: 'Host Grotesk', sans-serif;
    --ce-bg: #fff;
    --ce-text: #1a1a1a;
    --ce-muted: #8a857d;
    --ce-border: rgba(26, 26, 26, 0.09);
    --ce-shell-w: min(100% - 48px, 1240px);
    background: var(--ce-bg);
    color: var(--ce-text);
  }

  @keyframes ce-fade-up {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0);    }
  }

  .ce__hero {
    display: grid;
    grid-template-columns: 1fr;
    overflow: hidden;
    border-bottom: 1px solid var(--ce-border);
  }

  .ce__hero-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: clamp(20px, 3.2vw, 48px) clamp(24px, 4.5vw, 64px);
  }

  .ce__hero-eyebrow {
    display: block;
    font-size: 9px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--ce-muted);
    font-weight: 500;
    margin-bottom: 14px;
    margin-left: 4px;
    animation: ce-fade-up 0.55s ease both;
  }

  .ce__hero-dot {
    display: none;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    margin-bottom: 14px;
    animation: ce-fade-up 0.55s 0.08s ease both;
  }

  .ce__hero-name {
    margin: 0 0 26px;
    font-family: var(--ce-font-head);
    font-size: clamp(32px, 4.8vw, 76px);
    line-height: 0.92;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: #111;
    font-weight: 200;
    animation: ce-fade-up 0.6s 0.14s ease both;
  }

  .ce__hero-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    color: #111;
    padding-bottom: 3px;
    border-bottom: 1px solid currentColor;
    transition: opacity 0.2s ease;
    animation: ce-fade-up 0.55s 0.28s ease both;
    margin-left: 5px;
  }

  .ce__hero-cta:hover { opacity: 0.45; }

  .ce__hero-right {
    overflow: hidden;
    background: #ece8e2;
  }

  .ce__hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: none;
  }

  .ce__hero-img--solid { width: 100%; height: 100%; }

  .ce__palette-bar {
    border-bottom: 1px solid var(--ce-border);
    padding: 22px 0 16px;
  }

  .ce__palette-inner {
    width: var(--ce-shell-w);
    margin: 0 auto;
    display: flex;
    gap: 10px;
    overflow-x: auto;
    scrollbar-width: none;
    padding-bottom: 2px;
    align-items: center;
    justify-content: center;
  }

  .ce__palette-inner::-webkit-scrollbar { display: none; }

  .ce__swatch {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 7px;
    flex: 0 0 auto;
    text-decoration: none;
    color: var(--ce-text);
    cursor: pointer;
  }

  .ce__swatch-fill {
    display: block;
    width: clamp(60px, 10vw, 76px);
    height: 4px;
    border-radius: 2px;
    transition: height 0.2s ease;
  }

  .ce__swatch:hover .ce__swatch-fill { height: 8px; }

  .ce__swatch--active .ce__swatch-fill {
    height: 8px;
    outline-offset: 2px;
  }

  .ce__swatch-name {
    font-size: 8px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ce-muted);
    white-space: nowrap;
  }

  .ce__swatch--active .ce__swatch-name {
    color: var(--ce-text);
    font-weight: 600;
  }

  .ce__shell {
    width: var(--ce-shell-w);
    margin: 0 auto;
  }

  .ce__label {
    display: block;
    font-size: 9px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--ce-muted);
    margin-bottom: 10px;
  }

  .ce__products {
    padding: 44px 0 60px;
  }

  .ce__products-hd {
    margin-bottom: 0;
  }

  .ce__products-title {
    margin: 0 0 16px;
    font-family: var(--ce-font-head);
    font-size: clamp(18px, 2.6vw, 30px);
    font-weight: 300;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.1;
  }

  .ce__rule {
    width: 100%;
    height: 1px;
    background: var(--ce-border);
    margin-bottom: 0;
  }

  .ce__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    list-style: none;
    margin: 0;
    padding: 28px 0 0;
  }


  .ce__explore-hd {
    width: min(4 * 260px + 3 * 6px, 100%);
    margin: 0 auto;
    padding-bottom: 20px;
  }

  .ce__explore-title {
    margin: 0;
    font-family: var(--ce-font-head);
    font-size: clamp(16px, 2.2vw, 26px);
    font-weight: 300;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .ce__explore {
    background: #fbfaf2;
    padding: clamp(32px, 5vw, 40px) 0;
  }

  .ce__explore-grid {
    display: grid;
    grid-template-columns: repeat(4, 260px);
    grid-template-rows: 1fr 1fr;
    height: min(88vh, 820px);
    gap: 6px;
    overflow: hidden;
    justify-content: center;
    margin: 0 auto;
  }

  .ce__ec {
    text-decoration: none;
    color: var(--ce-text);
    min-height: 0;
  }

  .ce__ec-media {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    background: #e6e2dc;
  }

  .ce__ec-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
    display: block;
    transition: transform 0.5s ease;
  }

  .ce__ec-img--solid { width: 100%; height: 100%; }

  .ce__ec:hover .ce__ec-img { transform: scale(1.04); }

  .ce__ec-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 40px 12px 12px;
    background: linear-gradient(to top, rgba(8, 6, 4, 0.58) 0%, transparent 100%);
    display: flex;
    align-items: flex-end;
    gap: 7px;
  }

  .ce__ec-dot {
    flex-shrink: 0;
    width: 7px; height: 7px;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.4);
    margin-bottom: 1px;
  }

  .ce__ec-oname {
    font-size: 10px;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.9);
    text-transform: uppercase;
    font-weight: 500;
    flex: 1;
    line-height: 1.3;
  }

  .ce__ec-arrow {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.55);
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .ce__ec:hover .ce__ec-arrow { transform: translate(2px, -2px); }

  @media (max-width: 767.98px) {
    .ce {
      --ce-shell-w: min(100% - 32px, 1240px);
    }

    .ce__hero {
      grid-template-columns: 1fr;
      height: auto;
      min-height: 0;
      overflow: visible;
    }

    .ce__hero-right {
      overflow: hidden;
      order: -1;
    }

    .ce__hero-left {
      padding: clamp(24px, 6vw, 40px) clamp(18px, 5vw, 32px);
    }

    .ce__hero-name {
      font-size: clamp(30px, 11vw, 56px);
      margin-bottom: 20px;
    }

    .ce__palette-bar { padding: 12px 0 10px; }

    .ce__swatch-fill { width: clamp(52px, 20vw, 100px); }

    .ce__products { padding: 28px 0 40px; }

    .ce__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px 8px;
    }

    .ce__explore {
      padding: 20px 0 0;
    }

    .ce__explore-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: auto;
      height: auto;
      overflow: visible;
      gap: 4px;
    }

    .ce__explore {
      background: none;
      padding: 20px 0 0;
    }

    .ce__explore-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: auto;
      height: auto;
      overflow: visible;
      gap: 4px;
      justify-content: stretch;
    }

    .ce__ec-media {
      aspect-ratio: 3 / 4;
      height: auto;
    }

    .ce__hero-img {
      display: block;
    }
  }
</style>

{% schema %}
{
  "name": "Color editorial",
  "class": "cc-color-editorial",
  "settings": [
    {
      "type": "link_list",
      "id": "color_menu",
      "label": "Color menu"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Color"
    },
    {
      "type": "text",
      "id": "products_label",
      "label": "Products label",
      "default": "Shop this color"
    },
    {
      "type": "text",
      "id": "products_heading",
      "label": "Products heading",
      "default": "Pieces in this palette"
    },
    {
      "type": "text",
      "id": "other_colors_label",
      "label": "Other colors label",
      "default": "Explore more"
    },
    {
      "type": "text",
      "id": "other_colors_heading",
      "label": "Other colors heading",
      "default": "Colors"
    }
  ]
}
{% endschema %}
