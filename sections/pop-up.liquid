{%- if section.blocks.size > 0 or section.settings.image != blank -%}
  {%- unless section.settings.show_to_guests_only and customer and request.design_mode == false -%}
    {%- if section.settings.delay < 2 -%}
      {{ 'popup.css' | asset_url | stylesheet_tag }}
      {{ 'modal.css' | asset_url | stylesheet_tag }}
    {%- else -%}
      <link rel="stylesheet" href="{{ 'popup.css' | asset_url }}" media="print" onload="this.media='all'">
      <link rel="stylesheet" href="{{ 'modal.css' | asset_url }}" media="print" onload="this.media='all'">
    {%- endif -%}
    <script src="{{ 'pop-up.js' | asset_url }}" defer></script>

    {%- liquid
      # constants
      assign breakpoint_md = 769

      if section.settings.mobile_image_enabled
        if section.settings.mobile_image
          assign mobile_image = section.settings.mobile_image
        else
          assign mobile_image = section.settings.image
        endif
      endif

      assign rtl = false
      assign rtl_iso_codes = 'ar,arc,dv,fa,ha,he,khw,ks,ku,ps,ur,yi' | split: ','
      assign current_code_first_part = localization.language.iso_code | split: '-' | first

      if rtl_iso_codes contains current_code_first_part
        assign rtl = true
      endif

      assign image_position = section.settings.image_position
      if rtl
        if image_position == 'left'
          assign image_position = 'right'
        elsif image_position == 'right'
          assign image_position = 'left'
        endif
      endif
    -%}

    {%- capture popup_image -%}
      {%- liquid
        if section.settings.image_cutout
          assign mobile_image_class = 'md:hidden'
          assign desktop_image_class = ''
        else
          assign desktop_image_class = 'img-fit'
          assign mobile_image_class = 'img-fit md:hidden'
        endif

        if mobile_image and mobile_image != section.settings.image
          assign desktop_image_class = desktop_image_class | append: ' hidden md:block'
        endif
      -%}

      {% render 'image',
        image: section.settings.image,
        widths: '460, 700, 860, 1296',
        src_width: 700,
        class: desktop_image_class
      %}

      {%- if mobile_image and mobile_image != section.settings.image -%}
        {% render 'image',
          image: mobile_image,
          widths: '460, 700, 860, 1296',
          src_width: 700,
          class: mobile_image_class
        %}
      {%- endif -%}
    {%-endcapture-%}

    {%- style -%}
      #{{ section.id }} {
        --popup-width: {{ section.settings.popup_width }}px;
      }

      {%- if section.settings.bg_image != blank -%}
        #{{ section.id }} .popup-section__background-image::after {
          background-color: {{ section.settings.tint_color }};
          opacity: {{ section.settings.tint_opacity }}%;
        }
      {%- endif -%}
    {%- endstyle -%}

    <pop-up class="popup-section{% if settings.content_border_radius == '48' %} popup-section--very-rounded{% endif %}{% if mobile_image and section.settings.mobile_image_position == 'top'%} popup-section--with-mob-image{% endif %}{% if section.settings.image_cutout_shadow %} popup-section__cutout-shadow{% endif %} color-scheme color-scheme--{{ section.settings.color_scheme }} modal invisible fixed top-0 left-0 w-full h-full flex justify-center items-center"
            {% if section.settings.image %}style="--image-size: {{ section.settings.image_size }}px"{% endif %}
            id="{{ section.id }}"
            data-trigger="delay"
            data-delay="{{ section.settings.delay }}"
            data-dismiss-days="{% if section.settings.dismiss_days > 0 %}{{ section.settings.dismiss_days }}{% else %}400{% endif %}"
            data-mode="{{ section.settings.mode }}"
            data-show-on-mobile="{{ section.settings.show_on_mobile }}">

      <div class="relative popup-section__container">
        {%- if section.settings.image and section.settings.image_cutout -%}
          <div class="popup-section__cutout-image overflow-hidden popup-section__cutout-image--{{ section.settings.image_position }}{% if mobile_image %} popup-section__cutout-image--mob-{{ section.settings.mobile_image_position }}{% endif %} absolute z-1{% unless mobile_image %} hidden md:block{% endunless %}"
            style="--cutout-offset: {{ section.settings.cutout_offset }}%; border-radius: {{ section.settings.cutout_radius }}px"
          >
            {{ popup_image }}
          </div>
        {%- endif -%}

        <div class="modal__window flex relative bg-theme-bg text-theme-text text-start has-motion" role="dialog" aria-labelledby="{{ section.id }}-heading" aria-modal="true" tabindex="-1">
          <button type="button" class="modal__close-btn absolute text-current js-close-modal" aria-label="{{ 'accessibility.close' | t }}">
            {% render 'icon-close' %}
          </button>

          <div class="modal__main-image-container flex
            {% if mobile_image %}
              {% if section.settings.mobile_image_position == 'top' %}
                flex-col
              {% else %}
                flex-col-reverse
              {% endif %}
            {% endif %}

            {% if section.settings.image and section.settings.image_cutout == false %}
              {% if image_position == 'left' %}
                md:flex-row
              {% elsif image_position == 'right' %}
                md:flex-row-reverse
              {% elsif section.settings.image_position == 'top' %}
                md:flex-col
              {% elsif section.settings.image_position == 'bottom' %}
                md:flex-col-reverse
              {% endif %}
            {% endif %}
          ">
            {%- if section.settings.image and section.settings.image_cutout == false -%}
              <div class="popup-section__image {% if section.settings.image_position == 'left' or section.settings.image_position == 'right' %} popup-section__image-x{% else %} popup-section__image-y{% endif %}  {% unless mobile_image %} hidden md:block{% endunless %} relative"
                   style="--mobile-image-height: {{ section.settings.mobile_image_height }}px;--desktop-image-size: {{ section.settings.image_size }}px;">
                {{ popup_image }}
              </div>
            {%- endif -%}

            <div class="modal__content has-motion modal__content--p-large relative {{ section.settings.text_align }}">
              {%- capture sizes %}{% render 'sizes-attribute' %}{% endcapture -%}
              {%- if section.settings.bg_image != blank -%}
                <div class="popup-section__background-image media media--has-overlay absolute top-0 left-0 h-full w-full">
                  {% render 'image',
                  image: section.settings.bg_image,
                  widths: '460, 700, 860, 1296',
                  src_width: 700,
                  sizes: sizes,
                  class: 'img-fit'
                  %}
                </div>
              {%- endif -%}
              {%- for block in section.blocks -%}
                {%- case block.type -%}
                  {% when '@app' %}
                    <div class="section__block" {{ block.shopify_attributes }}>
                      {% render block %}
                    </div>

                  {%- when 'heading' -%}
                    {%- if block.settings.heading != blank -%}
                      <h2 class="section__block {{ block.settings.heading_size }}" id="{{ section.id }}-heading" {{ block.shopify_attributes }}>
                        {{- block.settings.heading | escape -}}
                      </h2>
                    {%- endif -%}

                  {%- when 'subheading' -%}
                    {%- if block.settings.text != blank -%}
                      <p class="section__block subheading" {{ block.shopify_attributes }}>
                        {{- block.settings.text | escape -}}
                      </p>
                    {%- endif -%}

                  {%- when 'text' -%}
                    {%- if block.settings.text != blank -%}
                      <div class="section__block rte {{ block.settings.text_size }}" {{ block.shopify_attributes }}>
                        {{ block.settings.text }}
                      </div>
                    {%- endif -%}

                  {%- when 'newsletter-signup' -%}
                    <div class="section__block form-width{% if section.settings.text_align == 'text-start' %} me-auto{% elsif section.settings.text_align == 'text-end' %} ms-auto{% else %} mx-auto{% endif %}" {{ block.shopify_attributes }}>
                      {%- assign form_id = section.id | append: '-sign-up' -%}
                      {% render 'newsletter-signup', id: form_id, tags: 'pop-up', arrow_button: true %}
                    </div>

                  {%- when 'countdown' -%}
                    {% style %}
                      #{{ section.id }} .countdown__grid {
                        font-size: calc(({{ block.settings.number_size }} / 1.25) * var(--fluid-1-25));
                      }
                    {% endstyle %}
                    <script src="{{ 'countdown-timer.js' | asset_url }}" defer></script>
                    <div class="section__block countdown__block countdown-font-{{ block.settings.number_font }} no-js-hidden{% if block.settings.enlarge_end_text %} countdown-large-endtext{% endif %}" id="{{ block.id }}" {{ block.shopify_attributes }}>
                      {% render 'countdown-timer',
                        end_date: block.settings.end_date,
                        end_time: block.settings.end_time,
                        end_text: block.settings.end_text,
                        end_midnight: true,
                        hide_on_end: block.settings.hide_on_end,
                        show_labels: block.settings.show_timer_labels
                      %}
                    </div>

                  {%- when 'social' -%}
                    <div class="section__block" {{ block.shopify_attributes }}>
                      {%- assign social_class = section.settings.text_align | split: '-' | last | prepend: 'justify-' -%}
                      {% render 'social-media', icon: settings.social_custom_icon, class: social_class %}
                    </div>

                  {%- when 'button' -%}
                    {%- if block.settings.button_1_label != blank or block.settings.button_2_label != blank -%}
                      <div class="section__block section__block--buttons items-center inline-flex flex-wrap{% if section.settings.text_align == 'text-start' %} justify-start{% elsif section.settings.text_align == 'text-end' %} justify-end{% else %} justify-center{% endif %}" {{ block.shopify_attributes }}>
                        {%- if block.settings.button_1_label != blank %}
                          {%- if block.settings.button_1_link != blank -%}
                            <a class="{{ block.settings.button_1_style }} btn--popup-1 js-close-modal" href="{{ block.settings.button_1_link }}">
                              {{- block.settings.button_1_label | escape -}}
                            </a>
                          {%- else -%}
                            <button class="{{ block.settings.button_1_style }} btn--popup-1 js-close-modal">
                              {{- block.settings.button_1_label | escape -}}
                            </button>
                          {%- endif -%}
                        {%- endif -%}
                        {%- if block.settings.button_2_label != blank %}
                          {%- if block.settings.button_2_link != blank -%}
                            <a class="{{ block.settings.button_2_style }} btn--popup-2 js-close-modal" href="{{ block.settings.button_2_link }}">
                              {{- block.settings.button_2_label | escape -}}
                            </a>
                          {%- else -%}
                            <button class="{{ block.settings.button_2_style }} btn--popup-2 js-close-modal">
                              {{- block.settings.button_2_label | escape -}}
                            </button>
                          {%- endif -%}
                        {%- endif -%}
                      </div>
                    {%- endif -%}
                {%- endcase -%}
              {%- endfor -%}
            </div>
          </div>
        </div>
      </div>
    </pop-up>
  {%- endunless -%}
{%- endif -%}

{% schema %}
{
  "name": "Pop-up",
  "tag": "section",
  "class": "cc-pop-up",
  "settings": [
    {
      "type": "range",
      "id": "delay",
      "label": "Delay seconds",
      "default": 5,
      "min": 0,
      "max": 30,
      "step": 1
    },
    {
      "type": "checkbox",
      "id": "show_to_guests_only",
      "label": "Show to guest users only",
      "info": "Not shown to logged in customers.",
      "default": true
    },
    {
      "type": "range",
      "id": "dismiss_days",
      "label": "Days to remain dismissed",
      "default": 30,
      "info": "Number of days before showing the pop-up again after it gets closed. Set to 0 to show the popup only once.",
      "min": 0,
      "max": 30,
      "step": 1
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "show_on_mobile",
      "label": "Show on mobile",
      "info": "Hiding the popup on mobile could help SEO.",
      "default": true
    },
    {
      "type": "range",
      "id": "popup_width",
      "min": 480,
      "max": 700,
      "step": 10,
      "unit": "px",
      "label": "Popup width on large screens",
      "default": 640
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "options": [
        {
          "value": "text-start",
          "label": "Left"
        },
        {
          "value": "text-center",
          "label": "Center"
        },
        {
          "value": "text-end",
          "label": "Right"
        }
      ],
      "default": "text-center"
    },
    {
      "type": "header",
      "content": "Main image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "visible_if": "{{ section.settings.image }}",
      "type": "range",
      "id": "image_size",
      "min": 100,
      "max": 300,
      "step": 5,
      "unit": "px",
      "label": "Image size",
      "default": 240
    },
    {
      "visible_if": "{{ section.settings.image }}",
      "type": "select",
      "id": "image_position",
      "label": "Position on large screens",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        },
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Mobile image"
    },
    {
      "type": "checkbox",
      "id": "mobile_image_enabled",
      "label": "Show image on mobile",
      "default": false
    },
    {
      "visible_if": "{{ section.settings.mobile_image_enabled }}",
      "type": "image_picker",
      "id": "mobile_image",
      "info": "Optional. Uses main image by default.",
      "label": "Image"
    },
    {
      "visible_if": "{{ section.settings.mobile_image_enabled }}",
      "type": "range",
      "id": "mobile_image_height",
      "min": 100,
      "max": 350,
      "step": 5,
      "unit": "px",
      "label": "Image height",
      "default": 250
    },
    {
      "visible_if": "{{ section.settings.mobile_image_enabled }}",
      "type": "select",
      "id": "mobile_image_position",
      "label": "Position",
      "options": [
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        }
      ],
      "default": "top"
    },
    {
      "type": "header",
      "content": "Cutout image"
    },
    {
      "type": "checkbox",
      "id": "image_cutout",
      "label": "Show as cutout",
      "default": false
    },
    {
      "visible_if": "{{ section.settings.image_cutout }}",
      "type": "checkbox",
      "id": "image_cutout_shadow",
      "label": "Show shadow",
      "default": false
    },
    {
      "visible_if": "{{ section.settings.image_cutout }}",
      "type": "range",
      "id": "cutout_offset",
      "min": -20,
      "max": 20,
      "step": 1,
      "unit": "%",
      "label": "Cutout image offset",
      "default": 0
    },
    {
      "visible_if": "{{ section.settings.image_cutout }}",
      "type": "range",
      "id": "cutout_radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "Cutout image corner radius",
      "default": 0
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image",
      "info": "Optional"
    },
    {
      "visible_if": "{{ section.settings.bg_image }}",
      "type": "color",
      "alpha": true,
      "id": "tint_color",
      "label": "Background image tint",
      "default": "#ffffff"
    },
    {
      "visible_if": "{{ section.settings.bg_image }}",
      "type": "range",
      "id": "tint_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Background image tint opacity",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Sign up and save"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "Heading size",
          "options": [
            {
              "value": "h4",
              "label": "Extra extra small"
            },
            {
              "value": "h3",
              "label": "Extra small"
            },
            {
              "value": "h2",
              "label": "Small"
            },
            {
              "value": "h1",
              "label": "Medium"
            },
            {
              "value": "x-large-heading",
              "label": "Large"
            },
            {
              "value": "xx-large-heading",
              "label": "Extra large"
            }
          ],
          "default": "h2"
        }
      ]
    },
    {
      "type": "subheading",
      "name": "Subheading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Subheading",
          "default": "Subheading"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 2,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Entice customers to sign up for your mailing list with discounts or exclusive offers.</p>"
        },
        {
          "type": "select",
          "id": "text_size",
          "label": "Text size",
          "options": [
            {
              "value": "small-text",
              "label": "Small"
            },
            {
              "value": "",
              "label": "Medium"
            },
            {
              "value": "enlarge-text",
              "label": "Large"
            }
          ],
          "default": ""
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "Button 1"
        },
        {
          "type": "text",
          "id": "button_1_label",
          "label": "Button label",
          "default": "Close"
        },
        {
          "type": "select",
          "id": "button_1_style",
          "label": "Button style",
          "options": [
            {
              "value": "link",
              "label": "Link"
            },
            {
              "value": "btn btn--primary",
              "label": "Primary button"
            },
            {
              "value": "btn btn--secondary",
              "label": "Secondary button"
            }
          ],
          "default": "btn btn--primary"
        },
        {
          "type": "url",
          "id": "button_1_link",
          "info": "Clicking the button will close the popup.",
          "label": "Button link"
        },
        {
          "type": "header",
          "content": "Button 2"
        },
        {
          "type": "text",
          "id": "button_2_label",
          "label": "Button label"
        },
        {
          "type": "select",
          "id": "button_2_style",
          "label": "Button style",
          "options": [
            {
              "value": "link",
              "label": "Link"
            },
            {
              "value": "btn btn--primary",
              "label": "Primary button"
            },
            {
              "value": "btn btn--secondary",
              "label": "Secondary button"
            }
          ],
          "default": "btn btn--secondary"
        },
        {
          "type": "url",
          "id": "button_2_link",
          "info": "Clicking the button will close the popup.",
          "label": "Button link"
        }
      ]
    },
    {
      "type": "countdown",
      "name": "Countdown timer",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "end_date",
          "label": "End date",
          "info": "Required. Format: YYYY-MM-DD."
        },
        {
          "type": "text",
          "id": "end_time",
          "label": "End time (optional)",
          "info": "Format: 17:00 (24 hour clock). Uses the store's timezone."
        },
        {
          "type": "richtext",
          "id": "end_text",
          "label": "End text",
          "info": "This shows when the date and time elapses."
        },
        {
          "type": "checkbox",
          "id": "hide_on_end",
          "label": "Hide the timer when the date and time elapses",
          "default": false
        },
        {
          "type": "range",
          "id": "number_size",
          "min": 20,
          "max": 60,
          "step": 2,
          "unit": "px",
          "label": "Number size",
          "default": 40
        },
        {
          "type": "select",
          "id": "number_font",
          "label": "Number font",
          "options": [
            {
              "label": "Text font",
              "value": "base"
            },
            {
              "label": "Heading font",
              "value": "heading"
            }
          ],
          "default": "base"
        },
        {
          "type": "checkbox",
          "id": "show_timer_labels",
          "label": "Show labels",
          "default": true
        }
      ]
    },
    {
      "type": "newsletter-signup",
      "name": "Email sign-up",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "Customers who subscribe will have an account created for them. [Learn more](https://help.shopify.com/en/manual/customers/manage-customers)"
        }
      ]
    },
    {
      "type": "social",
      "name": "Social links",
      "limit": 1
    }
  ],
  "presets": [
    {
      "name": "Pop-up",
      "category": "Feature",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "text"
        },
        {
          "type": "newsletter-signup"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  }
}
{% endschema %}
