{%- assign color_scheme = section.settings.color_scheme -%}

{%- style -%}
  {%- if section.settings.background_mode == 'color' -%}
    #{{ section.id }} { background: {{ section.settings.background_color }}; }
  {%- elsif section.settings.background_mode == 'simple-gradient' -%}
    #{{ section.id }} {
      background: {% render 'custom-gradient',
                      type: section.settings.background_gradient_curve,
                      start_color: section.settings.background_gradient_stop_1,
                      end_color: section.settings.background_gradient_stop_2
                  %};
    }
  {%- elsif section.settings.background_mode == 'advanced-gradient' -%}
    #{{ section.id }} { background: {{ section.settings.background_gradient }}; }
  {%- endif -%}
{%- endstyle -%}

<div id="{{ section.id }}" class="section-background{% if section.settings.background_mode == 'image' %} relative{% endif %}">
{%- if section.settings.background_mode == 'image' and section.settings.background_image != blank -%}
  <div class="absolute inset-0">
    {%- render 'image',
      image: section.settings.background_image,
      src_width: 1400,
      widths: '480, 980, 1200, 1400, 1600, 1920, 2560, 3200',
      class: 'img-fit cover',
      sizes: '100vw'
    -%}
    </div>
{%- endif -%}

  <div class="flex{% if section.settings.full_width == false %} container{% endif %}">
    <div class="section
                {%- if section.settings.full_width %} section--full-width section--padded-more{% else %} section--standard{% endif %}
                {%- if section.settings.full_width == false %} section--boundary-{{ section.settings.section_join_mode }}{% endif %}
                z-3
                {%- if section.settings.full_width == false %} section--border-radius{% endif %}
                color-scheme
                {%- if section.settings.full_width and section.settings.background_mode != 'default' %} color-scheme--no-bg{% endif %}
                color-scheme--{{ color_scheme }}">
      <div class="container container--text{% if section.settings.mob_center_text %} md-down:text-center{% endif %}" {%- render 'animation-attrs', attrs: 'data-cc-animate' -%}>
        <div class="reading-width--fixed">
          {%- if section.settings.heading != blank -%}
            <{% if section.settings.heading_h1 %}h1{% else %}h2{% endif %} class="section__heading {{ section.settings.heading_size }} {{ section.settings.heading_align }}">{{ section.settings.heading | escape }}</{% if section.settings.heading_h1 %}h1{% else %}h2{% endif %}>
          {%- endif -%}

          {%- form 'contact', id: form_id, class: 'form' -%}
            <div class="form__grid grid grid-cols-2 gap-x-theme gap-y-6" {%- render 'animation-attrs', attrs: 'data-cc-animate' -%}>
              {%- for block in section.blocks -%}
                <div class="col-span-2{% if block.settings.half_width %} md:col-span-1{% endif %}{% if block.settings.required %} is-required{% endif %}" {{ block.shopify_attributes }}>
                  {%- case block.type -%}
                    {%- when 'name' -%}
                      <label class="label" for="{{ form_id }}-name">{{ 'contact.form.name' | t }}</label>
                      <input type="text"
                            class="input w-full"
                            id="{{ form_id }}-name"
                            name="contact[{{ 'contact.form.name' | t }}]"
                            autocomplete="name"
                            value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
                            {%- if block.settings.required %}
                              aria-required="true"
                              required
                            {%- endif %}>

                    {%- when 'email' -%}
                      <label class="label" for="{{ form_id }}-email">{{ 'contact.form.email' | t }}</label>
                      <input type="email"
                            class="input w-full"
                            id="{{ form_id }}-email"
                            name="contact[email]"
                            autocomplete="email"
                            value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
                            {%- if form.errors contains 'email' %}
                              aria-invalid="true"
                              aria-describedby="{{ form_id }}-email-error"
                            {%- endif %}
                            {%- if block.settings.required %}
                              aria-required="true"
                              required
                            {%- endif %}>

                    {%- when 'phone' -%}
                      <label class="label" for="{{ form_id }}-phone">{{ 'contact.form.phone' | t }}</label>
                      <input type="tel"
                            class="input w-full"
                            id="{{ form_id }}-phone"
                            name="contact[{{ 'contact.form.phone' | t }}]"
                            pattern="[0-9\-]*"
                            autocomplete="tel"
                            value="{% if form.phone %}{{ form.phone }}{% elsif customer %}{{ customer.phone }}{% endif %}"
                            {%- if block.settings.required %}
                              aria-required="true"
                              required
                            {%- endif %}>

                    {%- when 'body' -%}
                      <label class="label" for="{{ form_id }}-body">{{ 'contact.form.message' | t }}</label>
                      <textarea class="input w-full"
                                id="{{ form_id }}-body"
                                name="contact[{{ 'contact.form.message' | t }}]"
                                rows="8"
                                {%- if block.settings.required %}
                                  aria-required="true"
                                  required
                                {%- endif %}>
                        {{- form.body -}}
                      </textarea>

                    {%- when 'custom' -%}
                      {%- if block.settings.title != blank -%}
                        {%- assign field_handle = block.settings.title | handleize -%}
                        <label class="label" for="{{ form_id }}-field-{{ forloop.index }}">
                          {{- block.settings.title -}}
                        </label>
                        {%- if block.settings.type == 'textarea' -%}
                          <textarea class="input w-full"
                                    id="{{ form_id }}-field-{{ forloop.index }}"
                                    name="contact[{{ field_handle }}]"
                                    rows="8"
                                    {%- if block.settings.required %}
                                      aria-required="true"
                                      required
                                    {%- endif %}>
                            {{- form[field_handle] -}}
                          </textarea>
                        {%- else -%}
                          <input type="{{ block.settings.type }}"
                                class="input w-full"
                                id="{{ form_id }}-field-{{ forloop.index }}"
                                name="contact[{{ field_handle }}]"
                                value="{{ form[field_handle] }}"
                                {%- if block.settings.type == 'tel' %}pattern="[0-9\-]*"{% endif %}
                                {%- if block.settings.required %}
                                  aria-required="true"
                                  required
                                {%- endif %}>
                        {%- endif -%}
                      {%- endif -%}

                    {%- when 'dropdown' -%}
                      {%- if block.settings.title != blank -%}
                        {%- liquid
                          assign field_handle = block.settings.title | handleize
                          assign field_options = block.settings.options | newline_to_br | strip_newlines | split: '<br />'
                          assign native_name = 'contact[' | append: field_handle | append: ']'
                          assign selected_value = form[field_handle] | default: field_options.first
                        -%}
                        <label class="label" for="{{ form_id }}-field-{{ forloop.index }}">
                          {{- block.settings.title -}}
                        </label>
                        <div class="select relative">
                          <select class="w-full input" name="{{ native_name }}" id="{{ form_id }}-field-{{ forloop.index }}">
                            {% for option in field_options %}
                              <option value="{{ option | escape }}"{% if option == selected_value %} selected{% endif %}>{{ option }}</option>
                            {% endfor %}
                          </select>
                        </div>
                      {%- endif -%}

                    {%- when 'text' -%}
                      {%- if block.settings.text != blank -%}
                          <div class="w-full rte">
                            {{ block.settings.text }}
                          </div>
                      {%- endif -%}

                    {%- when 'checkbox' -%}
                      {% if block.settings.title != blank %}
                        {%- assign title_handle = block.settings.title | handle -%}
                        <input
                          type="hidden"
                          name="contact[{{ title_handle }}]"
                          value="{{ block.settings.value_no | escape }}" />
                        <input
                          type="checkbox"
                          class="checkbox checkbox--small"
                          id="contact_{{ title_handle }}"
                          name="contact[{{ title_handle }}]"
                          value="{{ block.settings.value_yes | escape }}"
                          {%- if block.settings.required %} required{% endif %}
                          {% if form[title_handle] == block.settings.value_yes %} checked{% endif %} />
                        <label for="contact_{{ title_handle }}" class="required-inline label">
                          {{ block.settings.title | escape }}{% if block.settings.required %} *{% endif %}
                        </label>
                      {% endif %}

                  {%- endcase -%}

                  {%- if form.errors contains block.type -%}
                    <p class="form__field-error" id="{{ form_id }}-{{ block.type }}-error">
                      {{ form.errors.translated_fields[block.type] | capitalize }}
                      {{ form.errors.messages[block.type] }}
                    </p>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            </div>

            {%- if form.posted_successfully? -%}
              <div class="alert mt-8 bg-success-bg text-success-text" tabindex="-1" autofocus {%- render 'animation-attrs', attrs: 'data-cc-animate' -%}>
                {{ 'contact.form.post_success' | t }}
              </div>
            {%- elsif form.errors -%}
              <div class="alert mt-8 bg-error-bg text-error-text" tabindex="-1" autofocus {%- render 'animation-attrs', attrs: 'data-cc-animate' -%}>
                <h2 class="h5 text-current">{{ 'contact.form.error_heading' | t }}</h2>
                <ul class="styled-list">
                  <li>
                    <a class="link text-current" href="#{{ form_id }}-email">
                      {{- form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] -}}
                    </a>
                  </li>
                </ul>
              </div>
            {%- endif -%}

            {%- if section.blocks.size > 0 -%}
              <div class="mt-6" {%- render 'animation-attrs', attrs: 'data-cc-animate' -%}>
                <button class="{{ section.settings.button_style }} w-full md:w-auto">{{ 'contact.form.send' | t }}</button>
              </div>
            {%- endif -%}
          {%- endform -%}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Contact form",
  "tag": "section",
  "class": "cc-contact-form",
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Contact form",
      "label": "Contact us"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        {
          "value": "h4",
          "label": "Extra extra small"
        },
        {
          "value": "h3",
          "label": "Extra small"
        },
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "x-large-heading",
          "label": "Large"
        },
        {
          "value": "xx-large-heading",
          "label": "Extra large"
        }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_align",
      "label": "Heading alignment",
      "options": [
        {
          "value": "text-start",
          "label": "Left"
        },
        {
          "value": "text-center",
          "label": "Center"
        },
        {
          "value": "text-end",
          "label": "Right"
        }
      ],
      "default": "text-center"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button",
      "options": [
        {
          "value": "btn btn--primary",
          "label": "Primary button"
        },
        {
          "value": "btn btn--secondary",
          "label": "Secondary button"
        }
      ],
      "default": "btn btn--primary"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "background_mode",
      "label": "Section background",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "color",
          "label": "Color"
        },
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "simple-gradient",
          "label": "Simple gradient"
        },
        {
          "value": "advanced-gradient",
          "label": "Advanced gradient"
        }
      ],
      "default": "default"
    },
    {
      "visible_if": "{{ section.settings.background_mode == 'color' }}",
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "visible_if": "{{ section.settings.background_mode == 'image' }}",
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "visible_if": "{{ section.settings.background_mode == 'simple-gradient' }}",
      "type": "color",
      "id": "background_gradient_stop_1",
      "label": "Gradient start",
      "default": "#cccccc"
    },
    {
      "visible_if": "{{ section.settings.background_mode == 'simple-gradient' }}",
      "type": "color",
      "id": "background_gradient_stop_2",
      "label": "Gradient end",
      "default": "#ffffff"
    },
    {
      "visible_if": "{{ section.settings.background_mode == 'simple-gradient' }}",
      "type": "select",
      "id": "background_gradient_curve",
      "label": "Gradient style",
      "options": [
        {
          "value": "linear",
          "label": "Linear"
        },
        {
          "value": "ease-up",
          "label": "Ease up"
        },
        {
          "value": "ease-down",
          "label": "Ease down"
        }
      ],
      "default": "linear"
    },
    {
      "visible_if": "{{ section.settings.background_mode == 'advanced-gradient' }}",
      "type": "color_background",
      "id": "background_gradient",
      "label": "Advanced gradient",
      "default": "linear-gradient(#f8f1f4, #f8f1f4 12%, #c8bdc1, #e8dccc 92%)"
    },
    {
      "visible_if": "{{ section.settings.full_width == false }}",
      "type": "header",
      "content": "Layout"
    },
    {
      "visible_if": "{{ section.settings.full_width == false }}",
      "type": "select",
      "id": "section_join_mode",
      "label": "Boundary above section",
      "info": "Some sections support seamless joining",
      "options": [
        {
          "value": "default",
          "label": "Default"
        },
        {
          "value": "tight",
          "label": "Tight"
        },
        {
          "value": "join",
          "label": "Join"
        }
      ],
      "default": "default"
    }
  ],
  "blocks": [
    {
      "type": "name",
      "name": "Name",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "required",
          "label": "Required",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "half_width",
          "label": "Half width on large screens",
          "default": false
        }
      ]
    },
    {
      "type": "email",
      "name": "Email",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "REQUIRED - Contact form will not work if this block is removed."
        },
        {
          "type": "checkbox",
          "id": "required",
          "label": "Required",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "half_width",
          "label": "Half width on large screens",
          "default": false
        }
      ]
    },
    {
      "type": "phone",
      "name": "Phone",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "required",
          "label": "Required",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "half_width",
          "label": "Half width on large screens",
          "default": false
        }
      ]
    },
    {
      "type": "body",
      "name": "Message",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "required",
          "label": "Required",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "half_width",
          "label": "Half width on large screens",
          "default": false
        }
      ]
    },
    {
      "type": "custom",
      "name": "Custom input",
      "settings": [
        {
          "type": "paragraph",
          "content": "Custom inputs require a label, and that label may only be used once in the form."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Label",
          "default": "Custom input"
        },
        {
          "type": "select",
          "id": "type",
          "label": "Input type",
          "options": [
            {
              "value": "text",
              "label": "Text (single line)"
            },
            {
              "value": "textarea",
              "label": "Text (multi line)"
            },
            {
              "value": "email",
              "label": "Email"
            },
            {
              "value": "tel",
              "label": "Phone"
            },
            {
              "value": "number",
              "label": "Number"
            },
            {
              "value": "url",
              "label": "URL"
            }
          ],
          "default": "text"
        },
        {
          "type": "checkbox",
          "id": "required",
          "label": "Required",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "half_width",
          "label": "Half width on large screens",
          "default": false
        }
      ]
    },
    {
      "type": "dropdown",
      "name": "Dropdown",
      "settings": [
        {
          "type": "paragraph",
          "content": "Dropdowns require a label, and that label may only be used once in the form."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Label",
          "default": "Dropdown"
        },
        {
          "type": "textarea",
          "id": "options",
          "label": "Options",
          "info": "One option per line.",
          "default": "Option 1\nOption 2\nOption 3"
        },
        {
          "type": "checkbox",
          "id": "half_width",
          "label": "Half width on large screens",
          "default": false
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Text content</p>"
        },
        {
          "type": "checkbox",
          "id": "half_width",
          "label": "Half width on large screens",
          "default": false
        }
      ]
    },
    {
      "type": "checkbox",
      "name": "Checkbox",
      "settings": [
        {
          "type": "paragraph",
          "content": "Checkboxes require a label, and that label may only be used once in the form."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Label",
          "default": "Custom checkbox"
        },
        {
          "type": "text",
          "id": "value_no",
          "label": "Deselected value",
          "default": "No"
        },
        {
          "type": "text",
          "id": "value_yes",
          "label": "Selected value",
          "default": "Yes"
        },
        {
          "type": "checkbox",
          "id": "half_width",
          "label": "Half width on large screens",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "required",
          "label": "Required",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Contact form",
      "category": "Forms",
      "blocks": [
        {
          "type": "name",
          "settings": {
            "half_width": true
          }
        },
        {
          "type": "email",
          "settings": {
            "half_width": true
          }
        },
        {
          "type": "phone",
          "settings": {
            "half_width": true
          }
        },
        {
          "type": "dropdown",
          "settings": {
            "half_width": true
          }
        },
        {
          "type": "body"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": [
      "header",
      "footer",
      "aside"
    ]
  }
}
{% endschema %}
