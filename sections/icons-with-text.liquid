{%- if section.blocks.size > 0 -%}
  <link rel="stylesheet" href="{{ 'icons-with-text.css' | asset_url }}">

  {%- liquid
    assign color_scheme = section.settings.color_scheme
    assign grid_classes = 'auto-cols-1'
    if section.blocks.size == 2
      assign grid_classes = grid_classes | append: ' sm:auto-cols-2'
    elsif section.blocks.size == 3
      assign grid_classes = grid_classes | append: ' sm:auto-cols-2 lg:auto-cols-3'
    elsif section.blocks.size > 3
      assign grid_classes = grid_classes | append: ' sm:auto-cols-2 md:auto-cols-3 lg:auto-cols-4'
    endif
  -%}

  <div class="icons-with-text section section--full-width  {{ section.settings.height }} color-scheme color-scheme--{{ color_scheme }}">
    <div class="container">
      {%- if section.settings.heading != blank -%}
        <h2 class="section__heading {{ section.settings.heading_size }}">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      <carousel-slider class="carousel block relative" inactive>
        <div class="slider-nav slider-nav--alt flex justify-between absolute no-js-hidden">
          <button type="button" class="slider-nav__btn btn text-current has-ltr-icon" name="prev" aria-controls="slider-{{ section.id }}" aria-label="{{ 'general.slider.previous' | t }}">
            {% render 'icon-chevron-left' %}
          </button>
          <button type="button" class="slider-nav__btn btn text-current has-ltr-icon" name="next" aria-controls="slider-{{ section.id }}" aria-label="{{ 'general.slider.next' | t }}">
            {% render 'icon-chevron-right' %}
          </button>
        </div>

        <div class="slider slider--no-container slider--no-scrollbar relative" id="slider-{{ section.id }}">
          <ul class="slider__grid grid grid-flow-col gap-x-theme {{ grid_classes }}">
            {%- for block in section.blocks -%}
              <li class="slider__item flex{% if section.settings.icon_position == 'above' %} flex-col{% endif %} justify-center items-center" {{ block.shopify_attributes }}>
                {%- if block.settings.custom_icon != blank -%}
                  {%- liquid
                    assign icon_size_2x = section.settings.icon_size | times: 2
                    assign icon_widths = section.settings.icon_size | append: ', ' | append: icon_size_2x
                    assign icon_style = 'width: ' | append: section.settings.icon_size | append: 'px;'
                  -%}
                  {{ block.settings.custom_icon | image_url: width: icon_size_2x | image_tag: widths: icon_widths, loading: 'lazy', style: icon_style }}
                {%- elsif block.settings.usp_icon != 'none' -%}
                  {% render 'icon-usp',
                    icon: block.settings.usp_icon,
                    width: section.settings.icon_size,
                    height: section.settings.icon_size
                  %}
                {%- else -%}
                  {% render 'icon',
                    icon: block.settings.icon,
                    width: section.settings.icon_size,
                    height: section.settings.icon_size
                  %}
                {%- endif -%}

                {% unless block.settings.heading == blank and block.settings.text == blank %}
                  <div class="icons-with-text__text{% if section.settings.icon_position == 'above' %} mt-4 text-center{% endif %}">
                    {%- if block.settings.heading != blank -%}
                      <p class="m-0"><strong>{{ block.settings.heading | escape }}</strong></p>
                    {%- endif -%}

                    {%- if block.settings.text != blank -%}
                      {{ block.settings.text }}
                    {%- endif -%}
                  </div>
                {% endunless %}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </carousel-slider>
    </div>
  </div>
{%- endif -%}

