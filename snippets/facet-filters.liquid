{% comment %}
  Parameters:
  - results {Object} - Results object (collection or search).

  Usage:
  {% render 'facet-filters', results: collection %}
{% endcomment %}

{%- liquid
  assign has_price_filter = false
  assign active_filters_count = 0
  assign sort_by = results.sort_by | default: results.default_sort_by

  for filter in results.filters
    if filter.type == 'price_range'
      assign has_price_filter = true

      if filter.min_value.value
        assign active_filters_count = active_filters_count | plus: 1
      endif
      if filter.max_value.value
        assign active_filters_count = active_filters_count | plus: 1
      endif
    else
      assign active_filters_count = active_filters_count | plus: filter.active_values.size
    endif
  endfor

  if results.url
    if results.current_vendor or results.current_type
      assign clear_filters_url = results.url | append: '&sort_by=' | append: sort_by
    else
      assign clear_filters_url = results.url | append: '?sort_by=' | append: sort_by
    endif
  else
    assign terms = results.terms | escape
    assign types = results.types | join: ',' | escape
  endif

  if results.products_count
    assign results_count = results.products_count
  else
    assign results_count = results.results_count
  endif
-%}

{%- unless results.url -%}
  {%- capture clear_filters_url -%}
    ?type={{ types }}&options%5Bprefix%5D=last&q={{ terms }}&sort_by={{ sort_by }}
  {%- endcapture -%}
{%- endunless -%}

<link rel="stylesheet" href="{{ 'facet-filters.css' | asset_url }}" media="print" onload="this.media='all'">
{%- if has_price_filter -%}
  <link rel="stylesheet" href="{{ 'price-range.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

<script src="{{ 'facet-filters.js' | asset_url }}" defer></script>
{%- if has_price_filter -%}
  <script src="{{ 'price-range.js' | asset_url }}" defer></script>
{%- endif -%}

<facet-filters class="facets drawer fixed top-0 right-0 flex flex-col w-full has-motion" id="facet-filters" data-name="facet-filters" data-filtering="{{ section.settings.enable_filtering }}" data-sorting="{{ section.settings.enable_sorting }}" role="dialog" aria-labelledby="facets-title" aria-modal="true" aria-hidden="true" tabindex="-1">
  <header class="drawer__header flex justify-between items-center">
    <h2 class="drawer__heading mb-0 font-heading leading-normal" id="facets-title">
      {%- if section.settings.enable_filtering and section.settings.enable_sorting -%}
        {{ 'products.filtering.filter_sort' | t }}
      {%- elsif section.settings.enable_filtering -%}
        {{ 'products.filtering.filter' | t }}
      {%- elsif section.settings.enable_sorting -%}
        {{ 'products.sorting.sort_button' | t }}
      {%- endif -%}
    </h2>
    <button type="button" class="drawer__close-btn js-close-drawer" aria-label="{{ 'accessibility.close' | t }}">
      {% render 'icon-close' %}
    </button>
  </header>

  <div class="drawer__content">
    <form id="facets" data-filter-section-id="{{ section.id }}" novalidate>
      {%- if results.current_vendor or results.current_type -%}
        <input type="hidden" name="q" value="{{ results.current_vendor }}{{ results.current_type }}">
      {%- elsif results.terms -%}
        <input type="hidden" name="q" value="{{ results.terms | escape }}">
        <input type="hidden" name="type" value="{{ types }}">
        <input name="options[prefix]" type="hidden" value="last">
      {%- endif -%}

      <div class="facets__active-filters"{% if active_filters_count == 0 %} hidden{% endif %}>
        <div class="active-filters"{% if active_filters_count == 0 %} hidden{% endif %}>
          {%- for filter in results.filters -%}
            {%- for value in filter.active_values -%}
              <a href="{{ value.url_to_remove }}" class="active-filter flex items-center text-sm">
                <span class="active-filter__icon">
                  {%- render 'icon-close' %}
                </span>
                {%- if filter.type == 'boolean' %}{{ filter.label | escape }}:{% endif %}
                {{ value.label | escape -}}
              </a>
            {%- endfor -%}

            {% if filter.type == "price_range" %}
              {%- if filter.min_value.value != nil or filter.max_value.value != nil -%}
                <a href="{{ filter.url_to_remove }}" class="active-filter flex items-center text-sm">
                  <span class="active-filter__icon">
                    {%- render 'icon-close' %}
                  </span>
                  {%- if filter.min_value.value %}{{ filter.min_value.value | money }}{% else %}{{ 0 | money }}{% endif %} -
                  {% if filter.max_value.value %}{{ filter.max_value.value | money }}{% else %}{{ filter.range_max | money }}{% endif -%}
                </a>
              {%- endif -%}
            {% endif %}
          {%- endfor -%}
        </div>

        <div class="mt-6 flex relative items-center">
          <a href="{{ clear_filters_url }}" class="link text-sm js-clear-all"{% if active_filters_count == 0 %} hidden{% endif %}>
            {{- 'products.filtering.clear_all' | t -}}
          </a>
        </div>
      </div>

      <div class="facets__filters">
        {%- if section.settings.enable_sorting -%}
          <details-disclosure>
            <details class="filter disclosure" id="filter-sort" data-type="sort" data-index="0"{% if section.settings.expand_filters %} open{% endif %}>
              <summary class="filter__toggle">
                <div class="flex items-center">
                  <span class="filter__heading font-heading leading-normal font-normal mb-0 me-2">{{- 'products.sorting.sort_by_label' | t -}}</span>
                  <span class="disclosure__toggle">
                    {%- if settings.disclosure_toggle == 'plus' -%}
                      {% render 'icon-plus' %}
                    {%- else -%}
                      {% render 'icon-chevron-down' %}
                    {%- endif -%}
                  </span>
                </div>
              </summary>
              <div class="disclosure__panel has-motion">
                <div class="disclosure__content">
                  <div class="filter__content">
                    <ul role="list">
                      {%- for option in results.sort_options -%}
                        {%- liquid
                            if section.settings.sort_show_featured == false and option.value == 'manual' and results.default_sort_by != 'manual'
                              continue
                            endif
                            if section.settings.sort_show_best == false and option.value == 'best-selling' and results.default_sort_by != 'best-selling'
                              continue
                            endif
                            if section.settings.sort_show_alpha == false and option.value == 'title-ascending' and results.default_sort_by != 'title-ascending'
                              continue
                            endif
                            if section.settings.sort_show_alpha == false and option.value == 'title-descending' and results.default_sort_by != 'title-descending'
                              continue
                            endif
                            if section.settings.sort_show_price == false and option.value == 'price-ascending' and results.default_sort_by != 'price-ascending'
                              continue
                            endif
                            if section.settings.sort_show_price == false and option.value == 'price-descending' and results.default_sort_by != 'price-descending'
                              continue
                            endif
                            if section.settings.sort_show_date == false and option.value == 'created-ascending' and results.default_sort_by != 'created-ascending'
                              continue
                            endif
                            if section.settings.sort_show_date == false and option.value == 'created-descending' and results.default_sort_by != 'created-descending'
                              continue
                            endif
                          -%}
                        <li>
                          <input type="radio"
                                  class="checkbox js-drawer-sort-by"
                                  id="filter-sort-{{ forloop.index }}"
                                  name="sort_by"
                                  value="{{ option.value | escape }}"
                                  {% if option.value == sort_by %}checked{% endif %}>
                          <label for="filter-sort-{{ forloop.index }}" class="flex items-start w-full m-0">
                            <span class="flex-auto text-sm">{{- option.name | escape -}}</span>
                          </label>
                        </li>
                      {%- endfor -%}
                    </ul>
                  </div>
                </div>
              </div>
            </details>
          </details-disclosure>
        {%- endif -%}

        {%- if section.settings.enable_filtering -%}
          {%- for filter in results.filters -%}
            {%- liquid
              if section.settings.hide_tag_filter and filter.param_name == 'filter.p.tag'
                continue
              endif

              assign filter_group_is_swatches = false
              assign has_active_filters = false
              assign active_count = filter.active_values.size
              assign selectable_filter_count = 0

              if filter.presentation == 'swatch' or filter.presentation == 'image'
                assign filter_group_is_swatches = true
              endif

              assign filter_group_is_inline = false
              if filter.type == 'list' and section.settings.button_grid_filter_name contains filter.label
                assign filter_group_is_inline = true
              endif

              assign filter_group_is_two_columns = false
              if section.settings.filter_two_columns
                if filter.type == 'boolean' or filter.type == 'list'
                  assign filter_group_is_two_columns = true
                endif
              endif

              if filter.type == 'price_range'
                if filter.min_value.value
                  assign has_active_filters = true
                  assign active_count = active_count | plus: 1
                endif
                if filter.max_value.value
                  assign has_active_filters = true
                  assign active_count = active_count | plus: 1
                endif
              else
                if active_count > 0
                  assign has_active_filters = true
                endif
              endif
            -%}

            {%- capture filter_markup -%}
              {%- case filter.type -%}
                {%- when 'boolean' or 'list' -%}
                  <ul class="filter__list{% if filter_group_is_inline %} filter__list--inline{% elsif filter_group_is_two_columns %} filter__list--columns{% endif %}" role="list">
                    {%- for value in filter.values -%}
                      {%- assign selectable_filter_count = selectable_filter_count | plus: 1 -%}
                      <li {%- if selectable_filter_count > section.settings.max_filter_options %} class="js-hidden"{% endif %}>
                        <input type="checkbox"
                              class="{% unless filter_group_is_swatches %}checkbox {% endunless %}visually-hidden focus-label-before"
                              id="filter-{{ filter.param_name | escape }}-{{ forloop.index }}"
                              name="{{ value.param_name }}"
                              value="{{ value.value | escape }}"
                              {% if value.active %}checked{% endif %}
                              {% if value.count == 0 and value.active == false %}disabled{% endif %}>
                        <label for="filter-{{ filter.param_name | escape }}-{{ forloop.index }}"
                              class="filter__label flex items-start w-full m-0">
                          {%- if filter_group_is_swatches -%}
                            <span class="filter__swatch"
                              data-swatch="{{ value.label | replace: '"', '' | downcase }}"
                              {% if value.swatch.color %}style="--swatch-color: rgb({{ value.swatch.color.rgb }})"{%- endif %}>
                              {%- if value.swatch.image -%}
                                {%- render 'image', image: value.swatch.image, src_width: 24, srcset_2x: true, class: 'img-fit' -%}
                              {%- endif -%}
                            </span>
                          {%- endif -%}
                          <span class="filter__text{% unless filter_group_is_inline or filter_group_is_two_columns %} flex-auto{% endunless %} text-sm">{{ value.label | escape }}</span>
                          {% if section.settings.show_filter_counts -%}
                            <span class="filter__count text-sm">({{ value.count }})</span>
                          {%- endif -%}
                        </label>
                      </li>
                    {%- endfor -%}
                  </ul>

                {%- when 'price_range' -%}
                  {%- assign selectable_filter_count = selectable_filter_count | plus: 1 -%}
                  {% render 'price-range', filter: filter %}

              {%- endcase -%}
            {%- endcapture -%}

            {%- if selectable_filter_count > 0 -%}
              <details-disclosure>
                <details class="filter disclosure" id="filter-{{ filter.param_name | escape }}" data-type="{{ filter.type }}" data-index="{{ forloop.index }}"{% if section.settings.expand_filters %} open{% endif %}>
                  <summary class="filter__toggle">
                    <div class="flex items-center">
                      <span class="filter__heading font-heading leading-normal font-normal mb-0 me-2">{{ filter.label | escape }}</span>
                      {%- if section.settings.show_active_filter_counts and active_count > 0 -%}
                        <span class="me-2">({{ active_count }})</span>
                      {%- endif -%}
                      <span class="disclosure__toggle">
                        {%- if settings.disclosure_toggle == 'plus' -%}
                          {% render 'icon-plus' %}
                        {%- else -%}
                          {% render 'icon-chevron-down' %}
                        {%- endif -%}
                      </span>
                    </div>
                  </summary>
                  <div class="disclosure__panel has-motion">
                    <div class="disclosure__content">
                      <div class="filter__content">
                        {{- filter_markup -}}
                      </div>

                      <div class="disclosure__show-more flex relative items-center">
                        {%- if selectable_filter_count > section.settings.max_filter_options -%}
                          <button type="button" class="filter__more link text-sm js-show-more" data-more-text="{{ 'products.filtering.show_more' | t }}" data-less-text="{{ 'products.filtering.show_less' | t }}">
                            {{- 'products.filtering.show_more' | t -}}
                          </button>
                        {%- endif -%}

                        <div class="filter__clear"{% if has_active_filters == false %} hidden{% endif %}>
                          <a href="{{ filter.url_to_remove }}" class="link text-sm js-clear-filter">
                            {{- 'products.filtering.clear' | t -}}
                          </a>
                        </div>
                      </div>
                    </div>
                  </div>
                </details>
              </details-disclosure>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>
    </form>
  </div>

  <footer class="drawer__footer">
    <div class="facets__footer flex flex-col sm:flex-row sm:justify-between sm:items-center">
      <button type="button" class="btn btn--primary md:px-12 js-close-drawer">
        {{- 'products.filtering.show_result_count' | t: count: results_count -}}
      </button>
      <a href="{{ clear_filters_url }}" class="link text-sm mt-4 mx-auto sm:mt-0 sm:ms-4 sm:me-0 js-clear-all"{% if active_filters_count == 0 %} hidden{% endif %}>
        {{- 'products.filtering.clear_all' | t -}}
      </a>
    </div>
  </footer>
</facet-filters>
