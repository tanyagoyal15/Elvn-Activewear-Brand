<div id="matching-drawer" class="matching-drawer">

    <div class="drawer-overlay"></div>
  
    <div class="drawer-panel">
  
      <!-- HEADER -->
      <div class="drawer-header">
        <div class="drawer-title">Shop the set</div>
        <button class="drawer-close">×</button>
      </div>
  
      <!-- CONTENT -->
      <div class="drawer-content"></div>
  
      <!-- FOOTER -->
      <div class="drawer-footer">
        <div class="drawer-total">
          <span>Total</span>
          <span class="total"></span>
        </div>

        {% comment %}
        <div class="discount-note">
            Get 10% off when you buy the full set
        </div>
        {% endcomment %}

        <button class="drawer-cta">
          Add full look
        </button>
      </div>
  
    </div>
</div>


  <style>

  /* ── DRAWER SHELL ── */

  .matching-drawer {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
  }
  .matching-drawer.open { pointer-events: auto; }

  .drawer-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.3);
    backdrop-filter: blur(3px);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .matching-drawer.open .drawer-overlay { opacity: 1; }

  .drawer-panel {
    position: absolute;
    background: #fafafa;
    display: flex;
    flex-direction: column;
    transition: transform 0.4s cubic-bezier(0.77, 0, 0.175, 1);
  }

  @media (max-width: 768px) {
    .drawer-panel {
      bottom: 0; left: 0;
      width: 100%;
      max-height: 88vh;
      transform: translateY(100%);
      border-radius: 16px 16px 0 0;
    }
  }
  @media (min-width: 769px) {
    .drawer-panel {
      top: 0; right: 0;
      width: 400px;
      height: 100%;
      transform: translateX(100%);
      border-left: 1px solid #ebebeb;
    }
  }
  .matching-drawer.open .drawer-panel { transform: translate(0,0); }


  /* ── HEADER ── */

  .drawer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    background: #fff;
    border-bottom: 1px solid #ebebeb;
    flex-shrink: 0;
  }
  .drawer-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #111;
  }
  .drawer-close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: #f2f2f2;
    border: none;
    border-radius: 50%;
    font-size: 16px;
    cursor: pointer;
    color: #555;
    transition: background 0.2s, color 0.2s;
  }
  .drawer-close:hover { background: #111; color: #fff; }


  /* ── SCROLLABLE CONTENT ── */

  .drawer-content {
    flex: 1;
    overflow-y: auto;
    padding: 0;
  }


  /* ── PRODUCT GROUP (TOP / BOTTOM) ── */

  .drawer-group {
     padding: 16px;
  }
  .drawer-group + .drawer-group {
    border-top: 1px solid #ebebeb;
  }

  .drawer-group-label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #bbb;
    margin-bottom: 14px;
  }


  /* ── PRODUCT ROW ── */

  .drawer-item {
    display: flex;
    gap: 14px;
  }

  .drawer-item > img {
    width: 76px;
    object-fit: cover;
    object-position: center top;
    border-radius: 6px;
    background: #f0f0ee;
    flex-shrink: 0;
    transition: opacity 0.2s ease;
  }
  .drawer-info { flex: 1; min-width: 0; }

  .drawer-name {
    font-size: 12px;
    font-weight: 500;
    line-height: 1.45;
    color: #111;
    margin-bottom: 8px;
  }


  /* ── COLOR PILLS ── */

  .color-row {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-bottom: 8px;
  }
  .color-btn {
    border: 1px solid #e0e0e0;
    padding: 3px 6px;
    font-size: 10px;
    letter-spacing: 0.03em;
    background: #fff;
    color: #444;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }
  .color-btn:hover { border-color: #888; }
  .color-btn.active {
    border-color: #111;
    background: #111;
    color: #fff;
  }


  /* ── SIZE PILLS ── */

  .variant-row {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-bottom: 8px;
  }
  .variant-btn {
    border: 1px solid #e0e0e0;
    padding: 3px 6px;
    font-size: 10px;
    letter-spacing: 0.04em;
    background: #fff;
    color: #444;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }
  .variant-btn:hover { border-color: #888; }
  .variant-btn.active {
    border-color: #111;
    background: #111;
    color: #fff;
  }
  .variant-btn.disabled {
    opacity: 0.35;
    cursor: not-allowed;
    border-color: #e8e8e8;
  }

  .drawer-price {
    font-size: 12px;
    color: #555;
    margin-top: 2px;
  }


  /* ── ALSO PAIR WITH  */

  .also-pair-section {
    padding: 16px 20px 22px;
    border-top: 1px solid #ebebeb;
  }
  .also-pair-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }
  .also-pair-divider {
    flex: 1;
    height: 1px;
    background: #e8e8e8;
  }
  .also-pair-label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #bbb;
    white-space: nowrap;
  }
  .also-pair-options {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    padding-bottom: 2px;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .also-pair-options::-webkit-scrollbar { display: none; }

  .also-pair-item {
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    width: 96px;
    border: 1px solid #e8e8e8;
    border-radius: 6px;
    overflow: hidden;
    cursor: pointer;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    text-align: left;
  }
  .also-pair-item:hover {
    border-color: #111;
    box-shadow: 0 3px 10px rgba(0,0,0,0.07);
  }

  .also-pair-img-wrap {
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #f0f0ee;
  }
  .also-pair-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    transition: transform 0.3s ease;
  }
  .also-pair-item:hover .also-pair-img-wrap img {
    transform: scale(1.04);
  }

  .also-pair-info {
    padding: 7px 8px 8px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .also-pair-name {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: #222;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .also-pair-type {
    display: inline-block;
    font-size: 8px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #999;
    background: #f5f5f3;
    padding: 2px 5px;
    border-radius: 2px;
    align-self: flex-start;
  }


  /* ── FOOTER ── */

  .drawer-footer {
    border-top: 1px solid #ebebeb;
    padding: 16px;
    background: #fff;
    flex-shrink: 0;
  }
  .drawer-total {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 12px;
    font-size: 13px;
    color: #111;
    font-weight: 500;
  }
  .drawer-cta {
    width: 100%;
    padding: 14px;
    background: #111;
    color: #fff;
    border: none;
    border-radius: 4px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }
  .drawer-cta:hover { opacity: 0.82; }
  .drawer-cta:disabled { opacity: 0.5; cursor: not-allowed; }

  </style>