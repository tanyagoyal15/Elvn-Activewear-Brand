<div id="matching-drawer" class="matching-drawer">

    <div class="drawer-overlay"></div>
  
    <div class="drawer-panel">
  
      <!-- HEADER -->
      <div class="drawer-header">
        <div class="drawer-title">Shop the set</div>
        <button class="drawer-close">×</button>
      </div>
  
      <!-- CONTENT -->
      <div class="drawer-content"></div>
  
      <!-- FOOTER -->
      <div class="drawer-footer">
        <div class="drawer-total">
          <span>Total</span>
          <span class="total"></span>
        </div>
  
        <button class="drawer-cta">
          Add full look
        </button>
      </div>
  
    </div>
</div>


  <style>
    /* =========================
   DRAWER BASE
========================= */

.matching-drawer {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
  }
  
  .matching-drawer.open {
    pointer-events: auto;
  }
  
  /* =========================
     OVERLAY
  ========================= */
  
  .drawer-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.35);
    backdrop-filter: blur(4px);
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  
  /* =========================
     PANEL BASE
  ========================= */
  
  .drawer-panel {
    position: absolute;
    background: #ffffff;
    display: flex;
    flex-direction: column;
    transition: transform 0.4s cubic-bezier(0.77, 0, 0.175, 1);
  }
  
  /* MOBILE (BOTTOM SHEET) */
  @media (max-width: 768px) {
    .drawer-panel {
      bottom: 0;
      left: 0;
      width: 100%;
      {% comment %} height: 75%; {% endcomment %}
      transform: translateY(100%);
      border-radius: 18px 18px 0 0;
    }
  }
  
  /* DESKTOP (SIDE PANEL) */
  @media (min-width: 769px) {
    .drawer-panel {
      top: 0;
      right: 0;
      width: 420px;
      height: 100%;
      transform: translateX(100%);
      border-left: 1px solid #eee;
    }
  }
  
  /* OPEN STATE */
  .matching-drawer.open .drawer-overlay {
    opacity: 1;
  }
  
  .matching-drawer.open .drawer-panel {
    transform: translate(0, 0);
  }
  
  /* =========================
     HEADER
  ========================= */
  
  .drawer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 20px;
    border-bottom: 1px solid #eee;
  }
  
  .drawer-title {
    font-size: 13px;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: #111;
  }
  
  .drawer-close {
    background: none;
    border: none;
    font-size: 20px;
    cursor: pointer;
    opacity: 0.6;
    transition: 0.2s;
  }
  
  .drawer-close:hover {
    opacity: 1;
  }
  
  /* =========================
     CONTENT
  ========================= */
  
  .drawer-content {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
  }
  
  /* =========================
     PRODUCT ITEM
  ========================= */
  
  .drawer-item {
    display: flex;
    gap: 14px;
    margin-bottom: 24px;
  }
  
  .drawer-item img {
    width: 70px;
    height: 90px;
    object-fit: cover;
    border-radius: 6px;
  }
  
  .drawer-info {
    flex: 1;
  }
  
  /* PRODUCT NAME */
  .drawer-name {
    font-size: 13px;
    line-height: 1.4;
    color: #111;
  }
  
  .drawer-color {
    font-size: 12px;
    color: #666;
    margin: 4px 0 8px;
    letter-spacing: 0.3px;
  }

  /* PRICE */
  .drawer-price {
    font-size: 13px;
    margin-top: 6px;
    color: #111;
  }
  
  /* =========================
     VARIANTS (SIZE)
  ========================= */
  
  .variant-row {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 8px;
  }
  
  .variant-btn {
    border: 1px solid #ddd;
    padding: 5px 10px;
    font-size: 11px;
    background: #fff;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .variant-btn:hover {
    border-color: #000;
  }
  
  .variant-btn.active {
    border-color: #000;
    background: #000;
    color: #fff;
  }
  
  /* =========================
     FOOTER
  ========================= */
  
  .drawer-footer {
    border-top: 1px solid #eee;
    padding: 18px 20px;
    background: #fff;
  }
  
  /* TOTAL ROW */
  .drawer-total {
    display: flex;
    justify-content: space-between;
    margin-bottom: 12px;
    font-size: 14px;
    color: #111;
  }
  
  /* CTA BUTTON */
  .drawer-cta {
    width: 100%;
    padding: 14px;
    background: #000;
    color: #fff;
    border: none;
    font-size: 13px;
    letter-spacing: 1px;
    text-transform: uppercase;
    cursor: pointer;
    transition: 0.25s ease;
  }
  
  .drawer-cta:hover {
    opacity: 0.85;
  }
  </style>