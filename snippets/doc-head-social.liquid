{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: shop.url
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description
  if og_description == blank
    assign og_description = 'Shop Elvn Active — premium activewear for women. Leggings, sports bras, shorts & co-ords built for yoga, running & everyday movement.'
  endif

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'collection'
    assign og_type = 'product.group'
  elsif request.page_type == 'password'
    assign og_url = shop.url
  endif
-%}

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">

{%- if page_image -%}
  <meta property="og:image" content="https:{{ page_image | image_url: width: 1200, height: 1200 }}">
  <meta property="og:image:secure_url" content="https:{{ page_image | image_url: width: 1200, height: 1200 }}">
  <meta property="og:image:width" content="{{ page_image.width }}">
  <meta property="og:image:height" content="{{ page_image.height }}">
{%- elsif shop.brand.cover_image -%}
  <meta property="og:image" content="https:{{ shop.brand.cover_image | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="https:{{ shop.brand.cover_image | image_url: width: 1200 }}">
{%- elsif shop.brand.logo -%}
  <meta property="og:image" content="https:{{ shop.brand.logo | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="https:{{ shop.brand.logo | image_url: width: 1200 }}">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta property="og:price:amount" content="{{ product.selected_or_first_available_variant.price | money_without_currency | strip_html }}">
  <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}

{%- unless settings.social_twitter_url == blank -%}
  {%- liquid
    assign split_twitter_url = settings.social_twitter_url | split: '/'
    for part in split_twitter_url reversed
      if part != blank
        assign twitter_handle = part
        break
      endif
    endfor
  -%}
  <meta name="twitter:site" content="@{{ twitter_handle }}">
{%- endunless -%}

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">
{%- if page_image -%}
  <meta name="twitter:image" content="https:{{ page_image | image_url: width: 1200, height: 1200 }}">
{%- elsif shop.brand.cover_image -%}
  <meta name="twitter:image" content="https:{{ shop.brand.cover_image | image_url: width: 1200 }}">
{%- elsif shop.brand.logo -%}
  <meta name="twitter:image" content="https:{{ shop.brand.logo | image_url: width: 1200 }}">
{%- endif -%}
