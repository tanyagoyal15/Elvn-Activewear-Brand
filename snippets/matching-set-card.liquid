{%- liquid
  assign card_image_width = image_width | default: 900
  assign card_image_height = image_height | default: 1200
  assign show_card_info = true
  if show_info == false
    assign show_card_info = false
  endif
-%}

<div class="matching-set-card" data-set="{{ set_index }}">
  
    <div class="set-image">
      <img
        src="{{ set.image | image_url: width: card_image_width }}"
        width="{{ card_image_width }}"
        height="{{ card_image_height }}"
        class="set-img"
        alt="{{ set.title | escape }}"
        loading="lazy"
      />
  
      {% render 'matching-set-hotspot',
        x: set.hotspot_top_x,
        y: set.hotspot_top_y,
        type: 'top',
        set_id: set_index
      %}
  
      {% render 'matching-set-hotspot',
        x: set.hotspot_bottom_x,
        y: set.hotspot_bottom_y,
        type: 'bottom',
        set_id: set_index
      %}

    </div>

    <div class="mini-card"></div>

    {%- if show_card_info -%}
      <div class="set-info">
        <div class="set-title">{{ set.title }}</div>
        <button class="open-drawer" data-set="{{ set_index }}">
          Shop the set
        </button>
      </div>
    {%- endif -%}
  
  </div>
