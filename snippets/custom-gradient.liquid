  rgb({{ start_color }} / {{ start_opacity | times: 0.2320 }}) 68%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.1815 }}) 72%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.1342 }}) 76%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.0955 }}) 80%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.0619 }}) 84%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.0348 }}) 88%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.0156 }}) 92%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.0040 }}) 96%,
  transparent 100%
);

{%- when 'linear' -%}
linear-gradient(to bottom, {{ start_color }}, {{ end_color }});
{%- endcase -%}
