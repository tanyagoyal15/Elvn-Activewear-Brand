{% comment %}
  Parameters:
  - type {String} - Gradient type. One of: 'down-out' 'ease-up' 'ease-down' 'linear'
  - start_color {String} - Starting color of gradient, 'r g b' format.
  - end_color {String} - Ending color of gradient, 'r g b' format (optional).
  - start_opacity {Number} - Opacity used at start of gradient (optional). Number between 0 and 1.

  Usage:
  {% render 'custom-gradient',
    type: 'down-out',
    start_color: settings.gradient_start_color.rgb,
    start_opacity: 0.9
  %}
{% endcomment %}

{%- case type -%}
{%- when 'up-out' -%}
linear-gradient(
  to top,
  rgb({{ start_color }} / {{ start_opacity }}) 0%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.738 }}) 19%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.541 }}) 34%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.382 }}) 47%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.278 }}) 56.5%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.194 }}) 65%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.126 }}) 73%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.075 }}) 80.2%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.042 }}) 86.1%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.021 }}) 91%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.008 }}) 95.2%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.002 }}) 98.2%,
  transparent 100%
);

{%- when 'down-out' -%}
linear-gradient(
  to bottom,
  rgb({{ start_color }} / {{ start_opacity }}) 0%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.738 }}) 19%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.541 }}) 34%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.382 }}) 47%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.278 }}) 56.5%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.194 }}) 65%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.126 }}) 73%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.075 }}) 80.2%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.042 }}) 86.1%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.021 }}) 91%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.008 }}) 95.2%,
  rgb({{ start_color }} / {{ start_opacity | times: 0.002 }}) 98.2%,
  transparent 100%
);

{%- when 'ease-up' -%}
linear-gradient(
  to top,
  {{ end_color }} 0%,
  {{ end_color | color_mix: start_color, 73.8 | color_to_rgb }} 19%,
  {{ end_color | color_mix: start_color, 54.1 | color_to_rgb }} 34%,
  {{ end_color | color_mix: start_color, 38.2 | color_to_rgb }} 47%,
  {{ end_color | color_mix: start_color, 27.8 | color_to_rgb }} 56.5%,
  {{ end_color | color_mix: start_color, 19.4 | color_to_rgb }} 65%,
  {{ end_color | color_mix: start_color, 12.6 | color_to_rgb }} 73%,
  {{ end_color | color_mix: start_color, 07.5 | color_to_rgb }} 80.2%,
  {{ end_color | color_mix: start_color, 04.2 | color_to_rgb }} 86.1%,
  {{ end_color | color_mix: start_color, 02.1 | color_to_rgb }} 91%,
  {{ end_color | color_mix: start_color, 00.8 | color_to_rgb }} 95.2%,
  {{ end_color | color_mix: start_color, 00.2 | color_to_rgb }} 98.2%,
  {{ start_color }} 100%
);

{%- when 'ease-down' -%}
linear-gradient(
  to bottom,
  {{ start_color }} 0%,
  {{ start_color | color_mix: end_color, 73.8 | color_to_rgb }} 19%,
  {{ start_color | color_mix: end_color, 54.1 | color_to_rgb }} 34%,
  {{ start_color | color_mix: end_color, 38.2 | color_to_rgb }} 47%,
  {{ start_color | color_mix: end_color, 27.8 | color_to_rgb }} 56.5%,
  {{ start_color | color_mix: end_color, 19.4 | color_to_rgb }} 65%,
  {{ start_color | color_mix: end_color, 12.6 | color_to_rgb }} 73%,
  {{ start_color | color_mix: end_color, 07.5 | color_to_rgb }} 80.2%,
  {{ start_color | color_mix: end_color, 04.2 | color_to_rgb }} 86.1%,
  {{ start_color | color_mix: end_color, 02.1 | color_to_rgb }} 91%,
  {{ start_color | color_mix: end_color, 00.8 | color_to_rgb }} 95.2%,
  {{ start_color | color_mix: end_color, 00.2 | color_to_rgb }} 98.2%,
  {{ end_color }} 100%
);

{%- when 'ease-up-out' -%}
linear-gradient(
  to bottom,
  rgb({{ start_color }} / {{ start_opacity }}) 0%,
