{%- liquid
  if block.settings.is_table_header
    assign cell_tag = 'th'
  else
    assign cell_tag = 'td'
  endif
-%}
<{{ cell_tag }} {{ block.shopify_attributes }}>{{- block.settings.title | escape -}}</{{ cell_tag }}>

{%- if block.settings.column_1 != blank -%}
  <{{ cell_tag }}>{{ block.settings.column_1 }}</{{ cell_tag }}>
{%- endif -%}

